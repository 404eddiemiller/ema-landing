---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Plus de voyageurs pour votre hôtel | Eddie Miller Agency"
  description="40 % des voyageurs planifient leur séjour avec l'IA. Votre hôtel apparaît-il quand ils demandent conseil à ChatGPT ? Diagnostic gratuit en 24h."
  canonicalUrl="https://eddiemiller.agency/hotels"
  ogTitle="Plus de voyageurs pour votre hôtel | Eddie Miller Agency"
  ogDescription="40 % des voyageurs planifient leur séjour avec l'IA. Votre hôtel apparaît-il sur ChatGPT ? Diagnostic gratuit en 24h."
>
  <Header />
  <main id="main-content">

    <!-- ═══════════════════ HERO ═══════════════════ -->
    <section class="relative overflow-hidden pt-32 pb-16 md:pt-40 md:pb-24 lg:pt-48 lg:pb-32 bg-cream" aria-label="Accroche principale">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl">
          <p class="inline-block px-3 py-1 mb-6 text-sm font-sans font-medium text-terracotta border border-terracotta/40 tracking-wide">
            Spécialiste hôtels
          </p>
          <h1 class="text-[2.5rem] md:text-[3.25rem] lg:text-[4rem] font-serif font-normal leading-[1.1] tracking-[-0.02em] text-charcoal">
            40&nbsp;% des voyageurs planifient leur séjour avec l'IA. Votre hôtel est-il dans leurs suggestions&nbsp;?
          </h1>
          <div class="mt-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>
          <p class="mt-6 md:mt-8 max-w-[65ch] text-lg md:text-xl font-sans font-normal leading-relaxed text-stone blur-in" style="transition-delay: 0.4s;">
            Avant même d'ouvrir Booking, les voyageurs demandent à ChatGPT où dormir à Paris. Si votre hôtel n'apparaît pas dans ces recommandations, vous perdez des réservations chaque&nbsp;jour.
          </p>
          <div class="flex flex-col sm:flex-row items-start gap-4 mt-8 md:mt-10 fade-up" style="transition-delay: 0.6s;">
            <a href="#audit" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark" onclick="plausible('CTA Click', {props: {location: 'hotels-hero'}})">
              Demander mon diagnostic gratuit
            </a>
            <a href="#comment-ca-marche" class="inline-flex items-center gap-1 px-2 py-4 font-sans font-medium text-base text-stone transition-all duration-200 hover:text-charcoal">
              Voir comment ça marche ↓
            </a>
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-2 mt-6 md:mt-8 fade-up" style="transition-delay: 0.75s;">
            <span class="text-sm font-sans text-stone/80">✓ Diagnostic en 24h</span>
            <span class="text-sm font-sans text-stone/80">✓ 100 % gratuit</span>
            <span class="text-sm font-sans text-stone/80">✓ 1 seul hôtel par quartier</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ SOCIAL PROOF ═══════════════════ -->
    <section class="py-12 md:py-16 bg-sand" aria-label="Plateformes optimisées">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <p class="text-center text-sm font-sans font-medium tracking-[0.1em] uppercase text-stone mb-8">
          Vos futurs clients planifient ici
        </p>
        <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10 lg:gap-14">
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">ChatGPT</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Claude</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Google Maps</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Gemini</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Perplexity</span>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ CE QUE VOUS RECEVEZ ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Ce que vous recevez">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
            Ce que vous recevez en&nbsp;24h
          </h2>
          <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-14 fade-up">
            Un diagnostic complet de votre hôtel, pas un simple email.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
            <div class="flex gap-4 scale-in card-hover" style="transition-delay: 0s;">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">Votre score de visibilité sur 100</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">Votre note globale sur ChatGPT, Claude, Perplexity, Gemini et Google Maps.</p>
              </div>
            </div>
            <div class="flex gap-4 scale-in card-hover" style="transition-delay: 0.1s;">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">Ce qui bloque vos voyageurs</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">Ce qui empêche ChatGPT de recommander votre hôtel quand un voyageur planifie son séjour à Paris.</p>
              </div>
            </div>
            <div class="flex gap-4 scale-in card-hover" style="transition-delay: 0.2s;">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">3 actions prioritaires</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">Les corrections classées par impact : ce qui fera bouger votre score le plus vite.</p>
              </div>
            </div>
            <div class="flex gap-4 scale-in card-hover" style="transition-delay: 0.3s;">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">Un appel de 15 minutes</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">15 minutes pour parcourir vos résultats, répondre à vos questions et définir la suite.</p>
              </div>
            </div>
          </div>
          <div class="text-center mt-10 md:mt-12 fade-up">
            <a href="#audit" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark">
              Demander mon diagnostic gratuit
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ TÉMOIGNAGE ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Résultat client">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
          L'impact concret pour un hôtel
        </h2>
        <div class="max-w-3xl mx-auto">
          <div class="border border-warmgray bg-cream p-8 md:p-12 scale-in card-hover" style="transition-delay: 0.1s;">
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-4 mb-8">
              <p class="text-base font-sans font-medium text-charcoal">Isabelle R.</p>
              <span class="hidden sm:block text-warmgray/60" aria-hidden="true">·</span>
              <p class="text-base font-sans font-normal text-stone">Hôtel boutique, Paris 6e</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mb-8">
              <div class="text-center md:text-left">
                <p class="text-sm font-sans font-medium text-stone/70 tracking-[0.1em] uppercase mb-3">Avant</p>
                <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-charcoal">8<span class="text-lg text-stone/60">/100</span></p>
                <p class="mt-2 text-sm font-sans font-normal leading-relaxed text-stone">score de visibilité IA</p>
              </div>
              <div class="text-center md:text-left">
                <p class="text-sm font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-3">Après 10 semaines</p>
                <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta">79<span class="text-lg text-stone/60">/100</span></p>
                <p class="mt-2 text-sm font-sans font-normal leading-relaxed text-stone">score de visibilité IA</p>
              </div>
              <div class="text-center md:text-left">
                <p class="text-sm font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-3">Résultat</p>
                <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta">+22%</p>
                <p class="mt-2 text-sm font-sans font-normal leading-relaxed text-stone">taux d'occupation</p>
              </div>
            </div>
            <div class="w-full h-px bg-warmgray/30 mb-8" aria-hidden="true"></div>
            <p class="text-lg md:text-xl font-sans font-normal leading-relaxed text-stone italic">
              «&nbsp;Depuis deux mois, des clients internationaux nous disent qu'ils nous ont trouvés grâce à ChatGPT. Des réservations directes, sans passer par Booking. On ne pensait pas que c'était possible pour un hôtel de notre taille.&nbsp;»
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ STATS / PROBLÈME ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Le problème">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
          Ce qui a changé pour les hôteliers
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-12 md:mb-16">
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0s;">
            <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4" data-count-to="40" data-suffix="%">40%</p>
            <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-4">des voyageurs utilisent l'IA pour planifier leur séjour</p>
            <p class="text-sm font-sans font-medium text-stone/70">Statista, 2025</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0.1s;">
            <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4" data-count-to="83" data-suffix="%">83%</p>
            <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-4">des hôtels sont invisibles sur ChatGPT</p>
            <p class="text-sm font-sans font-medium text-stone/70">Local Falcon, 2026</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0.2s;">
            <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4">3 à 5</p>
            <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-4">résultats : c'est tout ce que l'IA montre quand un voyageur cherche un hôtel</p>
          </div>
        </div>
        <p class="max-w-[65ch] mx-auto text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone blur-in">
          Booking.com perd le premier contact. Aujourd'hui, les voyageurs demandent d'abord à ChatGPT «&nbsp;hôtel romantique à Paris&nbsp;» avant d'aller réserver. On fait en sorte que ce soit le vôtre que l'IA recommande.
        </p>
      </div>
    </section>

    <!-- ═══════════════════ PROBLÈMES SPÉCIFIQUES HÔTELS ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Problèmes spécifiques aux hôtels">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
          Les problèmes que vous&nbsp;connaissez
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 max-w-4xl mx-auto">
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0s;">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Booking prend sa commission. L'IA pourrait vous apporter des réservations directes.</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">Quand ChatGPT recommande votre hôtel, le voyageur va directement sur votre site pour réserver. Pas de commission, pas d'intermédiaire.</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0.1s;">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Les voyageurs préparent avant de réserver</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">Ils demandent à l'IA des conseils de quartier, des recommandations d'hôtels. On fait en sorte que votre hôtel apparaisse dès cette étape de recherche.</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0.2s;">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Les avis internationaux comptent plus que jamais</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">L'IA lit les avis dans toutes les langues. Des avis peu nombreux ou incohérents signifient aucune recommandation.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ SOLUTION ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Ce que nous faisons">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Ce que nous faisons pour votre hôtel
        </h2>
        <p class="text-center max-w-[55ch] mx-auto text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-16 fade-up">
          On amène plus de voyageurs dans votre hôtel, via l'IA et Google.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-4xl mx-auto">
          <div class="border border-warmgray p-8 md:p-10 bg-cream slide-in-left card-hover">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-4">Visibilité IA</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-4 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Apparaître quand un voyageur demande «&nbsp;hôtel à Paris&nbsp;» à ChatGPT, Claude, Gemini ou Perplexity
              </li>
              <li class="flex items-start gap-4 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Être référencé sur les plateformes de voyage et annuaires qui comptent pour l'IA
              </li>
              <li class="flex items-start gap-4 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Gérer vos avis internationaux pour renforcer votre e-réputation
              </li>
            </ul>
          </div>
          <div class="border border-warmgray p-8 md:p-10 bg-cream slide-in-right card-hover">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-4">Visibilité Google</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-4 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Remonter dans les résultats Google Maps de votre ville et de votre quartier
              </li>
              <li class="flex items-start gap-4 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Optimiser votre fiche Google Business Profile pour les voyageurs
              </li>
              <li class="flex items-start gap-4 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Développer votre présence sur les requêtes locales qui comptent
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ COMMENT ÇA MARCHE ═══════════════════ -->
    <section id="comment-ca-marche" class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Comment ça marche">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
          Comment ça marche
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10 mb-12 md:mb-16">
          <div class="relative scale-in card-hover" style="transition-delay: 0s;">
            <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">01</p>
            <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Diagnostic gratuit</h3>
            <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">Nous testons votre hôtel sur ChatGPT, Claude, Google Maps et les assistants IA. Vous recevez votre score de visibilité sur 100.</p>
            <div class="hidden md:flex absolute top-12 -right-5 md:-right-6 items-center text-warmgray/50" aria-hidden="true">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <div class="relative scale-in card-hover" style="transition-delay: 0.15s;">
            <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">02</p>
            <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">On en parle ensemble</h3>
            <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">Un rapport avec les actions prioritaires pour votre hôtel. Classées par impact sur vos réservations, sans jargon technique.</p>
            <div class="hidden md:flex absolute top-12 -right-5 md:-right-6 items-center text-warmgray/50" aria-hidden="true">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <div class="scale-in card-hover" style="transition-delay: 0.3s;">
            <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">03</p>
            <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Vos voyageurs vous trouvent</h3>
            <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">Nous mettons en place les optimisations. Les voyageurs vous trouvent sur ChatGPT et réservent en direct.</p>
          </div>
        </div>
        <div class="text-center fade-up">
          <a href="#audit" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark" onclick="plausible('CTA Click', {props: {location: 'hotels-how-it-works'}})">
            Demander mon diagnostic gratuit →
          </a>
        </div>
        <p class="text-center text-sm font-sans font-medium text-stone mt-6 blur-in">
          Un seul hôtel par quartier et par gamme, pour vous garantir l'exclusivité.
        </p>
      </div>
    </section>

    <!-- ═══════════════════ FAQ ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Questions fréquentes">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
            Questions fréquentes
          </h2>
          <div class="space-y-0 fade-up">
            <details class="group border-b border-warmgray/30" open>
              <summary class="flex items-center justify-between gap-4 py-5 md:py-6 cursor-pointer list-none font-sans font-medium text-base md:text-lg text-charcoal transition-all duration-200 hover:text-terracotta hover:pl-2 [&::-webkit-details-marker]:hidden">
                <span>Ça remplace Booking.com ?</span>
