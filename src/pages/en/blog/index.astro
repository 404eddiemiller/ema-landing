---
// Blog index page (English) — Lists all English blog articles sorted by date
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft && post.data.lang === 'en')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group posts by category
const categories = [...new Set(posts.map((post) => post.data.category))];
---
<Layout
  title="Blog — Eddie Miller Agency"
  description="Articles and guides to help your business be found by your future customers, on Google and AI."
  canonicalUrl="https://eddiemiller.agency/en/blog"
  ogTitle="Blog — Eddie Miller Agency"
  ogDescription="Articles and guides to help your business be found online, on Google and AI."
>
  <Header />

  <main id="main-content" class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">

      <!-- Page header -->
      <div class="mb-12 md:mb-16 max-w-[720px]">
        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight mb-4">
          Blog
        </h1>
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed">
          Practical guides to help your business be found by your future customers.
        </p>
      </div>

      <!-- Category filters -->
      <div class="flex flex-wrap gap-2 mb-10 md:mb-12" id="category-filters">
        <button
          class="category-btn active px-4 py-2 text-sm font-sans font-medium tracking-wide uppercase border transition-colors duration-200 border-terracotta text-terracotta bg-terracotta/5"
          data-category="all"
        >
          All
        </button>
        {categories.map((cat) => (
          <button
            class="category-btn px-4 py-2 text-sm font-sans font-medium tracking-wide uppercase border border-warmgray text-stone transition-colors duration-200 hover:border-terracotta hover:text-terracotta"
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Articles list -->
      <div class="grid gap-0">
        {posts.map((post, index) => {
          const formattedDate = post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });

          return (
            <article class:list={['group fade-in', index === 0 ? 'border-t border-warmgray/30' : '', 'border-b border-warmgray/30']} data-category={post.data.category}>
              <a href={`/en/blog/${post.data.slug}`} class="block py-8 md:py-10 transition-colors duration-200 hover:bg-sand/50">
                <div class="flex flex-col md:flex-row md:items-start md:gap-8">

                  <!-- Meta column -->
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-sans text-stone mb-3 md:mb-0 md:w-48 md:shrink-0 md:pt-1">
                    <time datetime={post.data.date.toISOString().split('T')[0]}>{formattedDate}</time>
                    <span class="text-warmgray md:hidden" aria-hidden="true">&middot;</span>
                    <span class="md:hidden">{post.data.reading_time}</span>
                  </div>

                  <!-- Content column -->
                  <div class="flex-1 flex gap-6">
                    <div class="flex-1">
                      <span class="inline-block text-xs font-sans font-medium text-terracotta uppercase tracking-wider mb-2">
                        {post.data.category}
                      </span>
                      <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug group-hover:text-terracotta transition-colors duration-200">
                        {post.data.title}
                      </h2>
                      <p class="mt-2 text-sm md:text-base font-sans text-stone leading-relaxed line-clamp-2">
                        {post.data.meta_description}
                      </p>
                      <span class="hidden md:inline-block mt-3 text-sm font-sans text-stone">
                        {post.data.reading_time} read
                      </span>
                    </div>
                    {post.data.image && (
                      <div class="hidden md:block shrink-0 self-center">
                        <img
                          src={post.data.image}
                          alt={post.data.imageAlt || post.data.title}
                          width="200"
                          height="105"
                          loading="lazy"
                          decoding="async"
                          class="w-[200px] h-[105px] object-cover"
                        />
                      </div>
                    )}
                  </div>

                </div>
              </a>
            </article>
          );
        })}
      </div>

      <!-- CTA at bottom -->
      <div class="mt-14 md:mt-20 py-10 md:py-12 px-6 md:px-10 bg-sand border border-warmgray/30 text-center">
        <p class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-3">
          Is your business visible on AI?
        </p>
        <p class="font-sans text-stone text-base leading-relaxed mb-6 max-w-lg mx-auto">
          Free diagnostic within 24h: we check if your future customers can find you online, and give you your top 3 priority actions.
        </p>
        <a
          href="/#audit"
          class="inline-block px-6 py-3 font-sans font-medium text-[0.9375rem] text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
        >
          Request my free diagnostic &rarr;
        </a>
        <a
          href="/formules"
          class="inline-block px-6 py-3 font-sans font-medium text-[0.9375rem] text-charcoal border border-warmgray tracking-wider uppercase transition-colors duration-300 hover:border-terracotta hover:text-terracotta"
        >
          See our pricing
        </a>
      </div>

    </div>
  </main>

  <Footer />

  <script>
    const buttons = document.querySelectorAll('.category-btn');
    const articles = document.querySelectorAll('article[data-category]');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');

        // Update active state
        buttons.forEach(b => {
          b.classList.remove('active', 'border-terracotta', 'text-terracotta', 'bg-terracotta/5');
          b.classList.add('border-warmgray', 'text-stone');
        });
        btn.classList.add('active', 'border-terracotta', 'text-terracotta');
        btn.classList.remove('border-warmgray', 'text-stone');

        // Filter articles
        articles.forEach(article => {
          if (category === 'all' || article.getAttribute('data-category') === category) {
            article.style.display = '';
          } else {
            article.style.display = 'none';
          }
        });
      });
    });
  </script>
</Layout>
