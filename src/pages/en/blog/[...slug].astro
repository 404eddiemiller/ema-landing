---
// Blog article page (English) — Dynamic route for individual English blog posts
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getDisplayDate } from '../../../utils/blog-dates';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(p => p.data.lang === 'en');
  const sorted = [...posts].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return sorted.map((post, i) => ({
    params: { slug: post.data.slug },
    props: { post, displayDate: getDisplayDate(i, sorted.length) },
  }));
}

const { post, displayDate } = Astro.props;
const { Content } = await render(post);
const canonicalUrl = `https://eddiemiller.agency/en/blog/${post.data.slug}`;
const articleImage = post.data.image
  ? `https://eddiemiller.agency${post.data.image}`
  : 'https://eddiemiller.agency/og-image.png';

// Format date in English
const formattedDate = displayDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Get related articles (3 most recent in same locale, excluding current)
const relatedPosts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'en' && !p.data.draft && p.data.slug !== post.data.slug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<Layout
  title={post.data.meta_title}
  description={post.data.meta_description}
  canonicalUrl={canonicalUrl}
  ogTitle={post.data.meta_title}
  ogDescription={post.data.meta_description}
  ogType="article"
  ogImage={articleImage}
>
  <Header />

  <!-- BlogPosting JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.meta_description,
    "datePublished": displayDate.toISOString().split('T')[0],
    "dateModified": displayDate.toISOString().split('T')[0],
    "author": {
      "@type": "Organization",
      "name": "Eddie Miller Agency",
      "url": "https://eddiemiller.agency"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Eddie Miller Agency",
      "url": "https://eddiemiller.agency",
      "logo": {
        "@type": "ImageObject",
        "url": "https://eddiemiller.agency/favicon.svg"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalUrl
    },
    "image": articleImage,
    "inLanguage": "en",
    "keywords": post.data.tags.join(", "),
    "articleSection": post.data.category
  })} />

  <!-- BreadcrumbList JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://eddiemiller.agency/en" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://eddiemiller.agency/en/blog" },
      { "@type": "ListItem", "position": 3, "name": post.data.title, "item": canonicalUrl }
    ]
  })} />

  <article class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-[720px] mx-auto px-6 md:px-8">

      <!-- Article header -->
      <div class="mb-10 md:mb-14">
        <nav aria-label="Breadcrumb" class="mb-8 md:mb-10">
          <ol class="flex items-center gap-2 text-sm font-sans text-stone">
            <li>
              <a href="/en" class="font-medium tracking-wide transition-colors duration-200 hover:text-terracotta">Home</a>
            </li>
            <li aria-hidden="true" class="text-warmgray">/</li>
            <li>
              <a href="/en/blog" class="font-medium tracking-wide transition-colors duration-200 hover:text-terracotta">Blog</a>
            </li>
            <li aria-hidden="true" class="text-warmgray">/</li>
            <li class="text-warmgray truncate max-w-[200px] md:max-w-none" aria-current="page">{post.data.title}</li>
          </ol>
        </nav>

        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-sans text-stone mb-4">
          <span class="font-medium text-terracotta uppercase tracking-wider text-xs">{post.data.category}</span>
          <span class="text-warmgray" aria-hidden="true">&middot;</span>
          <time datetime={displayDate.toISOString().split('T')[0]}>{formattedDate}</time>
          <span class="text-warmgray" aria-hidden="true">&middot;</span>
          <span>{post.data.reading_time} read</span>
        </div>

        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight">
          {post.data.title}
        </h1>
      </div>

      <!-- Hero image -->
      {post.data.image && (
        <div class="mb-10 md:mb-14 fade-in">
          <picture>
            <source srcset={post.data.image.replace('.webp', '.avif')} type="image/avif" />
            <source srcset={post.data.image} type="image/webp" />
            <img
              src={post.data.image}
              alt={post.data.imageAlt || post.data.title}
              width="1200"
              height="630"
              loading="eager"
              decoding="async"
              class="w-full h-auto"
              style="aspect-ratio: 1200/630; object-fit: cover;"
            />
          </picture>
        </div>
      )}

      <!-- Article content -->
      <div class="prose">
        <Content />
      </div>

      <!-- Inline CTA -->
      <div class="my-10 md:my-14 py-6 border-t border-b border-warmgray/30">
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed mb-4">
          Want to know if your business is visible on AI?
        </p>
        <a
          href="/#diagnostic"
          class="inline-block px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          onclick="plausible('CTA Click', {props: {location: 'blog-inline'}})"
        >
          Request my free diagnostic &rarr;
        </a>
      </div>

      <!-- CTA Section -->
      <aside class="mt-14 md:mt-20 py-10 md:py-12 px-6 md:px-10 bg-sand border border-warmgray/30" role="complementary">
        <p class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-3">
          Can your future customers find you online?
        </p>
        <p class="font-sans text-stone text-base leading-relaxed mb-6">
          Free diagnostic within 24h: we check if your future customers can find you on Google and AI, and give you your priority actions.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/#diagnostic"
            class="inline-block px-6 py-3 font-sans font-medium text-[0.9375rem] text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Request my free diagnostic &rarr;
          </a>
          <a
            href="/formules"
            class="inline-block px-6 py-3 font-sans font-medium text-[0.9375rem] text-charcoal border border-warmgray tracking-wider uppercase transition-colors duration-300 hover:border-terracotta hover:text-terracotta"
          >
            See our pricing
          </a>
        </div>
      </aside>

      <!-- Tags -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-10 pt-8 border-t border-warmgray/30">
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="inline-block px-3 py-1 text-xs font-sans font-medium text-stone bg-sand tracking-wide uppercase">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      {relatedPosts.length > 0 && (
        <div class="mt-10 pt-8 border-t border-warmgray/30">
          <h2 class="font-serif text-xl md:text-2xl text-charcoal mb-6">Related articles</h2>
          <div class="space-y-4">
            {relatedPosts.map((related) => (
              <a href={`/en/blog/${related.data.slug}`} class="block group py-3 transition-colors duration-200">
                <span class="inline-block text-xs font-sans font-medium text-terracotta uppercase tracking-wider mb-1">
                  {related.data.category}
                </span>
                <p class="font-serif text-lg text-charcoal group-hover:text-terracotta transition-colors duration-200 leading-snug">
                  {related.data.title}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </article>

  <Footer />
</Layout>
