---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AuditForm from '../../components/AuditForm.astro';

const formules = [
  {
    name: 'Diagnostic',
    tagline: 'Know where you stand',
    price: 'Free',
    priceDetail: '',
    description: "We test your business on Google and AI. You receive a clear report with your score and priority actions.",
    includes: [
      'Visibility score out of 100',
      'Clear report with full diagnostic',
      '15-minute call to discuss results',
    ],
    ideal: "To find out if you have a visibility problem and what it is.",
    cta: 'Request my free diagnostic',
    ctaHref: '#diagnostic',
    highlight: false,
    free: true,
  },
  {
    name: 'Essential',
    tagline: 'Build the foundation',
    price: 'From €490',
    priceDetail: 'one-time service',
    description: "We set up the foundations so Google and AI start recommending you.",
    includes: [
      'Full diagnostic included',
      'Google profile optimized and complete',
      'Presence on sources consulted by AI',
      'Detailed debrief call',
    ],
    ideal: "For businesses starting from scratch or with a neglected online presence.",
    cta: 'Request a quote',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
  {
    name: 'Complete',
    tagline: 'Go further',
    price: 'Custom quote',
    priceDetail: 'tailored to your situation',
    description: "We optimize your entire online presence to maximize your chances of being found and recommended.",
    includes: [
      'Everything in Essential included',
      'Full optimization across 15 points',
      'Registration on key directories in your industry',
      'Online review strategy',
      'In-depth 45-minute call',
    ],
    ideal: "For businesses that want to go further and dominate their area.",
    cta: 'Request a quote',
    ctaHref: '#diagnostic',
    highlight: true,
    free: false,
  },
  {
    name: 'Premium',
    tagline: 'Lasting results',
    price: 'Custom quote',
    priceDetail: '3-month engagement',
    description: "We take charge of your visibility over 3 months with monthly monitoring and continuous adjustments.",
    includes: [
      'Everything in Complete included',
      '3-month engagement',
      '3 monthly progress reports',
      'Continuous adjustments',
      'Dedicated point of contact',
    ],
    ideal: "For businesses that want measurable results and long-term support.",
    cta: 'Request a quote',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
];
---
<Layout
  title="Pricing — Eddie Miller Agency"
  description="Free diagnostic, tailored support. Discover our plans to be found by your future customers on Google and ChatGPT."
  canonicalUrl="https://eddiemiller.agency/en/pricing"
  ogTitle="Pricing — Eddie Miller Agency"
  ogDescription="Free diagnostic, tailored support to be found by your future customers."
>
  <Header />

  <main id="main-content" class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">

      <!-- Page header -->
      <div class="text-center mb-12 md:mb-16 max-w-2xl mx-auto">
        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight mb-4 fade-up-slow">
          Clear plans, concrete results
        </h1>
        <div class="mx-auto mb-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed blur-in" style="transition-delay: 0.3s;">
          Everything starts with a free diagnostic. Then, we recommend the plan that fits your situation. No unnecessary packages, no surprises.
        </p>
      </div>

      <!-- Formule cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {formules.map((f) => (
          <div class:list={[
            'flex flex-col border p-6 md:p-8 bg-cream card-hover scale-in',
            f.highlight ? 'border-terracotta' : 'border-warmgray',
          ]}>
            <!-- Badge zone — fixed height so titles align -->
            <div class="lg:min-h-[1.5rem] mb-2">
              {f.highlight && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Most popular
                </p>
              )}
              {f.free && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Free
                </p>
              )}
            </div>
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-1">
              {f.name}
            </h2>
            <p class="text-sm font-sans font-medium text-terracotta mb-4">
              {f.tagline}
            </p>
            <div class="mb-5">
              <p class="text-2xl font-serif font-normal text-charcoal leading-tight">
                {f.price}
              </p>
              {f.priceDetail && (
                <p class="text-xs font-sans text-stone mt-1">{f.priceDetail}</p>
              )}
            </div>
            <p class="text-sm font-sans font-normal leading-relaxed text-stone mb-6 lg:min-h-[6rem]">
              {f.description}
            </p>
            <ul class="space-y-3 mb-6 flex-1">
              {f.includes.map((item) => (
                <li class="flex items-start gap-2 text-sm font-sans text-stone">
                  <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
            <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic mb-6">
              {f.ideal}
            </p>
            <a
              href={f.ctaHref}
              class:list={[
                'block text-center px-6 py-3 font-sans font-medium text-sm tracking-wider uppercase transition-colors duration-300 mt-auto',
                f.highlight
                  ? 'text-cream bg-terracotta hover:bg-terracotta-dark'
                  : 'text-charcoal border border-warmgray hover:border-terracotta hover:text-terracotta',
              ]}
            >
              {f.cta} →
            </a>
          </div>
        ))}
      </div>

      <!-- Monthly monitoring -->
      <div class="mt-10 md:mt-14 border border-warmgray p-8 md:p-10 bg-sand card-hover fade-up">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div class="flex-1">
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-2">
              Monthly monitoring
            </h2>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Offered after every engagement. We monitor your visibility each month, adjust what needs to be adjusted, and you receive a progress report. No commitment, cancel anytime.
            </p>
          </div>
          <a
            href="#diagnostic"
            class="inline-block shrink-0 text-center px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Learn more
          </a>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="mt-14 md:mt-20 text-center max-w-2xl mx-auto">
        <h2 class="text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Not sure which plan is right for you?
        </h2>
        <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-8 fade-up">
          Start with the free diagnostic. We will tell you exactly where you stand and what will have the most impact for your situation. You decide from there.
        </p>
        <a
          href="#diagnostic"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark fade-up"
        >
          Request my free diagnostic
        </a>
      </div>

    </div>
  </main>

  <AuditForm />
  <Footer />
</Layout>
