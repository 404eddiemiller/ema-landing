---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AuditForm from '../../components/AuditForm.astro';

const formules = [
  {
    name: 'Diagnostic',
    tagline: 'Know where you stand',
    price: 'Free',
    priceDetail: '',
    description: "We test your business on Google and AI. You receive a clear report with your score and priority actions.",
    includes: [
      'Visibility score out of 100',
      'Clear report with full diagnostic',
      '15-minute call to discuss results',
    ],
    ideal: "To find out if you have a visibility problem and what it is.",
    cta: 'Request my free diagnostic',
    ctaHref: '#diagnostic',
    highlight: false,
    free: true,
  },
  {
    name: 'Essential',
    tagline: 'Build the foundation',
    price: '€399',
    priceDetail: 'excl. VAT · one-time service',
    description: "We set up the foundations so Google and AI start recommending you.",
    includes: [
      'Full diagnostic included',
      'Google profile optimized and complete',
      'Registration on 5 key directories in your industry',
      '2 Google Business Profile posts written and published',
      'Presence on sources consulted by AI',
      'Schema.org / structured data (if website exists)',
      'Personalized roadmap with before/after screenshots',
      '30-minute debrief call',
    ],
    ideal: "For businesses starting from scratch or with a neglected online presence.",
    cta: 'Request my free diagnostic',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
  {
    name: 'Complete',
    tagline: 'Go further',
    price: '€699',
    priceDetail: 'excl. VAT · one-time service',
    description: "We optimize your entire online presence to maximize your chances of being found and recommended.",
    includes: [
      'Everything in Essential included',
      'Full optimization across 15 points',
      'Registration on 10+ directories in your industry',
      'Online review strategy (templates + guide + QR code)',
      '4 Google Business Profile posts written and published',
      'Complete Schema.org (business + FAQ + practitioners)',
      'Competitive report (3 competitors analyzed)',
      'Basic website optimization (if applicable)',
      'In-depth 45-minute call',
    ],
    ideal: "For businesses that want to go further and dominate their area.",
    cta: 'Request my free diagnostic',
    ctaHref: '#diagnostic',
    highlight: true,
    free: false,
  },
  {
    name: 'Premium',
    tagline: 'Lasting results',
    price: '€1,199',
    priceDetail: 'excl. VAT · one-time service',
    description: "We handle your entire online visibility with a comprehensive, tailored service.",
    includes: [
      'Everything in Complete included',
      'Registration on 20+ directories',
      '8 Google Business Profile posts written and published',
      'Full keyword research for your industry',
      '5 competitor analysis',
      'Complete website optimization',
      'Advanced Schema.org (all relevant types)',
      'Personalized 6-month strategic guide',
    ],
    ideal: "For businesses that want the maximum in a single service.",
    cta: 'Request my free diagnostic',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
];
---
<Layout
  title="Pricing — Eddie Miller Agency"
  description="Free diagnostic, tailored support. Discover our plans to be found by your future customers on Google and ChatGPT."
  canonicalUrl="https://eddiemiller.agency/en/pricing"
  ogTitle="Pricing — Eddie Miller Agency"
  ogDescription="Free diagnostic, tailored support to be found by your future customers."
>
  <Header />

  <main id="main-content" class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">

      <!-- Page header -->
      <div class="text-center mb-12 md:mb-16 max-w-2xl mx-auto">
        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight mb-4 fade-up-slow">
          Clear plans, concrete results
        </h1>
        <div class="mx-auto mb-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed blur-in" style="transition-delay: 0.3s;">
          Everything starts with a free diagnostic. Then, we recommend the plan that fits your situation. No unnecessary packages, no surprises.
        </p>
      </div>

      <!-- Formule cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {formules.map((f) => (
          <div class:list={[
            'flex flex-col border p-6 md:p-8 bg-cream card-hover scale-in',
            f.highlight ? 'border-terracotta' : 'border-warmgray',
          ]}>
            <!-- Badge zone — fixed height so titles align -->
            <div class="lg:min-h-[1.5rem] mb-2">
              {f.highlight && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Most popular
                </p>
              )}
              {f.free && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Free
                </p>
              )}
            </div>
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-1">
              {f.name}
            </h2>
            <p class="text-sm font-sans font-medium text-terracotta mb-4">
              {f.tagline}
            </p>
            <div class="mb-5">
              <p class="text-3xl md:text-4xl font-serif font-normal text-charcoal leading-tight">
                {f.price}
              </p>
              {f.priceDetail && (
                <p class="text-sm font-sans text-stone mt-1">{f.priceDetail}</p>
              )}
            </div>
            <p class="text-sm font-sans font-normal leading-relaxed text-stone mb-6 lg:min-h-[6rem]">
              {f.description}
            </p>
            <ul class="space-y-3 mb-6 flex-1">
              {f.includes.map((item) => (
                <li class="flex items-start gap-2 text-sm font-sans text-stone">
                  <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
            <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic mb-6">
              {f.ideal}
            </p>
            <a
              href={f.ctaHref}
              class:list={[
                'block text-center px-6 py-3 font-sans font-medium text-sm tracking-wider uppercase transition-colors duration-300 mt-auto',
                f.highlight
                  ? 'text-cream bg-terracotta hover:bg-terracotta-dark'
                  : 'text-charcoal border border-warmgray hover:border-terracotta hover:text-terracotta',
              ]}
            >
              {f.cta} →
            </a>
          </div>
        ))}
      </div>

      <!-- Monthly monitoring -->
      <div class="mt-10 md:mt-14 border border-warmgray p-8 md:p-10 bg-sand card-hover fade-up">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
          <div class="flex-1">
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-2">
              Monthly monitoring
            </h2>
            <div class="mb-4">
              <p class="text-3xl md:text-4xl font-serif font-normal text-charcoal leading-tight">
                €99
              </p>
              <p class="text-sm font-sans text-stone mt-1">excl. VAT/month</p>
              <p class="text-sm font-sans font-medium text-terracotta mt-1">No commitment · cancel anytime</p>
            </div>
            <p class="text-base font-sans font-normal leading-relaxed text-stone mb-5">
              We monitor your visibility each month, adjust what needs to be adjusted, and you receive a progress report.
            </p>
            <ul class="space-y-3 mb-5">
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Monthly AI visibility score re-test
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                2 to 4 Google Business Profile posts per month
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Google reviews monitoring + suggested responses
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Monthly progress report
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Geographic exclusivity: one client per area and specialty
              </li>
            </ul>
            <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic">
              Offered after every engagement.
            </p>
          </div>
          <a
            href="#diagnostic"
            class="inline-block shrink-0 text-center px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Learn more
          </a>
        </div>
      </div>

      <!-- ROI by sector -->
      <div class="mt-14 md:mt-20 max-w-4xl mx-auto">
        <h2 class="text-center text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          What it actually brings in
        </h2>
        <p class="text-center text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-10 md:mb-12 fade-up">
          An investment that pays for itself quickly, whatever your industry.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          <div class="border border-warmgray p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Restaurant · Essential (€399)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              One extra cover per evening at €35 = +€1,050/month. The "Essential" plan pays for itself in 12 days. After that, the returns keep growing.
            </p>
          </div>
          <div class="border border-terracotta p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Dentist · Complete (€699)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              With the "Complete" plan, just one new patient is enough to pay for it, and our results show an average of +12 new patients per month.
            </p>
          </div>
          <div class="border border-warmgray p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Hotel · Premium (€1,199)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Every direct booking saves you 15–22% in OTA commission. For a hotel at €160/night, that's €25–35 per night straight to you. The "Premium" plan pays for itself in one month, then you benefit directly from the investment.
            </p>
          </div>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="mt-14 md:mt-20 text-center max-w-2xl mx-auto">
        <h2 class="text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Not sure which plan is right for you?
        </h2>
        <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-8 fade-up">
          Start with the free diagnostic. We will tell you exactly where you stand and what will have the most impact for your situation. You decide from there.
        </p>
        <a
          href="#diagnostic"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark fade-up"
        >
          Request my free diagnostic
        </a>
      </div>

    </div>
  </main>

  <AuditForm />
  <Footer />
</Layout>
