---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Merci — Eddie Miller Agency"
  description="Votre demande d'audit gratuit a bien été envoyée. Nous vous répondons sous 24 heures."
>
  <Header />
  <main class="pt-32 pb-16 md:pt-40 md:pb-24 lg:pt-48 lg:pb-32 bg-cream">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
      <div class="max-w-2xl mx-auto text-center">
        <div class="mb-8">
          <svg class="w-16 h-16 mx-auto text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
        </div>
        <h1 class="text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-6">
          Merci, c'est envoyé&nbsp;!
        </h1>
        <p class="text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-4">
          Votre demande d'audit de visibilité IA a bien été reçue. Nous analysons votre établissement et vous répondons sous 24&nbsp;heures avec votre score et vos recommandations.
        </p>
        <p class="text-base font-sans font-normal leading-relaxed text-stone mb-10">
          Pensez à vérifier vos spams si vous ne recevez rien.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/"
            class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Retour à l'accueil
          </a>
          <a
            href="/blog"
            class="inline-block px-8 py-4 font-sans font-medium text-base text-charcoal border border-warmgray tracking-[0.02em] transition-colors duration-300 hover:border-charcoal"
          >
            Lire notre blog
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
