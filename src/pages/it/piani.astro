---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AuditForm from '../../components/AuditForm.astro';

const formule = [
  {
    name: 'Diagnosi',
    tagline: 'Sapere a che punto siete',
    price: 'Gratuito',
    priceDetail: '',
    description: "Testiamo la vostra attivita su Google e sulle IA. Riceverete un rapporto chiaro con il vostro punteggio e le azioni prioritarie.",
    includes: [
      'Punteggio di visibilita su 100',
      'Rapporto chiaro con diagnosi completa',
      'Chiamata di 15 min per parlarne',
    ],
    ideal: "Per sapere se avete un problema di visibilita e quale.",
    cta: 'Richiedere la diagnosi gratuita',
    ctaHref: '#diagnostic',
    highlight: false,
    free: true,
  },
  {
    name: 'Essenziale',
    tagline: 'Gettare le basi',
    price: '399 €',
    priceDetail: 'IVA esclusa · servizio una tantum',
    description: "Mettiamo in atto le fondamenta perche Google e le IA inizino a raccomandarvi.",
    includes: [
      'Tutta la diagnosi inclusa',
      'Scheda Google ottimizzata e completa',
      'Iscrizione su 5 elenchi chiave del vostro settore',
      '2 post Google Business Profile redatti e pubblicati',
      'Presenza sulle fonti consultate dalle IA',
      'Schema.org / dati strutturati (se sito web esistente)',
      'Tabella di marcia personalizzata con screenshot prima/dopo',
      'Chiamata di restituzione di 30 min',
    ],
    ideal: "Per le attivita che partono da zero o che hanno una presenza online trascurata.",
    cta: 'Richiedere la diagnosi gratuita',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
  {
    name: 'Completo',
    tagline: 'Andare oltre',
    price: '699 €',
    priceDetail: 'IVA esclusa · servizio una tantum',
    description: "Ottimizziamo l'intera presenza online per massimizzare le possibilita di essere trovati e raccomandati.",
    includes: [
      "Tutto l'Essenziale incluso",
      'Ottimizzazione completa su 15 punti',
      'Iscrizione su 10+ elenchi del vostro settore',
      'Strategia delle recensioni online (modelli + guida + codice QR)',
      '4 post Google Business Profile redatti e pubblicati',
      'Schema.org completo (azienda + FAQ + professionisti)',
      'Rapporto concorrenziale (3 concorrenti analizzati)',
      'Ottimizzazione di base del vostro sito web (se esistente)',
      'Chiamata approfondita di 45 min',
    ],
    ideal: "Per le attivita che vogliono andare oltre e dominare il proprio quartiere.",
    cta: 'Richiedere la diagnosi gratuita',
    ctaHref: '#diagnostic',
    highlight: true,
    free: false,
  },
  {
    name: 'Premium',
    tagline: 'Risultati duraturi',
    price: '1 199 €',
    priceDetail: 'IVA esclusa · servizio una tantum',
    description: "Ci occupiamo della vostra intera visibilita online con un servizio completo e su misura.",
    includes: [
      'Tutto il Completo incluso',
      'Iscrizione su 20+ elenchi',
      '8 post Google Business Profile redatti e pubblicati',
      'Ricerca di parole chiave completa per il vostro settore',
      'Analisi di 5 concorrenti',
      'Ottimizzazione completa del vostro sito web',
      'Schema.org avanzato (tutti i tipi rilevanti)',
      'Guida strategica personalizzata a 6 mesi',
    ],
    ideal: "Per le attivita che vogliono il massimo in un unico servizio.",
    cta: 'Richiedere la diagnosi gratuita',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
];
---
<Layout
  title="I nostri piani — Eddie Miller Agency"
  description="Diagnosi gratuita, accompagnamento su misura. Scoprite i nostri piani per farvi trovare dai vostri futuri clienti su Google e ChatGPT."
  canonicalUrl="https://eddiemiller.agency/it/piani"
  ogTitle="I nostri piani — Eddie Miller Agency"
  ogDescription="Diagnosi gratuita, accompagnamento su misura per farvi trovare dai vostri futuri clienti."
>
  <Header />

  <main id="main-content" class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">

      <!-- Page header -->
      <div class="text-center mb-12 md:mb-16 max-w-2xl mx-auto">
        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight mb-4 fade-up-slow">
          Piani chiari, risultati concreti
        </h1>
        <div class="mx-auto mb-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed blur-in" style="transition-delay: 0.3s;">
          Tutto inizia con una diagnosi gratuita. Poi vi proponiamo il piano adatto alla vostra situazione. Nessun pacchetto inutile, nessuna sorpresa.
        </p>
      </div>

      <!-- Formule cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {formule.map((f) => (
          <div class:list={[
            'flex flex-col border p-6 md:p-8 bg-cream card-hover scale-in',
            f.highlight ? 'border-terracotta' : 'border-warmgray',
          ]}>
            <!-- Badge zone — fixed height so titles align -->
            <div class="lg:min-h-[1.5rem] mb-2">
              {f.highlight && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Il piu richiesto
                </p>
              )}
              {f.free && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Gratuito
                </p>
              )}
            </div>
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-1">
              {f.name}
            </h2>
            <p class="text-sm font-sans font-medium text-terracotta mb-4">
              {f.tagline}
            </p>
            <div class="mb-5">
              <p class="text-3xl md:text-4xl font-serif font-normal text-charcoal leading-tight">
                {f.price}
              </p>
              {f.priceDetail && (
                <p class="text-sm font-sans text-stone mt-1">{f.priceDetail}</p>
              )}
            </div>
            <p class="text-sm font-sans font-normal leading-relaxed text-stone mb-6 lg:min-h-[6rem]">
              {f.description}
            </p>
            <ul class="space-y-3 mb-6 flex-1">
              {f.includes.map((item) => (
                <li class="flex items-start gap-2 text-sm font-sans text-stone">
                  <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
            <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic mb-6">
              {f.ideal}
            </p>
            <a
              href={f.ctaHref}
              class:list={[
                'block text-center px-6 py-3 font-sans font-medium text-sm tracking-wider uppercase transition-colors duration-300 mt-auto',
                f.highlight
                  ? 'text-cream bg-terracotta hover:bg-terracotta-dark'
                  : 'text-charcoal border border-warmgray hover:border-terracotta hover:text-terracotta',
              ]}
            >
              {f.cta} →
            </a>
          </div>
        ))}
      </div>

      <!-- Monitoraggio mensile -->
      <div class="mt-10 md:mt-14 border border-warmgray p-8 md:p-10 bg-sand card-hover fade-up">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
          <div class="flex-1">
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-2">
              Monitoraggio mensile
            </h2>
            <div class="mb-4">
              <p class="text-3xl md:text-4xl font-serif font-normal text-charcoal leading-tight">
                99 €
              </p>
              <p class="text-sm font-sans text-stone mt-1">IVA esclusa/mese</p>
              <p class="text-sm font-sans font-medium text-terracotta mt-1">Senza impegno · disdetta in qualsiasi momento</p>
            </div>
            <p class="text-base font-sans font-normal leading-relaxed text-stone mb-5">
              Monitoriamo la vostra visibilita ogni mese, adattiamo cio che serve, e riceverete un rapporto di progressione.
            </p>
            <ul class="space-y-3 mb-5">
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Re-test mensile del punteggio di visibilita IA
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                2 a 4 post Google Business Profile al mese
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Monitoraggio recensioni Google + risposte suggerite
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Rapporto mensile di progressione
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Esclusivita geografica: un solo cliente per quartiere e specialita
              </li>
            </ul>
            <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic">
              Proposto dopo ogni prestazione.
            </p>
          </div>
          <a
            href="#diagnostic"
            class="inline-block shrink-0 text-center px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Scopri di piu
          </a>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="mt-14 md:mt-20 text-center max-w-2xl mx-auto">
        <h2 class="text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Non siete sicuri del piano giusto per voi?
        </h2>
        <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-8 fade-up">
          Iniziate con la diagnosi gratuita. Vi diremo esattamente a che punto siete e cosa ha il maggior impatto per la vostra situazione. Poi decidete voi.
        </p>
        <a
          href="#diagnostic"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark fade-up"
        >
          Richiedere la diagnosi gratuita
        </a>
      </div>

    </div>
  </main>

  <AuditForm />
  <Footer />
</Layout>
