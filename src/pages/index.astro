---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import Problem from '../components/Problem.astro';
import Solution from '../components/Solution.astro';
import WhyUs from '../components/WhyUs.astro';
import Verticals from '../components/Verticals.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhatYouGet from '../components/WhatYouGet.astro';
import Testimonial from '../components/Testimonial.astro';
import Quote from '../components/Quote.astro';
import FAQ from '../components/FAQ.astro';
import AuditForm from '../components/AuditForm.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Plus de clients pour votre commerce | Eddie Miller Agency"
  description="On aide les commerces parisiens à être trouvés par leurs futurs clients — sur Google et sur ChatGPT. Test de visibilité gratuit en 24h."
>
  <Header />
  <main id="main-content">
    <Hero />
    <SocialProof />
    <WhatYouGet />
    <Testimonial />
    <Problem />
    <Quote />
    <Solution />
    <WhyUs />
    <Verticals />
    <HowItWorks />
    <FAQ />
    <AuditForm />
  </main>
  <Footer />
</Layout>
