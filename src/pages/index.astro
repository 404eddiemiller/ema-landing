---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import Problem from '../components/Problem.astro';
import Solution from '../components/Solution.astro';
import Verticals from '../components/Verticals.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Quote from '../components/Quote.astro';
import Testimonial from '../components/Testimonial.astro';
import FAQ from '../components/FAQ.astro';
import AuditForm from '../components/AuditForm.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Eddie Miller Agency — Visibilité IA & SEO Local à Paris"
  description="Votre commerce est-il recommandé par ChatGPT ? Audit gratuit de visibilité IA en 30 minutes. Spécialiste GEO et SEO local pour restaurants, hôtels et cabinets à Paris."
>
  <Header />
  <main id="main-content">
    <Hero />
    <SocialProof />
    <Problem />
    <Solution />
    <Verticals />
    <HowItWorks />
    <Quote />
    <Testimonial />
    <FAQ />
    <AuditForm />
  </main>
  <Footer />
</Layout>
