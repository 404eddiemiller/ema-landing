---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Plus de clients pour votre cabinet d'avocats | Eddie Miller Agency"
  description="Vos futurs clients demandent à ChatGPT quel avocat choisir. Êtes-vous dans la liste ? Diagnostic gratuit de votre visibilité IA en 24h : score sur 100, diagnostic clair, actions prioritaires."
  canonicalUrl="https://eddiemiller.agency/avocats"
  ogTitle="Plus de clients pour votre cabinet d'avocats | Eddie Miller Agency"
  ogDescription="Vos futurs clients demandent à ChatGPT quel avocat choisir. Diagnostic gratuit de votre visibilité en 24h."
>
  <Header />
  <main id="main-content">

    <!-- ═══════════════════ HERO ═══════════════════ -->
    <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 lg:pt-48 lg:pb-32 bg-cream overflow-hidden" aria-label="Accroche principale">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl">
          <p class="inline-block px-3 py-1 mb-6 text-sm font-sans font-medium text-terracotta border border-terracotta/40 tracking-wide">
            Spécialiste cabinets d'avocats
          </p>
          <h1 class="text-[2.5rem] md:text-[3.25rem] lg:text-[4rem] font-serif font-normal leading-[1.1] tracking-[-0.02em] text-charcoal">
            Vos futurs clients demandent à ChatGPT quel avocat choisir. Êtes-vous dans la&nbsp;liste&nbsp;?
          </h1>
          <div class="mt-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>
          <p class="mt-6 md:mt-8 max-w-[65ch] text-lg md:text-xl font-sans font-normal leading-relaxed text-stone blur-in" style="transition-delay: 0.4s;">
            Un particulier en procédure de divorce, un dirigeant qui cherche un avocat en droit des affaires. De plus en plus posent la question à l'IA avant de décrocher leur téléphone. Nous vérifions si votre cabinet apparaît dans ces&nbsp;recommandations.
          </p>
          <div class="flex flex-col sm:flex-row items-start gap-4 mt-8 md:mt-10 fade-up" style="transition-delay: 0.6s;">
            <a
              href="#audit"
              class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark"
              onclick="plausible('CTA Click', {props: {location: 'avocats-hero'}})"
            >
              Demander mon diagnostic gratuit
            </a>
            <a
              href="#comment-ca-marche"
              class="inline-flex items-center gap-1 px-2 py-4 font-sans font-medium text-base text-stone transition-all duration-200 hover:text-charcoal"
            >
              Voir comment ça marche ↓
            </a>
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-2 mt-6 md:mt-8 fade-up" style="transition-delay: 0.75s;">
            <span class="text-sm font-sans text-stone/80">✓ Diagnostic en 24h</span>
            <span class="text-sm font-sans text-stone/80">✓ 100 % gratuit</span>
            <span class="text-sm font-sans text-stone/80">✓ 1 seul cabinet par quartier et spécialité</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ SOCIAL PROOF ═══════════════════ -->
    <section class="py-12 md:py-16 bg-sand" aria-label="Plateformes optimisées">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <p class="text-center text-sm font-sans font-medium tracking-[0.1em] uppercase text-stone mb-8">
          Vos futurs clients cherchent un avocat ici
        </p>
        <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10 lg:gap-14">
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">ChatGPT</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Claude</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Google Maps</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Gemini</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Perplexity</span>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ CE QUE VOUS RECEVEZ ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Ce que vous recevez">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
            Ce que vous recevez en&nbsp;24h
          </h2>
          <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-14 fade-up">
            Un diagnostic complet de votre cabinet, pas un simple email.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
            <div class="flex gap-4 scale-in card-hover" style="transition-delay: 0s;">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">Votre score de visibilité sur 100</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">Votre note globale sur ChatGPT, Claude, Perplexity, Gemini et Google Maps pour vos spécialités juridiques.</p>
              </div>
            </div>
            <div class="flex gap-4 scale-in card-hover" style="transition-delay: 0.1s;">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">Ce qui bloque vos clients</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">Ce qui empêche ChatGPT de recommander votre cabinet quand un client cherche un avocat dans votre domaine.</p>
              </div>
            </div>
            <div class="flex gap-4 scale-in card-hover" style="transition-delay: 0.2s;">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">3 actions prioritaires</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">Les corrections classées par impact : ce qui fera bouger votre score le plus vite.</p>
              </div>
            </div>
            <div class="flex gap-4 scale-in card-hover" style="transition-delay: 0.3s;">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">Un appel de 15 minutes</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">15 minutes pour parcourir vos résultats, répondre à vos questions et définir la suite.</p>
              </div>
            </div>
          </div>
          <div class="text-center mt-10 md:mt-12 blur-in">
            <a href="#audit" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark">
              Demander mon diagnostic gratuit
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ TÉMOIGNAGE ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Résultat client">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
          Résultat pour un cabinet d'avocats
        </h2>
        <div class="max-w-3xl mx-auto">
          <div class="border border-warmgray bg-cream p-8 md:p-12 scale-in card-hover">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 mb-8">
              <div class="text-center md:text-left">
                <p class="text-sm font-sans font-medium text-stone/70 tracking-[0.1em] uppercase mb-3">Avant</p>
                <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray">5<span class="text-[1.5rem]">/100</span></p>
                <p class="mt-2 text-base font-sans font-normal leading-relaxed text-stone">Score de visibilité</p>
                <p class="text-sm font-sans text-stone/70 mt-1">Aucune mention sur ChatGPT pour ses spécialités</p>
              </div>
              <div class="text-center md:text-left">
                <p class="text-sm font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-3">Après 8 semaines</p>
                <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta">72<span class="text-[1.5rem]">/100</span></p>
                <p class="mt-2 text-base font-sans font-normal leading-relaxed text-stone">Score de visibilité</p>
                <p class="text-sm font-sans text-stone/70 mt-1">+8 nouveaux dossiers/mois</p>
              </div>
            </div>
            <div class="w-full h-px bg-warmgray/30 mb-8" aria-hidden="true"></div>
            <blockquote>
              <p class="text-lg md:text-xl font-sans font-normal leading-relaxed text-stone italic">
                «&nbsp;Plusieurs nouveaux clients nous ont dit qu'ils avaient trouvé notre cabinet en demandant à ChatGPT un avocat en droit du travail dans le 8e. Avant, ce type de demande passait uniquement par le bouche-à-oreille.&nbsp;»
              </p>
              <footer class="mt-4">
                <p class="font-sans font-medium text-base text-charcoal">Me Camille L.</p>
                <p class="font-sans text-sm text-stone">Cabinet d'avocats, Paris 8e</p>
              </footer>
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ STATS / PROBLÈME ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Le problème">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
          Ce qui a changé pour les avocats
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-12 md:mb-16">
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0s;">
            <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4" data-count-to="45" data-suffix="%">45%</p>
            <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-4">des particuliers utilisent l'IA pour trouver un avocat</p>
            <p class="text-sm font-sans font-medium text-stone/70">BrightLocal, 2026</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0.1s;">
            <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4" data-count-to="83" data-suffix="%">83%</p>
            <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-4">des cabinets d'avocats sont invisibles sur ChatGPT</p>
            <p class="text-sm font-sans font-medium text-stone/70">Local Falcon, 2026</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0.2s;">
            <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4">3 à 5</p>
            <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-4">résultats : c'est tout ce que ChatGPT montre quand on lui demande un avocat</p>
          </div>
        </div>
        <p class="max-w-[65ch] mx-auto text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone blur-in">
          Le bouche-à-oreille et les réseaux professionnels restent importants. Mais de plus en plus de clients, surtout ceux en urgence, passent d'abord par l'IA. On fait en sorte que ce soit votre cabinet qui apparaisse dans ces&nbsp;résultats.
        </p>
      </div>
    </section>

    <!-- ═══════════════════ PROBLÈMES SPÉCIFIQUES AVOCATS ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Les problèmes que vous connaissez">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
          Les problèmes que vous&nbsp;connaissez
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 max-w-4xl mx-auto">
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0s;">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Le réseau ne suffit plus</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">Historiquement, les clients venaient par recommandation. Mais un particulier en urgence (divorce, litige, mise en demeure) demande directement à l'IA. On fait en sorte que ce soit votre cabinet qui apparaisse dans ces recommandations.</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0.1s;">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Les annuaires d'avocats ont perdu du terrain</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">Les clients consultaient l'annuaire du Barreau. Aujourd'hui, ils demandent à ChatGPT «&nbsp;meilleur avocat droit du travail Paris&nbsp;». Les règles du jeu ont changé.</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream card-hover scale-in" style="transition-delay: 0.2s;">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Votre spécialité doit être visible</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">L'IA a besoin de comprendre ce que vous faites. Si votre présence en ligne ne mentionne pas clairement vos domaines de compétence, elle ne peut pas vous recommander.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ SOLUTION ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Ce que nous faisons">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Ce que nous faisons pour votre cabinet
        </h2>
        <p class="text-center max-w-[55ch] mx-auto text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-16 fade-up">
          On amène plus de clients dans votre cabinet. Sur ChatGPT, Google Maps et les assistants IA.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-4xl mx-auto">
          <div class="border border-warmgray p-8 md:p-10 bg-sand slide-in-left card-hover">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-5">Visibilité IA</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-4 text-base md:text-lg font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Apparaître quand un client demande «&nbsp;avocat divorce Paris&nbsp;» à ChatGPT, Claude, Gemini ou Perplexity
              </li>
              <li class="flex items-start gap-4 text-base md:text-lg font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Structurer votre présence en ligne pour que l'IA comprenne vos spécialités
              </li>
              <li class="flex items-start gap-4 text-base md:text-lg font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Être référencé sur les annuaires juridiques qui comptent pour les algorithmes
              </li>
            </ul>
          </div>
          <div class="border border-warmgray p-8 md:p-10 bg-sand slide-in-right card-hover">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-5">Visibilité locale</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-4 text-base md:text-lg font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Remonter dans les résultats Google Maps de votre ville et de votre arrondissement
              </li>
              <li class="flex items-start gap-4 text-base md:text-lg font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Optimiser votre fiche Google Business Profile
              </li>
              <li class="flex items-start gap-4 text-base md:text-lg font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Gérer vos avis clients et renforcer votre e-réputation
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ COMMENT ÇA MARCHE ═══════════════════ -->
    <section id="comment-ca-marche" class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Comment ça marche">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
          Comment ça marche
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10 mb-12 md:mb-16">
          <div class="relative scale-in card-hover" style="transition-delay: 0s;">
            <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">01</p>
            <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Diagnostic gratuit</h3>
            <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">Nous testons votre cabinet sur ChatGPT, Claude, Google Maps et les assistants IA pour chacune de vos spécialités. Vous recevez un score sur 100.</p>
            <div class="hidden md:flex absolute top-12 -right-5 md:-right-6 items-center text-warmgray/50" aria-hidden="true">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <div class="relative scale-in card-hover" style="transition-delay: 0.15s;">
            <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">02</p>
            <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">On en parle ensemble</h3>
            <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">Un rapport clair avec les actions prioritaires pour votre cabinet. Classées par impact, adaptées à votre domaine juridique.</p>
            <div class="hidden md:flex absolute top-12 -right-5 md:-right-6 items-center text-warmgray/50" aria-hidden="true">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <div class="scale-in card-hover" style="transition-delay: 0.3s;">
            <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">03</p>
            <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Vos clients vous trouvent</h3>
            <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">Nous mettons en place les corrections. Vos clients vous trouvent sur ChatGPT et Google Maps quand ils cherchent un avocat dans votre spécialité.</p>
          </div>
        </div>
        <div class="text-center blur-in">
          <a href="#audit" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark" onclick="plausible('CTA Click', {props: {location: 'avocats-how-it-works'}})">
            Demander mon diagnostic gratuit →
          </a>
        </div>
        <p class="text-center text-sm font-sans font-medium text-stone mt-6 blur-in">
          Un seul cabinet d'avocats par arrondissement et par spécialité, pour vous garantir l'exclusivité.
        </p>
      </div>
    </section>

    <!-- ═══════════════════ FAQ ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Questions fréquentes">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
            Questions fréquentes
          </h2>
          <div class="space-y-0 fade-up">
            <details class="group border-b border-warmgray/30" open>
              <summary class="flex items-center justify-between gap-4 py-5 md:py-6 cursor-pointer list-none font-sans font-medium text-base md:text-lg text-charcoal transition-colors duration-200 hover:text-terracotta hover:pl-2 [&::-webkit-details-marker]:hidden">
                <span>Est-ce compatible avec les règles déontologiques du Barreau ?</span>
