---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AuditForm from '../../components/AuditForm.astro';

const formules = [
  {
    name: 'Diagnostico',
    tagline: 'Saber donde esta',
    price: 'Gratis',
    priceDetail: '',
    description: "Analizamos su negocio en Google y en la IA. Recibira un informe claro con su puntuacion y las acciones prioritarias.",
    includes: [
      'Puntuacion de visibilidad sobre 100',
      'Informe claro con diagnostico completo',
      'Llamada de 15 min para comentarlo',
    ],
    ideal: "Para saber si tiene un problema de visibilidad y cual es.",
    cta: 'Solicitar mi diagnostico gratuito',
    ctaHref: '#diagnostic',
    highlight: false,
    free: true,
  },
  {
    name: 'Esencial',
    tagline: 'Sentar las bases',
    price: '399 €',
    priceDetail: 'sin IVA · servicio único',
    description: "Establecemos los cimientos para que Google y la IA comiencen a recomendarle.",
    includes: [
      'Todo el diagnostico incluido',
      'Ficha de Google optimizada y completa',
      'Registro en 5 directorios clave de su sector',
      '2 publicaciones Google Business Profile redactadas y publicadas',
      'Presencia en las fuentes consultadas por la IA',
      'Schema.org / datos estructurados (si tiene sitio web)',
      'Hoja de ruta personalizada con capturas antes/despues',
      'Llamada de devolucion de 30 min',
    ],
    ideal: "Para negocios que parten de cero o que tienen una presencia en linea descuidada.",
    cta: 'Solicitar mi diagnostico gratuito',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
  {
    name: 'Completo',
    tagline: 'Ir mas lejos',
    price: '699 €',
    priceDetail: 'sin IVA · servicio único',
    description: "Optimizamos toda su presencia en linea para maximizar sus posibilidades de ser encontrado y recomendado.",
    includes: [
      'Todo el Esencial incluido',
      'Optimizacion completa en 15 puntos',
      'Registro en 10+ directorios de su sector',
      'Estrategia de resenas en linea (plantillas + guia + codigo QR)',
      '4 publicaciones Google Business Profile redactadas y publicadas',
      'Schema.org completo (empresa + FAQ + profesionales)',
      'Informe competitivo (3 competidores analizados)',
      'Optimizacion basica de su sitio web (si existe)',
      'Llamada en profundidad de 45 min',
    ],
    ideal: "Para negocios que quieren ir mas lejos y dominar su zona.",
    cta: 'Solicitar mi diagnostico gratuito',
    ctaHref: '#diagnostic',
    highlight: true,
    free: false,
  },
  {
    name: 'Premium',
    tagline: 'Resultados duraderos',
    price: '1 199 €',
    priceDetail: 'sin IVA · servicio único',
    description: "Nos encargamos de toda su visibilidad en linea con un servicio completo y a medida.",
    includes: [
      'Todo el Completo incluido',
      'Registro en 20+ directorios',
      '8 publicaciones Google Business Profile redactadas y publicadas',
      'Investigacion de palabras clave completa para su sector',
      'Analisis de 5 competidores',
      'Optimizacion completa de su sitio web',
      'Schema.org avanzado (todos los tipos relevantes)',
      'Guia estrategica personalizada a 6 meses',
    ],
    ideal: "Para negocios que quieren el maximo en un solo servicio.",
    cta: 'Solicitar mi diagnostico gratuito',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
];
---
<Layout
  title="Nuestros planes — Eddie Miller Agency"
  description="Diagnostico gratuito, acompanamiento a medida. Descubra nuestros planes para ser encontrado por sus futuros clientes en Google y ChatGPT."
  canonicalUrl="https://eddiemiller.agency/es/planes"
  ogTitle="Nuestros planes — Eddie Miller Agency"
  ogDescription="Diagnostico gratuito, acompanamiento a medida para ser encontrado por sus futuros clientes."
>
  <Header />

  <main id="main-content" class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">

      <!-- Page header -->
      <div class="text-center mb-12 md:mb-16 max-w-2xl mx-auto">
        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight mb-4 fade-up-slow">
          Planes claros, resultados concretos
        </h1>
        <div class="mx-auto mb-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed blur-in" style="transition-delay: 0.3s;">
          Todo empieza con un diagnostico gratuito. Despues, le proponemos el plan adaptado a su situacion. Sin paquetes innecesarios, sin sorpresas.
        </p>
      </div>

      <!-- Formule cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {formules.map((f) => (
          <div class:list={[
            'flex flex-col border p-6 md:p-8 bg-cream card-hover scale-in',
            f.highlight ? 'border-terracotta' : 'border-warmgray',
          ]}>
            <!-- Badge zone — fixed height so titles align -->
            <div class="lg:min-h-[1.5rem] mb-2">
              {f.highlight && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  El mas solicitado
                </p>
              )}
              {f.free && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Gratuito
                </p>
              )}
            </div>
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-1">
              {f.name}
            </h2>
            <p class="text-sm font-sans font-medium text-terracotta mb-4">
              {f.tagline}
            </p>
            <div class="mb-5">
              <p class="text-3xl md:text-4xl font-serif font-normal text-charcoal leading-tight">
                {f.price}
              </p>
              {f.priceDetail && (
                <p class="text-sm font-sans text-stone mt-1">{f.priceDetail}</p>
              )}
            </div>
            <p class="text-sm font-sans font-normal leading-relaxed text-stone mb-6 lg:min-h-[6rem]">
              {f.description}
            </p>
            <ul class="space-y-3 mb-6 flex-1">
              {f.includes.map((item) => (
                <li class="flex items-start gap-2 text-sm font-sans text-stone">
                  <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
            <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic mb-6">
              {f.ideal}
            </p>
            <a
              href={f.ctaHref}
              class:list={[
                'block text-center px-6 py-3 font-sans font-medium text-sm tracking-wider uppercase transition-colors duration-300 mt-auto',
                f.highlight
                  ? 'text-cream bg-terracotta hover:bg-terracotta-dark'
                  : 'text-charcoal border border-warmgray hover:border-terracotta hover:text-terracotta',
              ]}
            >
              {f.cta} →
            </a>
          </div>
        ))}
      </div>

      <!-- Seguimiento mensual -->
      <div class="mt-10 md:mt-14 border border-warmgray p-8 md:p-10 bg-sand card-hover fade-up">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
          <div class="flex-1">
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-2">
              Seguimiento mensual
            </h2>
            <div class="mb-4">
              <p class="text-3xl md:text-4xl font-serif font-normal text-charcoal leading-tight">
                99 €
              </p>
              <p class="text-sm font-sans text-stone mt-1">sin IVA/mes</p>
              <p class="text-sm font-sans font-medium text-terracotta mt-1">Sin compromiso · cancelable en cualquier momento</p>
            </div>
            <p class="text-base font-sans font-normal leading-relaxed text-stone mb-5">
              Supervisamos su visibilidad cada mes, ajustamos lo que sea necesario y recibe un informe de progreso.
            </p>
            <ul class="space-y-3 mb-5">
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Re-test mensual de puntuacion de visibilidad IA
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                2 a 4 publicaciones Google Business Profile al mes
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Monitoreo de resenas Google + respuestas sugeridas
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Informe mensual de progreso
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Exclusividad geografica: un solo cliente por zona y especialidad
              </li>
            </ul>
            <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic">
              Propuesto despues de cada servicio.
            </p>
          </div>
          <a
            href="#diagnostic"
            class="inline-block shrink-0 text-center px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Saber mas
          </a>
        </div>
      </div>

      <!-- ROI por sector -->
      <div class="mt-14 md:mt-20 max-w-4xl mx-auto">
        <h2 class="text-center text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Cuánto te aporta concretamente
        </h2>
        <p class="text-center text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-10 md:mb-12 fade-up">
          Una inversión que se amortiza rápidamente, sea cual sea tu sector.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          <div class="border border-warmgray p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Restaurante · Esencial (399 €)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Un cubierto extra por noche a 35 € = +1 050 €/mes. La fórmula "Esencial" se amortiza en 12 días. Después, los beneficios son crecientes para ti.
            </p>
          </div>
          <div class="border border-terracotta p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Dentista · Completo (699 €)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Con la fórmula "Completo", basta con un solo paciente nuevo para amortizarla, y nuestros resultados muestran una media de +12 nuevos pacientes al mes.
            </p>
          </div>
          <div class="border border-warmgray p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Hotel · Premium (1 199 €)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Cada reserva directa te ahorra entre un 15 y un 22 % de comisión OTA. Para un hotel a 160 €/noche, son de 25 a 35 € por noche directamente para ti. La fórmula "Premium" se amortiza en un mes, y después disfrutas directamente de la inversión.
            </p>
          </div>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="mt-14 md:mt-20 text-center max-w-2xl mx-auto">
        <h2 class="text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          No esta seguro del plan que necesita?
        </h2>
        <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-8 fade-up">
          Empiece por el diagnostico gratuito. Le diremos exactamente donde esta y que tiene mas impacto para su situacion. Usted decide despues.
        </p>
        <a
          href="#diagnostic"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark fade-up"
        >
          Solicitar mi diagnostico gratuito
        </a>
      </div>

    </div>
  </main>

  <AuditForm />
  <Footer />
</Layout>
