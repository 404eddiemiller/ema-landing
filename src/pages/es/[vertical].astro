---
import VerticalLayout from '../../components/VerticalLayout.astro';
import type { VerticalData } from '../../data/verticals/types';

export async function getStaticPaths() {
  const slugs = ['dentistas', 'restaurantes', 'hoteles', 'abogados', 'peluquerias', 'spa', 'gimnasios', 'bares'];
  const entries = await Promise.all(
    slugs.map(async (slug) => {
      const mod = await import(`../../data/verticals/es/${slug}.ts`);
      return { params: { vertical: slug }, props: { data: mod.data as VerticalData } };
    })
  );
  return entries;
}

interface Props { data: VerticalData }
const { data } = Astro.props;
---
<VerticalLayout data={data} />
