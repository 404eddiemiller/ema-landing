---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Plus de clients pour votre restaurant | Eddie Miller Agency"
  description="Vos futurs clients demandent à ChatGPT où manger. On fait en sorte que la réponse, ce soit vous. Diagnostic gratuit en 24h."
  canonicalUrl="https://eddiemiller.agency/restaurants"
  ogTitle="Plus de clients pour votre restaurant | Eddie Miller Agency"
  ogDescription="Vos futurs clients demandent à ChatGPT où manger. On fait en sorte que la réponse, ce soit vous. Diagnostic gratuit en 24h."
>
  <Header />
  <main id="main-content">

    <!-- ═══════════════════ HERO ═══════════════════ -->
    <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 lg:pt-48 lg:pb-32 bg-cream" aria-label="Accroche principale">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl">
          <p class="inline-block px-3 py-1 mb-6 text-sm font-sans font-medium text-terracotta border border-terracotta/40 tracking-wide">
            Spécialiste restaurants
          </p>
          <h1 class="text-[2.5rem] md:text-[3.25rem] lg:text-[4rem] font-serif font-normal leading-[1.1] tracking-[-0.02em] text-charcoal">
            «&nbsp;Où manger ce soir&nbsp;?&nbsp;» — vos futurs clients posent la question à&nbsp;ChatGPT. On fait en sorte que la réponse, ce&nbsp;soit&nbsp;vous.
          </h1>
          <p class="mt-6 md:mt-8 max-w-[65ch] text-lg md:text-xl font-sans font-normal leading-relaxed text-stone">
            Touristes et Parisiens ne cherchent plus sur Google. Ils demandent directement à l'IA. Si votre restaurant n'apparaît pas dans les 3 à 5 noms que l'IA recommande, le couvert va chez votre voisin.
          </p>
          <div class="flex flex-col sm:flex-row items-start gap-4 mt-8 md:mt-10">
            <a href="#audit" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark" onclick="plausible('CTA Click', {props: {location: 'restaurants-hero'}})">
              Tester ma visibilité gratuitement
            </a>
            <a href="#comment-ca-marche" class="inline-flex items-center gap-1 px-2 py-4 font-sans font-medium text-base text-stone transition-colors duration-200 hover:text-charcoal">
              Voir comment ça marche ↓
            </a>
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-2 mt-6 md:mt-8">
            <span class="text-sm font-sans text-stone/80">✓ Résultat en 24h</span>
            <span class="text-sm font-sans text-stone/80">✓ 100 % gratuit</span>
            <span class="text-sm font-sans text-stone/80">✓ 1 seul restaurant par quartier</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ SOCIAL PROOF ═══════════════════ -->
    <section class="py-12 md:py-16 bg-sand" aria-label="Plateformes optimisées">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <p class="text-center text-sm font-sans font-medium tracking-[0.1em] uppercase text-stone mb-8">
          Vos clients vous cherchent ici
        </p>
        <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10 lg:gap-14">
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">ChatGPT</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Google Maps</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Gemini</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">·</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Perplexity</span>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ CE QUE VOUS RECEVEZ ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Ce que vous recevez">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-in">
            Ce que vous recevez en&nbsp;24h
          </h2>
          <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-14 fade-in">
            Un diagnostic complet, pensé pour les restaurateurs. Pas un email générique.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
            <div class="flex gap-4 fade-in">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">Score de visibilité /100</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">Votre note globale sur ChatGPT, Perplexity, Gemini et Google Maps. Vous savez exactement où vous en êtes.</p>
              </div>
            </div>
            <div class="flex gap-4 fade-in">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">Diagnostic par plateforme</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">Pourquoi ChatGPT ne vous recommande pas quand un touriste cherche «&nbsp;où manger près de la Tour Eiffel&nbsp;».</p>
              </div>
            </div>
            <div class="flex gap-4 fade-in">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">3 actions prioritaires</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">Les corrections classées par impact. Ce qui fera venir des clients le plus vite.</p>
              </div>
            </div>
            <div class="flex gap-4 fade-in">
              <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
              <div>
                <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">Appel de restitution</h3>
                <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">15 minutes pour parcourir vos résultats, répondre à vos questions et définir la suite.</p>
              </div>
            </div>
          </div>
          <div class="text-center mt-10 md:mt-12 fade-in">
            <a href="#audit" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark">
              Tester ma visibilité gratuitement
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ TÉMOIGNAGE ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Résultat client">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-in">
          L'impact concret pour un restaurant
        </h2>
        <div class="max-w-3xl mx-auto">
          <div class="border border-warmgray bg-cream p-8 md:p-12 fade-in">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 mb-8">
              <div class="text-center md:text-left">
                <p class="text-sm font-sans font-medium text-stone/70 tracking-[0.1em] uppercase mb-3">Avant</p>
                <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray">12<span class="text-[1.5rem]">/100</span></p>
                <p class="mt-2 text-base font-sans font-normal leading-relaxed text-stone">Score de visibilité</p>
                <p class="text-sm font-sans text-stone/70 mt-1">Quasi-invisible sur les assistants IA</p>
              </div>
              <div class="text-center md:text-left">
                <p class="text-sm font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-3">Après 6 semaines</p>
                <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta">91<span class="text-[1.5rem]">/100</span></p>
                <p class="mt-2 text-base font-sans font-normal leading-relaxed text-stone">Score de visibilité</p>
                <p class="text-sm font-sans text-stone/70 mt-1">+18 couverts par semaine</p>
              </div>
            </div>
            <div class="w-full h-px bg-warmgray/30 mb-8" aria-hidden="true"></div>
            <blockquote>
              <p class="text-lg md:text-xl font-sans font-normal leading-relaxed text-stone italic">
                «&nbsp;Un touriste américain m'a dit qu'il avait trouvé notre restaurant en demandant à ChatGPT "best bistro near Eiffel Tower". On n'a rien changé à la carte, on n'a pas refait le site. On a juste suivi le plan d'Eddie Miller. Dix-huit couverts de plus par semaine.&nbsp;»
              </p>
              <footer class="mt-4">
                <p class="font-sans font-medium text-base text-charcoal">Marc D.</p>
                <p class="font-sans text-sm text-stone">Restaurant — Paris 7e</p>
              </footer>
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ STATS / PROBLÈME ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Le problème">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-in">
          Ce qui a changé pour les restaurateurs
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-12 md:mb-16">
          <div class="border border-warmgray p-8 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
            <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4" data-count-to="40" data-suffix="%">40%</p>
            <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-4">des voyageurs préparent leur trip avec l'IA — et demandent où manger</p>
            <p class="text-sm font-sans font-medium text-stone/70">Phocuswright, 2026</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
            <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4" data-count-to="83" data-suffix="%">83%</p>
            <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-4">des restaurants parisiens sont invisibles quand l'IA recommande une adresse</p>
            <p class="text-sm font-sans font-medium text-stone/70">Local Falcon, 2026</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
            <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4">3 à 5</p>
            <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-4">noms : c'est tout ce que ChatGPT donne quand on lui demande un restaurant</p>
          </div>
        </div>
        <p class="max-w-[65ch] mx-auto text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone fade-in">
          TripAdvisor perd du terrain face à l'IA. Quand un touriste demande «&nbsp;meilleur bistrot près du Marais&nbsp;» à ChatGPT, l'IA recommande 3 à 5 adresses. Pas une page de résultats. Si vous n'y êtes pas, le couvert va chez votre voisin.
        </p>
      </div>
    </section>

    <!-- ═══════════════════ PROBLÈMES SPÉCIFIQUES RESTAURANTS ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Pourquoi c'est différent pour les restaurants">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-in">
          Pourquoi votre restaurant n'apparaît pas
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 max-w-4xl mx-auto">
          <div class="border border-warmgray p-8 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">TripAdvisor et Google suffisaient. Plus maintenant.</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">L'IA ne parcourt pas les pages TripAdvisor comme un client. Elle synthétise des dizaines de sources. Si vos signaux sont faibles, vous n'êtes tout simplement pas recommandé.</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Les touristes demandent à l'IA</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">40 % des voyageurs préparent leur séjour avec l'IA. Un touriste dans son hôtel qui demande à ChatGPT «&nbsp;where to eat near Eiffel Tower&nbsp;» reçoit 3 noms. Pas 30.</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Les avis ne parlent pas tout seuls</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">De bons avis, c'est important. Mais l'IA a besoin de plus : informations complètes, présence cohérente, bons annuaires. Sans ça, vos 4,5 étoiles ne servent à rien.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ SOLUTION ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Ce que nous faisons">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-in">
          On amène plus de clients dans votre restaurant
        </h2>
        <p class="text-center max-w-[55ch] mx-auto text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-16 fade-in">
          Deux leviers complémentaires pour remplir vos tables.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-3xl mx-auto">
          <div class="border border-warmgray p-8 md:p-10 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
            <h3 class="text-xl md:text-[1.5rem] font-serif font-normal leading-[1.2] text-charcoal mb-4">Être trouvé sur Google</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Remonter dans Google Maps quand un client cherche un restaurant dans votre quartier
              </li>
              <li class="flex items-start gap-3 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Optimiser votre fiche Google : photos, horaires, menu, catégories
              </li>
              <li class="flex items-start gap-3 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Tirer le meilleur de vos avis clients
              </li>
            </ul>
          </div>
          <div class="border border-warmgray p-8 md:p-10 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
            <h3 class="text-xl md:text-[1.5rem] font-serif font-normal leading-[1.2] text-charcoal mb-4">Être recommandé par les IA</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Apparaître quand un touriste demande «&nbsp;where to eat&nbsp;» à ChatGPT
              </li>
              <li class="flex items-start gap-3 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Être cité quand un Parisien demande une recommandation à Gemini ou Perplexity
              </li>
              <li class="flex items-start gap-3 text-base font-sans font-normal leading-relaxed text-stone">
                <span class="mt-2 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Être présent sur les sources que l'IA consulte pour faire ses recommandations
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ COMMENT ÇA MARCHE ═══════════════════ -->
    <section id="comment-ca-marche" class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Comment ça marche">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-in">
          Comment ça marche
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10 mb-12 md:mb-16">
          <div class="relative fade-in">
            <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">01</p>
            <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Diagnostic gratuit</h3>
            <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">On teste votre restaurant sur ChatGPT, Google Maps et les assistants IA. Vous recevez un score sur 100 et un diagnostic clair en 24h.</p>
            <div class="hidden md:flex absolute top-12 -right-5 md:-right-6 items-center text-warmgray/50" aria-hidden="true">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <div class="relative fade-in">
            <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">02</p>
            <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Plan d'action</h3>
            <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">Un rapport avec les actions prioritaires pour votre restaurant. Classées par impact, sans jargon, applicables immédiatement.</p>
            <div class="hidden md:flex absolute top-12 -right-5 md:-right-6 items-center text-warmgray/50" aria-hidden="true">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
          <div class="fade-in">
            <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">03</p>
            <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">Plus de clients</h3>
            <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">On met en place les corrections. Vos futurs clients vous trouvent quand ils demandent à l'IA où manger ce soir.</p>
          </div>
        </div>
        <div class="text-center fade-in">
          <a href="#audit" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark" onclick="plausible('CTA Click', {props: {location: 'restaurants-how-it-works'}})">
            Tester ma visibilité gratuitement
          </a>
        </div>
        <p class="text-center text-sm font-sans font-medium text-stone mt-6 fade-in">
          Un seul restaurant par quartier et par type de cuisine — pour vous garantir l'exclusivité.
        </p>
      </div>
    </section>

    <!-- ═══════════════════ FAQ ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Questions fréquentes">
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-in">
            Questions fréquentes
          </h2>
          <div class="space-y-0 fade-in">
            <details class="group border-b border-warmgray/30" open>
              <summary class="flex items-center justify-between gap-4 py-5 md:py-6 cursor-pointer list-none font-sans font-medium text-base md:text-lg text-charcoal transition-colors duration-200 hover:text-terracotta [&::-webkit-details-marker]:hidden">
                <span>TripAdvisor et Google, ça ne suffit plus ?</span>
                <svg class="w-5 h-5 shrink-0 text-warmgray transition-transform duration-300 group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
              </summary>
              <div class="pb-6 pr-8">
                <p class="text-base font-sans font-normal leading-relaxed text-stone">Google reste important, et nous l'optimisons aussi. Mais de plus en plus de clients — surtout les touristes — passent directement par l'IA. L'IA ne montre pas 10 liens. Elle recommande 3 à 5 noms. Si vous n'y êtes pas, c'est un autre restaurant qui prend le couvert.</p>
              </div>
            </details>
            <details class="group border-b border-warmgray/30">
              <summary class="flex items-center justify-between gap-4 py-5 md:py-6 cursor-pointer list-none font-sans font-medium text-base md:text-lg text-charcoal transition-colors duration-200 hover:text-terracotta [&::-webkit-details-marker]:hidden">
                <span>En combien de temps mon restaurant apparaît sur ChatGPT ?</span>
