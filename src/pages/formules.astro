---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import AuditForm from '../components/AuditForm.astro';
import Footer from '../components/Footer.astro';

const formules = [
  {
    name: 'Diagnostic',
    tagline: 'Savoir où vous en êtes',
    price: 'Gratuit',
    priceDetail: 'sans engagement',
    description: "On teste la visibilité de votre nom sur les IA. Vous recevez un rapport clair avec votre score et les actions prioritaires.",
    includes: [
      'Score de visibilité sur 100',
      'Rapport clair avec audit complet',
      'Appel de 15 min pour en parler',
    ],
    ideal: "Pour savoir si vous avez un problème de visibilité et lequel.",
    cta: 'Demander mon diagnostic gratuit',
    ctaHref: '#diagnostic',
    highlight: false,
    free: true,
  },
  {
    name: 'Essentiel',
    tagline: 'Poser les bases',
    price: '399 €',
    priceDetail: 'HT · prestation unique',
    description: "On met en place les fondations pour que les IA commencent à vous recommander.",
    includes: [
      'Fiche Google optimisée et complète',
      'Votre entreprise référencée là où les IA et Google cherchent leurs informations',
      '2 posts Google Business Profile rédigés et publiés',
      'Présence sur les sources consultées par les IA',
      'Configuration technique pour que les IA vous recommandent (si site existant)',
      'Feuille de route personnalisée avec captures avant/après',
      'Appel de restitution de 30 min',
    ],
    ideal: "Pour les entreprises qui partent de zéro ou qui ont une présence en ligne négligée.",
    cta: 'Demander mon diagnostic gratuit',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
  {
    name: 'Complet',
    tagline: 'Obtenir plus de clients',
    price: '699 €',
    priceDetail: 'HT · prestation unique',
    description: "On optimise l'ensemble de votre présence en ligne pour maximiser vos chances d'être trouvé et recommandé par les IA.",
    includes: [
      'Toute la formule "Essentiel" incluse',
      'Optimisation complète sur 15 points',
      'Présence sur 10 sources consultées par les IA et Google',
      "Stratégie d'avis en ligne (templates + guide + QR code)",
      '4 posts Google Business Profile rédigés et publiés',
      'Configuration technique complète pour être recommandé par ChatGPT et Google',
      'Rapport concurrentiel (3 concurrents analysés)',
      'Optimisation de votre site web si existant',
      'Appel approfondi de 45 min',
    ],
    ideal: "Pour les entreprises qui veulent aller plus loin et dominer leur quartier.",
    cta: 'Demander mon diagnostic gratuit',
    ctaHref: '#diagnostic',
    highlight: true,
    free: false,
  },
  {
    name: 'Premium',
    tagline: 'Pour aller plus loin',
    price: '1 199 €',
    priceDetail: 'HT · prestation unique',
    description: "On prend en charge l'intégralité de votre visibilité en ligne avec une prestation complète et sur-mesure.",
    includes: [
      'Toute la formule "Complet" incluse',
      'Présence sur 20+ sources consultées par les IA et Google',
      '8 posts Google Business Profile rédigés et publiés',
      'Analyse des termes que vos clients utilisent pour vous trouver',
      'Rapport concurrentiel étendu (5 concurrents analysés)',
      'Optimisation complète de votre site web',
      'Configuration technique avancée pour maximiser les recommandations IA',
      'Guide stratégique personnalisé à 6 mois',
    ],
    ideal: "Pour les entreprises qui veulent le maximum en une seule prestation.",
    cta: 'Demander mon diagnostic gratuit',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
];
---
<Layout
  title="Nos formules — Eddie Miller Agency"
  description="Diagnostic gratuit, accompagnement sur-mesure. Découvrez nos formules pour être trouvé par vos futurs clients sur Google et ChatGPT."
  canonicalUrl="https://eddiemiller.agency/formules"
  ogTitle="Nos formules — Eddie Miller Agency"
  ogDescription="Diagnostic gratuit, accompagnement sur-mesure pour être trouvé par vos futurs clients."
>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Eddie Miller Agency — Formules",
    "provider": {
      "@type": "ProfessionalService",
      "name": "Eddie Miller Agency",
      "url": "https://eddiemiller.agency"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Nos formules",
      "itemListElement": formules.filter(f => !f.free).map(f => ({
        "@type": "Offer",
        "name": f.name,
        "description": f.description,
        "price": parseFloat(f.price.replace(/[^0-9]/g, '')),
        "priceCurrency": "EUR",
        "url": "https://eddiemiller.agency/formules"
      }))
    }
  })} />

  <main id="main-content" class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">

      <!-- Page header -->
      <div class="text-center mb-12 md:mb-16 max-w-2xl mx-auto">
        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight mb-4 fade-up-slow">
          Des formules claires, des résultats concrets
        </h1>
        <div class="mx-auto mb-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed blur-in" style="transition-delay: 0.3s;">
          Tout commence par un diagnostic gratuit. Ensuite, on vous propose la formule adaptée à vos besoins.
        </p>
      </div>

      <!-- Formule cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {formules.map((f) => (
          <div class:list={[
            'flex flex-col border p-6 md:p-8 bg-cream card-hover scale-in',
            f.highlight ? 'border-terracotta' : 'border-warmgray',
          ]}>
            <!-- Badge zone — fixed height so titles align -->
            <div class="lg:min-h-[1.5rem] mb-2">
              {f.highlight && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Le plus demandé
                </p>
              )}
              {f.free && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Gratuit
                </p>
              )}
            </div>
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-1">
              {f.name}
            </h2>
            <p class="text-sm font-sans font-medium text-terracotta mb-4">
              {f.tagline}
            </p>
            <div class="mb-5 lg:min-h-[4.5rem]">
              <p class="text-3xl md:text-4xl font-serif font-normal text-charcoal leading-tight">
                {f.price}
              </p>
              {f.priceDetail && (
                <p class="text-sm font-sans text-stone mt-1">{f.priceDetail}</p>
              )}
            </div>
            <p class="text-sm font-sans font-normal leading-relaxed text-stone mb-6 lg:min-h-[7.25rem]">
              {f.description}
            </p>
            <ul class="space-y-3 mb-6 lg:min-h-[22rem]">
              {f.includes.map((item) => (
                <li class="flex items-start gap-2 text-sm font-sans text-stone">
                  <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
            <div class="mt-auto">
              <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic mb-6">
                {f.ideal}
              </p>
              <a
                href={f.ctaHref}
                class:list={[
                  'block text-center px-6 py-3 font-sans font-medium text-sm tracking-wider uppercase transition-colors duration-300',
                  f.highlight
                    ? 'text-cream bg-terracotta hover:bg-terracotta-dark'
                    : 'text-charcoal border border-warmgray hover:border-terracotta hover:text-terracotta',
                ]}
                onclick={`plausible('CTA Click', {props: {location: 'formules-${f.name.toLowerCase()}'}})`}
              >
                {f.cta} →
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Suivi mensuel -->
      <div class="mt-10 md:mt-14 border border-warmgray p-8 md:p-10 bg-sand card-hover fade-up">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
          <div class="flex-1">
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-2">
              Suivi mensuel
            </h2>
            <div class="mb-4">
              <p class="text-3xl md:text-4xl font-serif font-normal text-charcoal leading-tight">
                99 €
              </p>
              <p class="text-sm font-sans text-stone mt-1">HT/mois</p>
              <p class="text-sm font-sans font-medium text-terracotta mt-1">Sans engagement · résiliable à tout moment</p>
            </div>
            <p class="text-base font-sans font-normal leading-relaxed text-stone mb-5">
              On surveille votre visibilité chaque mois, on ajuste ce qui doit l'être, et vous recevez un rapport de progression.
            </p>
            <ul class="space-y-3 mb-5">
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Rapport mensuel de progression avec évolution du test score de visibilité IA
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                2 à 4 posts Google Business Profile par mois
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Monitoring des avis Google + réponses
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Exclusivité géographique : vous devenez notre seul client par quartier et par spécialité
              </li>
            </ul>
          </div>
          <a
            href="#diagnostic"
            class="inline-block shrink-0 text-center px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
            onclick="plausible('CTA Click', {props: {location: 'formules-suivi'}})"
          >
            En savoir plus
          </a>
        </div>
      </div>

      <!-- ROI par secteur -->
      <div class="mt-14 md:mt-20 max-w-4xl mx-auto">
        <h2 class="text-center text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Combien ça rapporte concrètement
        </h2>
        <p class="text-center text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-10 md:mb-12 fade-up">
          Un investissement qui se rembourse rapidement, quel que soit votre secteur.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          <div class="border border-warmgray p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Restaurant · Essentiel (399 €)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Un couvert supplémentaire par soir à 35 € = +1 050 €/mois. La formule "Essentiel" est remboursée en 12 jours. Ensuite, les bénéfices sont croissants pour vous.
            </p>
          </div>
          <div class="border border-terracotta p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Dentiste · Complet (699 €)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Avec la formule "Complet", il suffit d'un seul nouveau patient pour la rembourser, et nos résultats montrent en moyenne +12 nouveaux patients par mois.
            </p>
          </div>
          <div class="border border-warmgray p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Hôtel · Premium (1 199 €)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Chaque réservation directe vous économise 15 à 22 % de commission OTA. Pour un hôtel à 160 €/nuit, c'est 25 à 35 € par nuit directement pour vous. La formule "Premium" est remboursée en un mois, puis vous profitez directement de l'investissement.
            </p>
          </div>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="mt-14 md:mt-20 text-center max-w-2xl mx-auto">
        <h2 class="text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Pas sûr de la formule qu'il vous faut ?
        </h2>
        <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-8 fade-up">
          Commencez par le diagnostic gratuit. On vous dira exactement où vous en êtes et ce qui a le plus d'impact pour votre situation. Vous décidez ensuite.
        </p>
        <a
          href="#diagnostic"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark fade-up"
          onclick="plausible('CTA Click', {props: {location: 'formules-bottom'}})"
        >
          Demander mon diagnostic gratuit
        </a>
      </div>

    </div>
  </main>

  <AuditForm />
  <Footer />
</Layout>
