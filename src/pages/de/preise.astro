---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const formules = [
  {
    name: 'Diagnose',
    tagline: 'Wissen, wo Sie stehen',
    description: "Wir testen Ihr Unternehmen auf Google und bei KI-Assistenten. Sie erhalten einen klaren Bericht mit Ihrem Wert und den vorrangigen Maßnahmen.",
    includes: [
      'Sichtbarkeitswert über 100',
      'Klarer Bericht mit vollständiger Diagnose',
      '15-minütiges Gespräch zur Besprechung',
    ],
    ideal: "Um herauszufinden, ob Sie ein Sichtbarkeitsproblem haben und welches.",
    cta: 'Kostenlose Diagnose anfordern',
    ctaHref: '/#diagnostic',
    highlight: false,
    free: true,
  },
  {
    name: 'Basis',
    tagline: 'Das Fundament legen',
    description: "Wir legen die Grundlagen, damit Google und KI-Assistenten beginnen, Sie zu empfehlen.",
    includes: [
      'Gesamte Diagnose inklusive',
      'Optimiertes und vollständiges Google-Profil',
      'Präsenz in den von KI genutzten Quellen',
      'Ausführliches Rückgabegespräch',
    ],
    ideal: "Für Unternehmen, die bei null anfangen oder deren Online-Präsenz vernachlässigt wurde.",
    cta: 'Angebot anfordern',
    ctaHref: '/#diagnostic',
    highlight: false,
    free: false,
  },
  {
    name: 'Komplett',
    tagline: 'Weiter gehen',
    description: "Wir optimieren Ihre gesamte Online-Präsenz, um Ihre Chancen zu maximieren, gefunden und empfohlen zu werden.",
    includes: [
      'Gesamtes Basis-Paket inklusive',
      'Vollständige Optimierung in 15 Punkten',
      'Eintrag in die wichtigsten Branchenverzeichnisse',
      'Online-Bewertungsstrategie',
      'Ausführliches 45-Min-Gespräch',
    ],
    ideal: "Für Unternehmen, die weiter gehen und ihr Viertel dominieren wollen.",
    cta: 'Angebot anfordern',
    ctaHref: '/#diagnostic',
    highlight: true,
    free: false,
  },
  {
    name: 'Premium',
    tagline: 'Dauerhafte Ergebnisse',
    description: "Wir übernehmen Ihre Sichtbarkeit über 3 Monate mit monatlicher Betreuung und kontinuierlichen Anpassungen.",
    includes: [
      'Gesamtes Komplett-Paket inklusive',
      'Betreuung über 3 Monate',
      '3 monatliche Fortschrittsberichte',
      'Kontinuierliche Anpassungen',
      'Persönlicher Ansprechpartner',
    ],
    ideal: "Für Unternehmen, die messbare Ergebnisse und langfristige Begleitung wünschen.",
    cta: 'Angebot anfordern',
    ctaHref: '/#diagnostic',
    highlight: false,
    free: false,
  },
];
---
<Layout
  title="Unsere Pakete — Eddie Miller Agency"
  description="Kostenlose Diagnose, maßgeschneiderte Betreuung. Entdecken Sie unsere Pakete, um von Ihren zukünftigen Kunden auf Google und ChatGPT gefunden zu werden."
  canonicalUrl="https://eddiemiller.agency/de/preise"
  ogTitle="Unsere Pakete — Eddie Miller Agency"
  ogDescription="Kostenlose Diagnose, maßgeschneiderte Betreuung, um von Ihren zukünftigen Kunden gefunden zu werden."
>
  <Header />

  <main id="main-content" class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">

      <!-- Page header -->
      <div class="text-center mb-12 md:mb-16 max-w-2xl mx-auto">
        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight mb-4 fade-up-slow">
          Klare Pakete, konkrete Ergebnisse
        </h1>
        <div class="mx-auto mb-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed blur-in" style="transition-delay: 0.3s;">
          Alles beginnt mit einer kostenlosen Diagnose. Danach schlagen wir Ihnen das passende Paket für Ihre Situation vor. Keine unnötigen Pauschalen, keine Überraschungen.
        </p>
      </div>

      <!-- Formule cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {formules.map((f) => (
          <div class:list={[
            'flex flex-col border p-6 md:p-8 bg-cream card-hover scale-in',
            f.highlight ? 'border-terracotta' : 'border-warmgray',
          ]}>
            <!-- Badge zone — fixed height so titles align -->
            <div class="lg:min-h-[1.5rem] mb-2">
              {f.highlight && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Am beliebtesten
                </p>
              )}
              {f.free && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Kostenlos
                </p>
              )}
            </div>
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-1">
              {f.name}
            </h2>
            <p class="text-sm font-sans font-medium text-terracotta mb-3">
              {f.tagline}
            </p>
            <p class="text-sm font-sans font-normal leading-relaxed text-stone mb-6 lg:min-h-[8.75rem]">
              {f.description}
            </p>
            <ul class="space-y-3 mb-6 flex-1">
              {f.includes.map((item) => (
                <li class="flex items-start gap-2 text-sm font-sans text-stone">
                  <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
            <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic mb-6">
              {f.ideal}
            </p>
            <a
              href={f.ctaHref}
              class:list={[
                'block text-center px-6 py-3 font-sans font-medium text-sm tracking-wider uppercase transition-colors duration-300 mt-auto',
                f.highlight
                  ? 'text-cream bg-terracotta hover:bg-terracotta-dark'
                  : 'text-charcoal border border-warmgray hover:border-terracotta hover:text-terracotta',
              ]}
            >
              {f.cta} →
            </a>
          </div>
        ))}
      </div>

      <!-- Monatliche Betreuung -->
      <div class="mt-10 md:mt-14 border border-warmgray p-8 md:p-10 bg-sand card-hover fade-up">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div class="flex-1">
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-2">
              Monatliche Betreuung
            </h2>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Nach jeder Leistung angeboten. Wir überwachen Ihre Sichtbarkeit jeden Monat, passen an, was nötig ist, und Sie erhalten einen Fortschrittsbericht. Ohne Verpflichtung, jederzeit kündbar.
            </p>
          </div>
          <a
            href="/#diagnostic"
            class="inline-block shrink-0 text-center px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Mehr erfahren
          </a>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="mt-14 md:mt-20 text-center max-w-2xl mx-auto">
        <h2 class="text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Nicht sicher, welches Paket Sie brauchen?
        </h2>
        <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-8 fade-up">
          Beginnen Sie mit der kostenlosen Diagnose. Wir sagen Ihnen genau, wo Sie stehen und was für Ihre Situation den größten Unterschied macht. Sie entscheiden danach.
        </p>
        <a
          href="/#diagnostic"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark fade-up"
        >
          Kostenlose Diagnose anfordern
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
