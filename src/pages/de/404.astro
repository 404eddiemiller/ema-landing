---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<Layout
  title="Seite nicht gefunden — Eddie Miller Agency"
  description="Die Seite, die Sie suchen, existiert nicht oder wurde verschoben."
  skipFaqSchema={true}
>
  <Header />
  <main class="pt-32 pb-16 md:pt-40 md:pb-24 lg:pt-48 lg:pb-32 bg-cream">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-[5rem] md:text-[7rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-6">
          404
        </p>
        <h1 class="text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-6">
          Seite nicht gefunden
        </h1>
        <p class="text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-10">
          Die Seite, die Sie suchen, existiert nicht oder wurde verschoben.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/de"
            class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Zur Startseite
          </a>
          <a
            href="/de/blog"
            class="inline-block px-8 py-4 font-sans font-medium text-base text-charcoal border border-warmgray tracking-[0.02em] transition-colors duration-300 hover:border-charcoal"
          >
            Unseren Blog lesen
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
