---
// Blog index page (German) — Lists all German blog articles sorted by date
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getDisplayDate } from '../../../utils/blog-dates';

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft && post.data.lang === 'de')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = allPosts.map((post, i) => ({ ...post, displayDate: getDisplayDate(i, allPosts.length) }));

const categories = [...new Set(posts.map((post) => post.data.category))];
---
<Layout
  title="Blog — Eddie Miller Agency"
  description="Artikel und Leitfaden, damit Ihr Unternehmen von Ihren zukuenftigen Kunden gefunden wird, auf Google und KI."
  canonicalUrl="https://eddiemiller.agency/de/blog"
  ogTitle="Blog — Eddie Miller Agency"
  ogDescription="Artikel und Leitfaden, damit Ihr Unternehmen online gefunden wird, auf Google und KI."
>
  <Header />

  <main id="main-content" class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">

      <div class="mb-12 md:mb-16 max-w-[720px]">
        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight mb-4">
          Blog
        </h1>
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed">
          Praktische Leitfaden, damit Ihr Unternehmen von Ihren zukuenftigen Kunden gefunden wird.
        </p>
      </div>

      {posts.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10 md:mb-12" id="category-filters">
        <button
          class="category-btn active px-4 py-2 text-sm font-sans font-medium tracking-wide uppercase border transition-colors duration-200 border-terracotta text-terracotta bg-terracotta/5"
          data-category="all"
        >
          Alle
        </button>
        {categories.map((cat) => (
          <button
            class="category-btn px-4 py-2 text-sm font-sans font-medium tracking-wide uppercase border border-warmgray text-stone transition-colors duration-200 hover:border-terracotta hover:text-terracotta"
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
      )}

      {posts.length === 0 && (
        <div class="py-12 md:py-16 text-center">
          <p class="font-sans text-lg text-stone leading-relaxed mb-4">
            Unsere Artikel sind derzeit nur auf Franz&ouml;sisch verf&uuml;gbar.
          </p>
          <a
            href="/blog"
            class="inline-block px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Blog auf Franz&ouml;sisch lesen &rarr;
          </a>
        </div>
      )}

      <div class="grid gap-0">
        {posts.map((post, index) => {
          const formattedDate = post.displayDate.toLocaleDateString('de-DE', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });

          return (
            <article class:list={['group fade-in', index === 0 ? 'border-t border-warmgray/30' : '', 'border-b border-warmgray/30']} data-category={post.data.category}>
              <a href={`/de/blog/${post.data.slug}`} class="block py-8 md:py-10 transition-colors duration-200 hover:bg-sand/50">
                <div class="flex flex-col md:flex-row md:items-start md:gap-8">
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-sans text-stone mb-3 md:mb-0 md:w-48 md:shrink-0 md:pt-1">
                    <time datetime={post.displayDate.toISOString().split('T')[0]}>{formattedDate}</time>
                    <span class="text-warmgray md:hidden" aria-hidden="true">&middot;</span>
                    <span class="md:hidden">{post.data.reading_time}</span>
                  </div>
                  <div class="flex-1 flex gap-6">
                    <div class="flex-1">
                      <span class="inline-block text-xs font-sans font-medium text-terracotta uppercase tracking-wider mb-2">{post.data.category}</span>
                      <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug group-hover:text-terracotta transition-colors duration-200">{post.data.title}</h2>
                      <p class="mt-2 text-sm md:text-base font-sans text-stone leading-relaxed line-clamp-2">{post.data.meta_description}</p>
                      <span class="hidden md:inline-block mt-3 text-sm font-sans text-stone">{post.data.reading_time} Lesezeit</span>
                    </div>
                    {post.data.image && (
                      <div class="hidden md:block shrink-0 self-center">
                        <picture>
                          <source srcset={post.data.image.replace('.webp', '.avif')} type="image/avif" />
                          <source srcset={post.data.image} type="image/webp" />
                        <img src={post.data.image} alt={post.data.imageAlt || post.data.title} width="200" height="105" loading="lazy" decoding="async" class="w-[200px] h-[105px] object-cover" />
                      </div>
                    )}
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>

      <div class="mt-14 md:mt-20 py-10 md:py-12 px-6 md:px-10 bg-sand border border-warmgray/30 text-center">
        <p class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-3">
          Ist Ihr Unternehmen auf KI sichtbar?
        </p>
        <p class="font-sans text-stone text-base leading-relaxed mb-6 max-w-lg mx-auto">
          Kostenlose Diagnose innerhalb von 24 Stunden: Wir pruefen, ob Ihre zukuenftigen Kunden Sie online finden, und geben Ihnen Ihre 3 wichtigsten Massnahmen.
        </p>
        <a href="/#diagnostic" class="inline-block px-6 py-3 font-sans font-medium text-[0.9375rem] text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark">
          Kostenlose Diagnose anfordern &rarr;
        </a>
        <a href="/formules" class="inline-block px-6 py-3 font-sans font-medium text-[0.9375rem] text-charcoal border border-warmgray tracking-wider uppercase transition-colors duration-300 hover:border-terracotta hover:text-terracotta">
          Unsere Pakete ansehen
        </a>
      </div>

    </div>
  </main>

  <Footer />

  <script>
    const buttons = document.querySelectorAll('.category-btn');
    const articles = document.querySelectorAll('article[data-category]');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');
        buttons.forEach(b => {
          b.classList.remove('active', 'border-terracotta', 'text-terracotta', 'bg-terracotta/5');
          b.classList.add('border-warmgray', 'text-stone');
        });
        btn.classList.add('active', 'border-terracotta', 'text-terracotta');
        btn.classList.remove('border-warmgray', 'text-stone');
        articles.forEach(article => {
          if (category === 'all' || article.getAttribute('data-category') === category) {
            article.style.display = '';
          } else {
            article.style.display = 'none';
          }
        });
      });
    });
  </script>
</Layout>
