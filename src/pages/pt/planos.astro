---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AuditForm from '../../components/AuditForm.astro';

const formulas = [
  {
    name: 'Diagnostico',
    tagline: 'Saber onde esta',
    price: 'Gratuito',
    priceDetail: '',
    description: "Testamos a sua atividade no Google e nas IA. Recebe um relatorio claro com a sua pontuacao e as acoes prioritarias.",
    includes: [
      'Pontuacao de visibilidade em 100',
      'Relatorio claro com diagnostico completo',
      'Chamada de 15 min para falar sobre o assunto',
    ],
    ideal: "Para saber se tem um problema de visibilidade e qual.",
    cta: 'Pedir o meu diagnostico gratuito',
    ctaHref: '#diagnostic',
    highlight: false,
    free: true,
  },
  {
    name: 'Essencial',
    tagline: 'Estabelecer as bases',
    price: '399 €',
    priceDetail: 'sem IVA · serviço único',
    description: "Implementamos as fundacoes para que o Google e as IA comecem a recomenda-lo.",
    includes: [
      'Todo o diagnostico incluido',
      'Ficha Google otimizada e completa',
      'Inscricao em 5 diretorios-chave do seu setor',
      '2 publicacoes Google Business Profile redigidas e publicadas',
      'Presenca nas fontes consultadas pelas IA',
      'Schema.org / dados estruturados (se site existente)',
      'Roteiro personalizado com capturas antes/depois',
      'Chamada de restituicao de 30 min',
    ],
    ideal: "Para as atividades que partem do zero ou que tem uma presenca online negligenciada.",
    cta: 'Pedir o meu diagnostico gratuito',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
  {
    name: 'Completo',
    tagline: 'Ir mais longe',
    price: '699 €',
    priceDetail: 'sem IVA · serviço único',
    description: "Otimizamos toda a sua presenca online para maximizar as hipoteses de ser encontrado e recomendado.",
    includes: [
      'Todo o Essencial incluido',
      'Otimizacao completa em 15 pontos',
      'Inscricao em 10+ diretorios do seu setor',
      'Estrategia de avaliacoes online (modelos + guia + codigo QR)',
      '4 publicacoes Google Business Profile redigidas e publicadas',
      'Schema.org completo (empresa + FAQ + profissionais)',
      'Relatorio competitivo (3 concorrentes analisados)',
      'Otimizacao basica do seu site web (se existente)',
      'Chamada aprofundada de 45 min',
    ],
    ideal: "Para as atividades que querem ir mais longe e dominar o seu bairro.",
    cta: 'Pedir o meu diagnostico gratuito',
    ctaHref: '#diagnostic',
    highlight: true,
    free: false,
  },
  {
    name: 'Premium',
    tagline: 'Resultados duraveis',
    price: '1 199 €',
    priceDetail: 'sem IVA · serviço único',
    description: "Encarregamo-nos de toda a sua visibilidade online com um servico completo e a medida.",
    includes: [
      'Todo o Completo incluido',
      'Inscricao em 20+ diretorios',
      '8 publicacoes Google Business Profile redigidas e publicadas',
      'Pesquisa de palavras-chave completa para o seu setor',
      'Analise de 5 concorrentes',
      'Otimizacao completa do seu site web',
      'Schema.org avancado (todos os tipos relevantes)',
      'Guia estrategico personalizado a 6 meses',
    ],
    ideal: "Para as atividades que querem o maximo num unico servico.",
    cta: 'Pedir o meu diagnostico gratuito',
    ctaHref: '#diagnostic',
    highlight: false,
    free: false,
  },
];
---
<Layout
  title="Os nossos planos — Eddie Miller Agency"
  description="Diagnostico gratuito, acompanhamento a medida. Descubra os nossos planos para ser encontrado pelos seus futuros clientes no Google e no ChatGPT."
  canonicalUrl="https://eddiemiller.agency/pt/planos"
  ogTitle="Os nossos planos — Eddie Miller Agency"
  ogDescription="Diagnostico gratuito, acompanhamento a medida para ser encontrado pelos seus futuros clientes."
>
  <Header />

  <main id="main-content" class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">

      <!-- Page header -->
      <div class="text-center mb-12 md:mb-16 max-w-2xl mx-auto">
        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight mb-4 fade-up-slow">
          Planos claros, resultados concretos
        </h1>
        <div class="mx-auto mb-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed blur-in" style="transition-delay: 0.3s;">
          Tudo comeca com um diagnostico gratuito. Depois, propomos-lhe o plano adaptado a sua situacao. Sem pacote inutil, sem surpresas.
        </p>
      </div>

      <!-- Formule cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {formulas.map((f) => (
          <div class:list={[
            'flex flex-col border p-6 md:p-8 bg-cream card-hover scale-in',
            f.highlight ? 'border-terracotta' : 'border-warmgray',
          ]}>
            <!-- Badge zone — fixed height so titles align -->
            <div class="lg:min-h-[1.5rem] mb-2">
              {f.highlight && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  O mais procurado
                </p>
              )}
              {f.free && (
                <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase">
                  Gratuito
                </p>
              )}
            </div>
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-1">
              {f.name}
            </h2>
            <p class="text-sm font-sans font-medium text-terracotta mb-4">
              {f.tagline}
            </p>
            <div class="mb-5">
              <p class="text-3xl md:text-4xl font-serif font-normal text-charcoal leading-tight">
                {f.price}
              </p>
              {f.priceDetail && (
                <p class="text-sm font-sans text-stone mt-1">{f.priceDetail}</p>
              )}
            </div>
            <p class="text-sm font-sans font-normal leading-relaxed text-stone mb-6 lg:min-h-[6rem]">
              {f.description}
            </p>
            <ul class="space-y-3 mb-6 flex-1">
              {f.includes.map((item) => (
                <li class="flex items-start gap-2 text-sm font-sans text-stone">
                  <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
            <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic mb-6">
              {f.ideal}
            </p>
            <a
              href={f.ctaHref}
              class:list={[
                'block text-center px-6 py-3 font-sans font-medium text-sm tracking-wider uppercase transition-colors duration-300 mt-auto',
                f.highlight
                  ? 'text-cream bg-terracotta hover:bg-terracotta-dark'
                  : 'text-charcoal border border-warmgray hover:border-terracotta hover:text-terracotta',
              ]}
            >
              {f.cta} →
            </a>
          </div>
        ))}
      </div>

      <!-- Acompanhamento mensal -->
      <div class="mt-10 md:mt-14 border border-warmgray p-8 md:p-10 bg-sand card-hover fade-up">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
          <div class="flex-1">
            <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-2">
              Acompanhamento mensal
            </h2>
            <div class="mb-4">
              <p class="text-3xl md:text-4xl font-serif font-normal text-charcoal leading-tight">
                99 €
              </p>
              <p class="text-sm font-sans text-stone mt-1">sem IVA/mês</p>
              <p class="text-sm font-sans font-medium text-terracotta mt-1">Sem compromisso · cancelável a qualquer momento</p>
            </div>
            <p class="text-base font-sans font-normal leading-relaxed text-stone mb-5">
              Monitorizamos a sua visibilidade todos os meses, ajustamos o que for necessario, e recebe um relatorio de progressao.
            </p>
            <ul class="space-y-3 mb-5">
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Re-teste mensal da pontuacao de visibilidade IA
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                2 a 4 publicacoes Google Business Profile por mes
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Monitorizacao de avaliacoes Google + respostas sugeridas
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Relatorio mensal de progressao
              </li>
              <li class="flex items-start gap-2 text-sm font-sans text-stone">
                <span class="mt-1 block w-1.5 h-1.5 shrink-0 bg-terracotta" aria-hidden="true"></span>
                Exclusividade geografica: um unico cliente por bairro e especialidade
              </li>
            </ul>
            <p class="text-xs font-sans font-normal leading-relaxed text-stone/70 italic">
              Proposto apos cada prestacao.
            </p>
          </div>
          <a
            href="#diagnostic"
            class="inline-block shrink-0 text-center px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Saber mais
          </a>
        </div>
      </div>

      <!-- ROI por setor -->
      <div class="mt-14 md:mt-20 max-w-4xl mx-auto">
        <h2 class="text-center text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Quanto lhe rende concretamente
        </h2>
        <p class="text-center text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-10 md:mb-12 fade-up">
          Um investimento que se paga rapidamente, seja qual for o seu setor.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          <div class="border border-warmgray p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Restaurante · Essencial (399 €)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Um talher extra por noite a 35 € = +1 050 €/mês. A fórmula "Essencial" paga-se em 12 dias. Depois, os benefícios são crescentes para si.
            </p>
          </div>
          <div class="border border-terracotta p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Dentista · Completo (699 €)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Com a fórmula "Completo", basta um único novo paciente para a pagar, e os nossos resultados mostram em média +12 novos pacientes por mês.
            </p>
          </div>
          <div class="border border-warmgray p-6 md:p-8 bg-cream card-hover scale-in">
            <p class="text-xs font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-2">Hotel · Premium (1 199 €)</p>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">
              Cada reserva direta poupa-lhe 15 a 22 % de comissão OTA. Para um hotel a 160 €/noite, são 25 a 35 € por noite diretamente para si. A fórmula "Premium" paga-se num mês, depois beneficia diretamente do investimento.
            </p>
          </div>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="mt-14 md:mt-20 text-center max-w-2xl mx-auto">
        <h2 class="text-[2rem] md:text-[2.5rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
          Nao tem a certeza de qual plano precisa?
        </h2>
        <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-8 fade-up">
          Comece pelo diagnostico gratuito. Diremos-lhe exatamente onde esta e o que tem mais impacto para a sua situacao. Depois, decide.
        </p>
        <a
          href="#diagnostic"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark fade-up"
        >
          Pedir o meu diagnostico gratuito
        </a>
      </div>

    </div>
  </main>

  <AuditForm />
  <Footer />
</Layout>
