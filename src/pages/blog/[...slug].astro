---
// Blog article page — Dynamic route for individual blog posts
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const canonicalUrl = `https://eddiemiller.agency/blog/${post.data.slug}`;

// Format date in French
const formattedDate = post.data.date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Get related articles from internal_links
const allPosts = await getCollection('blog');
const relatedSlugs = (post.data.internal_links || []).map((link: { slug: string; anchor: string }) => link.slug);
const relatedPosts = allPosts
  .filter((p) => relatedSlugs.includes(p.data.slug))
  .slice(0, 3);
---
<Layout
  title={post.data.meta_title}
  description={post.data.meta_description}
  canonicalUrl={canonicalUrl}
  ogTitle={post.data.meta_title}
  ogDescription={post.data.meta_description}
  ogType="article"
>
  <Header />

  <!-- BlogPosting JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.meta_description,
    "datePublished": post.data.date.toISOString().split('T')[0],
    "dateModified": post.data.date.toISOString().split('T')[0],
    "author": {
      "@type": "Organization",
      "name": "Eddie Miller Agency",
      "url": "https://eddiemiller.agency"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Eddie Miller Agency",
      "url": "https://eddiemiller.agency",
      "logo": {
        "@type": "ImageObject",
        "url": "https://eddiemiller.agency/favicon.svg"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalUrl
    },
    "image": "https://eddiemiller.agency/og-image.png",
    "inLanguage": "fr",
    "keywords": post.data.tags.join(", "),
    "articleSection": post.data.category
  })} />

  <!-- BreadcrumbList JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://eddiemiller.agency" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://eddiemiller.agency/blog" },
      { "@type": "ListItem", "position": 3, "name": post.data.title, "item": canonicalUrl }
    ]
  })} />

  <article class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-[720px] mx-auto px-6 md:px-8">

      <!-- Article header -->
      <div class="mb-10 md:mb-14">
        <nav aria-label="Fil d'Ariane" class="mb-8 md:mb-10">
          <ol class="flex items-center gap-2 text-sm font-sans text-stone">
            <li>
              <a href="/" class="font-medium tracking-wide transition-colors duration-200 hover:text-terracotta">Accueil</a>
            </li>
            <li aria-hidden="true" class="text-warmgray">/</li>
            <li>
              <a href="/blog" class="font-medium tracking-wide transition-colors duration-200 hover:text-terracotta">Blog</a>
            </li>
            <li aria-hidden="true" class="text-warmgray">/</li>
            <li class="text-warmgray truncate max-w-[200px] md:max-w-none" aria-current="page">{post.data.title}</li>
          </ol>
        </nav>

        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-sans text-stone mb-4">
          <span class="font-medium text-terracotta uppercase tracking-wider text-xs">{post.data.category}</span>
          <span class="text-warmgray" aria-hidden="true">·</span>
          <time datetime={post.data.date.toISOString().split('T')[0]}>{formattedDate}</time>
          <span class="text-warmgray" aria-hidden="true">·</span>
          <span>{post.data.reading_time} de lecture</span>
        </div>

        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight">
          {post.data.title}
        </h1>
      </div>

      <!-- Article content -->
      <div class="prose">
        <Content />
      </div>

      <!-- Inline CTA -->
      <div class="my-10 md:my-14 py-6 border-t border-b border-warmgray/30">
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed mb-4">
          Vous voulez savoir si votre établissement est visible sur les IA&nbsp;?
        </p>
        <a
          href="/#audit"
          class="inline-block px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          onclick="plausible('CTA Click', {props: {location: 'blog-inline'}})"
        >
          Demander mon score GEO gratuit →
        </a>
      </div>

      <!-- CTA Section -->
      <aside class="mt-14 md:mt-20 py-10 md:py-12 px-6 md:px-10 bg-sand border border-warmgray/30" role="complementary">
        <p class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-3">
          Votre établissement est-il visible sur les IA ?
        </p>
        <p class="font-sans text-stone text-base leading-relaxed mb-6">
          Recevez votre score de visibilité IA gratuit en 30 minutes. Nous testons votre établissement sur ChatGPT, Perplexity, Gemini et Google AI Overview.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/#audit"
            class="inline-block px-6 py-3 font-sans font-medium text-[0.9375rem] text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
          >
            Demander mon audit gratuit →
          </a>
          <a
            href="/tarifs"
            class="inline-block px-6 py-3 font-sans font-medium text-[0.9375rem] text-charcoal border border-warmgray tracking-wider uppercase transition-colors duration-300 hover:border-terracotta hover:text-terracotta"
          >
            Voir nos tarifs
          </a>
        </div>
      </aside>

      <!-- Tags -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-10 pt-8 border-t border-warmgray/30">
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="inline-block px-3 py-1 text-xs font-sans font-medium text-stone bg-sand tracking-wide uppercase">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      {relatedPosts.length > 0 && (
        <div class="mt-10 pt-8 border-t border-warmgray/30">
          <h2 class="font-serif text-xl md:text-2xl text-charcoal mb-6">À lire aussi</h2>
          <div class="space-y-4">
            {relatedPosts.map((related) => (
              <a href={`/blog/${related.data.slug}`} class="block group py-3 transition-colors duration-200">
                <span class="inline-block text-xs font-sans font-medium text-terracotta uppercase tracking-wider mb-1">
                  {related.data.category}
                </span>
                <p class="font-serif text-lg text-charcoal group-hover:text-terracotta transition-colors duration-200 leading-snug">
                  {related.data.title}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </article>

  <Footer />
</Layout>
