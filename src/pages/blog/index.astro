---
// Blog index page — Lists all blog articles sorted by date
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group posts by category
const categories = [...new Set(posts.map((post) => post.data.category))];
---
<Layout
  title="Blog — Eddie Miller Agency"
  description="Articles et guides sur la visibilité IA (GEO), le SEO local et Google Business Profile pour les commerces parisiens. Dentistes, restaurants, hôtels : devenez visibles sur ChatGPT, Perplexity et Google AI."
  canonicalUrl="https://eddiemiller.agency/blog"
  ogTitle="Blog — Eddie Miller Agency"
  ogDescription="Articles et guides sur la visibilité IA (GEO) et le SEO local pour les commerces parisiens."
>
  <Header />

  <main class="pt-28 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">

      <!-- Page header -->
      <div class="mb-12 md:mb-16 max-w-[720px]">
        <h1 class="font-serif text-3xl md:text-[2.75rem] lg:text-5xl text-charcoal leading-[1.15] tracking-tight mb-4">
          Blog
        </h1>
        <p class="font-sans text-base md:text-lg text-stone leading-relaxed">
          Guides pratiques et analyses sur la visibilité IA et le SEO local pour les commerces parisiens.
        </p>
      </div>

      <!-- Articles list -->
      <div class="grid gap-0">
        {posts.map((post, index) => {
          const formattedDate = post.data.date.toLocaleDateString('fr-FR', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });

          return (
            <article class:list={['group fade-in', index === 0 ? 'border-t border-warmgray/30' : '', 'border-b border-warmgray/30']}>
              <a href={`/blog/${post.data.slug}`} class="block py-8 md:py-10 transition-colors duration-200 hover:bg-sand/50">
                <div class="flex flex-col md:flex-row md:items-start md:gap-8">

                  <!-- Meta column -->
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-sans text-stone mb-3 md:mb-0 md:w-48 md:shrink-0 md:pt-1">
                    <time datetime={post.data.date.toISOString().split('T')[0]}>{formattedDate}</time>
                    <span class="text-warmgray md:hidden" aria-hidden="true">·</span>
                    <span class="md:hidden">{post.data.reading_time}</span>
                  </div>

                  <!-- Content column -->
                  <div class="flex-1">
                    <span class="inline-block text-xs font-sans font-medium text-terracotta uppercase tracking-wider mb-2">
                      {post.data.category}
                    </span>
                    <h2 class="font-serif text-xl md:text-2xl text-charcoal leading-snug group-hover:text-terracotta transition-colors duration-200">
                      {post.data.title}
                    </h2>
                    <p class="mt-2 text-sm md:text-base font-sans text-stone leading-relaxed line-clamp-2">
                      {post.data.meta_description}
                    </p>
                    <span class="hidden md:inline-block mt-3 text-sm font-sans text-stone">
                      {post.data.reading_time} de lecture
                    </span>
                  </div>

                </div>
              </a>
            </article>
          );
        })}
      </div>

      <!-- CTA at bottom -->
      <div class="mt-14 md:mt-20 py-10 md:py-12 px-6 md:px-10 bg-sand border border-warmgray/30 text-center">
        <p class="font-serif text-xl md:text-2xl text-charcoal leading-snug mb-3">
          Votre établissement est-il visible sur les IA ?
        </p>
        <p class="font-sans text-stone text-base leading-relaxed mb-6 max-w-lg mx-auto">
          Audit gratuit en 30 minutes : votre score de visibilité IA, les plateformes où vous êtes invisible, et vos 3 actions prioritaires.
        </p>
        <a
          href="/#audit"
          class="inline-block px-6 py-3 font-sans font-medium text-[0.9375rem] text-cream bg-terracotta tracking-wider uppercase transition-colors duration-300 hover:bg-terracotta-dark"
        >
          Demander mon audit gratuit →
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
