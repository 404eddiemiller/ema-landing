---
// Social proof bar — Real brand logos (monochrome, fill-based) with hover animation
import { t, getLocaleFromPath, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);

const platforms = [
  {
    name: 'ChatGPT',
    // Hexagonal spiral/flower — OpenAI mark
    icon: '<rect x="10.5" y="3" width="3" height="8" rx="1.5" transform="rotate(0 12 12) translate(1 0)"/><rect x="10.5" y="3" width="3" height="8" rx="1.5" transform="rotate(60 12 12) translate(1 0)"/><rect x="10.5" y="3" width="3" height="8" rx="1.5" transform="rotate(120 12 12) translate(1 0)"/><rect x="10.5" y="3" width="3" height="8" rx="1.5" transform="rotate(180 12 12) translate(1 0)"/><rect x="10.5" y="3" width="3" height="8" rx="1.5" transform="rotate(240 12 12) translate(1 0)"/><rect x="10.5" y="3" width="3" height="8" rx="1.5" transform="rotate(300 12 12) translate(1 0)"/>',
  },
  {
    name: 'Perplexity',
    // Perplexity official logomark
    icon: '<path d="M22.3977 7.0896h-2.3106V.0676l-7.5094 6.3542V.1577h-1.1554v6.1966L4.4904 0v7.0896H1.6023v10.3976h2.8882V24l6.932-6.3591v6.2005h1.1554v-6.0469l6.9318 6.1807v-6.4879h2.8882V7.0896zm-3.4657-4.531v4.531h-5.355l5.355-4.531zm-13.2862.0676 4.8691 4.4634H5.6458V2.6262zM2.7576 16.332V8.245h7.8476l-6.1149 6.1147v1.9723H2.7576zm2.8882 5.0404v-3.8852h.0001v-2.6488l5.7763-5.7764v7.0111l-5.7764 5.2993zm12.7086.0248-5.7766-5.1509V9.0618l5.7766 5.7766v6.5588zm2.8882-5.0652h-1.733v-1.9723L13.3948 8.245h7.8478v8.087z"/>',
  },
  {
    name: 'Claude',
    // Anthropic official logomark
    icon: '<path d="M17.3041 3.541h-3.6718l6.696 16.918H24Zm-10.6082 0L0 20.459h3.7442l1.3693-3.5527h7.0052l1.3693 3.5528h3.7442L10.5363 3.5409Zm-.3712 10.2232 2.2914-5.9456 2.2914 5.9456Z"/>',
  },
  {
    name: 'Gemini',
    // 4-pointed star with gently curved sides
    icon: '<path d="M12 1C14 6 18 10 23 12C18 14 14 18 12 23C10 18 6 14 1 12C6 10 10 6 12 1Z"/>',
  },
];
---
<section class="py-12 md:py-16 bg-sand overflow-hidden" aria-label="Là où vos clients cherchent">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <p class="text-center text-sm font-sans font-medium tracking-[0.1em] uppercase text-stone mb-8 fade-up">
      {t('socialProof.label', locale)}
    </p>
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 lg:gap-16">
      {platforms.map((p, i) => (
        <div class="flex items-center gap-3 group fade-up">
          <svg
            class="w-7 h-7 text-warmgray transition-colors duration-300 group-hover:text-terracotta"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            set:html={p.icon}
          />
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide transition-colors duration-300 group-hover:text-charcoal">
            {p.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
