---
// Social proof bar — AI platform names
---
<section class="py-12 md:py-16 bg-sand" aria-label="Plateformes optimisées">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <p class="text-center text-sm font-sans font-medium tracking-[0.1em] uppercase text-stone mb-8">
      Nous optimisons votre visibilité sur les plateformes qui comptent
    </p>
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 lg:gap-16">
      <!-- ChatGPT -->
      <div class="flex items-center gap-2 text-stone">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2a10 10 0 0 1 7.38 16.75l.22 3.15a.5.5 0 0 1-.72.49l-2.88-1.3A10 10 0 1 1 12 2z" />
          <circle cx="8.5" cy="12" r="1" fill="currentColor" stroke="none" />
          <circle cx="12" cy="12" r="1" fill="currentColor" stroke="none" />
          <circle cx="15.5" cy="12" r="1" fill="currentColor" stroke="none" />
        </svg>
        <span class="font-sans font-medium text-base text-stone">ChatGPT</span>
      </div>
      <!-- Google -->
      <div class="flex items-center gap-2 text-stone">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <path d="M12 6v6l4 2" />
        </svg>
        <span class="font-sans font-medium text-base text-stone">Google</span>
      </div>
      <!-- Gemini -->
      <div class="flex items-center gap-2 text-stone">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2L2 12l10 10 10-10L12 2z" />
        </svg>
        <span class="font-sans font-medium text-base text-stone">Gemini</span>
      </div>
      <!-- Perplexity -->
      <div class="flex items-center gap-2 text-stone">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
          <circle cx="12" cy="17" r="0.5" fill="currentColor" stroke="none" />
        </svg>
        <span class="font-sans font-medium text-base text-stone">Perplexity</span>
      </div>
      <!-- Claude -->
      <div class="flex items-center gap-2 text-stone">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="4" />
          <path d="M8 12h8M12 8v8" />
        </svg>
        <span class="font-sans font-medium text-base text-stone">Claude</span>
      </div>
    </div>
  </div>
</section>
