---
// Social proof bar — Platform logos with hover animation
// Using stylized text-based logos since we can't use actual brand logos
const platforms = [
  { name: 'ChatGPT', icon: '<circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/>' },
  { name: 'Google Maps', icon: '<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/>' },
  { name: 'Gemini', icon: '<path d="M12 2L2 12l10 10 10-10L12 2z"/><circle cx="12" cy="12" r="3"/>' },
  { name: 'Perplexity', icon: '<circle cx="12" cy="12" r="10"/><path d="M12 6v12M6 12h12"/><path d="M8.5 8.5l7 7M15.5 8.5l-7 7"/>' },
];
---
<section class="py-12 md:py-16 bg-sand overflow-hidden" aria-label="Là où vos clients cherchent">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <p class="text-center text-sm font-sans font-medium tracking-[0.1em] uppercase text-stone mb-8 fade-up">
      Vos clients vous cherchent ici — on vous y rend visible
    </p>
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 lg:gap-16">
      {platforms.map((p, i) => (
        <div class="flex items-center gap-3 group fade-up" style={`transition-delay: ${0.1 + i * 0.12}s;`}>
          <svg
            class="w-6 h-6 text-warmgray transition-colors duration-300 group-hover:text-terracotta"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            set:html={p.icon}
          />
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide transition-colors duration-300 group-hover:text-charcoal">
            {p.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
