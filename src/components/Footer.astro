---
// Footer — Contact + legal links with animated hover effects
import { t, getLocaleFromPath, navRoutes, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);
const nav = navRoutes[locale];
---
<footer class="py-12 md:py-16 bg-charcoal section-inverted" role="contentinfo">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <div class="flex flex-col items-center gap-4 text-center">
      <p class="font-serif text-lg text-cream/90">
        Eddie Miller Agency
      </p>
      <p class="text-sm font-sans font-normal leading-relaxed text-cream/70 max-w-md">
        {t('footer.description', locale)}
      </p>
      <a
        href="mailto:contact@eddiemiller.agency"
        class="text-sm font-sans font-normal text-cream/70 transition-colors duration-200 hover:text-terracotta hover-underline"
      >
        contact@eddiemiller.agency
      </a>
      <div class="w-8 h-px bg-terracotta/40 my-2" aria-hidden="true"></div>

      <nav class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2" aria-label={t('footer.legalLinks', locale)}>
        <a href={nav.blog} class="text-sm font-sans font-normal text-cream/60 transition-colors duration-200 hover:text-cream/90 hover-underline">
          {t('header.blog', locale)}
        </a>
        <span class="text-cream/30" aria-hidden="true">·</span>
        <a href={nav.pricing} class="text-sm font-sans font-normal text-cream/60 transition-colors duration-200 hover:text-cream/90 hover-underline">
          {t('header.pricing', locale)}
        </a>
        <span class="text-cream/30" aria-hidden="true">·</span>
        <a href={nav.legal} class="text-sm font-sans font-normal text-cream/60 transition-colors duration-200 hover:text-cream/90 hover-underline">
          {t('footer.legal', locale)}
        </a>
        <span class="text-cream/30" aria-hidden="true">·</span>
        <a href={nav.terms} class="text-sm font-sans font-normal text-cream/60 transition-colors duration-200 hover:text-cream/90 hover-underline">
          {t('footer.terms', locale)}
        </a>
      </nav>

      <p class="text-xs font-sans text-cream/50">
        {t('footer.copyright', locale)}
      </p>
    </div>
  </div>
</footer>
