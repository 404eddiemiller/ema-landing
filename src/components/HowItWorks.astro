---
// HowItWorks section — "Comment ça marche" — 3 simple steps
const steps = [
  {
    number: '01',
    title: 'Vous demandez votre audit',
    description: "Remplissez le formulaire en 1 minute. On vous envoie votre diagnostic complet sous 24 heures — avec votre score de visibilité et les actions à corriger.",
  },
  {
    number: '02',
    title: 'On en parle ensemble',
    description: "15 minutes au téléphone pour parcourir vos résultats, répondre à vos questions, et voir si on peut vous aider à aller plus loin.",
  },
  {
    number: '03',
    title: 'Vos clients vous trouvent',
    description: "Si vous décidez de travailler avec nous, on met en place les corrections. En quelques semaines, vos futurs clients commencent à vous trouver.",
  },
];
---
<section id="comment-ca-marche" class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Comment ça marche">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-in">
      Comment ça marche
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10 mb-12 md:mb-16">
      {steps.map((step, i) => (
        <div class="relative fade-in">
          <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">
            {step.number}
          </p>
          <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">
            {step.title}
          </h3>
          <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">
            {step.description}
          </p>
          {i < steps.length - 1 && (
            <div class="hidden md:flex absolute top-12 -right-5 md:-right-6 items-center text-warmgray/50" aria-hidden="true">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="text-center fade-in">
      <a
        href="#audit"
        class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark"
        onclick="plausible('CTA Click', {props: {location: 'how-it-works'}})"
      >
        Tester ma visibilité gratuitement →
      </a>
    </div>

    <p class="text-center text-sm font-sans font-medium text-stone mt-6 fade-in">
      Un seul client par quartier et par spécialité — pour vous garantir l'exclusivité.
    </p>
  </div>
</section>
