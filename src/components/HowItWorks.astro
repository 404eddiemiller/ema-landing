---
// HowItWorks section — Connected timeline with animated progress line
import { t, getLocaleFromPath, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);
const steps = [
  { number: '01', title: t('howItWorks.step1Title', locale), description: t('howItWorks.step1Text', locale) },
  { number: '02', title: t('howItWorks.step2Title', locale), description: t('howItWorks.step2Text', locale) },
  { number: '03', title: t('howItWorks.step3Title', locale), description: t('howItWorks.step3Text', locale) },
];
---
<section id="comment-ca-marche" class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Comment ça marche">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
      {t('howItWorks.title', locale)}
    </h2>
    <p class="text-center max-w-[55ch] mx-auto text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-16 fade-up">
      {t('howItWorks.subtitle', locale)}
    </p>

    <div class="relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-[5.25rem] left-0 right-0 h-px" aria-hidden="true">
        <svg class="w-full h-1" viewBox="0 0 1000 2" preserveAspectRatio="none">
          <line x1="80" y1="1" x2="920" y2="1" stroke="#B5ADA6" stroke-width="1" opacity="0.3" class="draw-line" style="--line-length: 840;" />
        </svg>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10 mb-12 md:mb-16">
        {steps.map((step, i) => (
          <div class="relative scale-in">
            <!-- Step number with circle accent -->
            <div class="relative inline-block mb-6">
              <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/50 relative z-10">
                {step.number}
              </p>
              <!-- Dot indicator -->
              <div class="hidden md:block absolute -bottom-1 left-1/2 -translate-x-1/2 w-3 h-3 bg-terracotta" aria-hidden="true" style="clip-path: circle(50%);"></div>
            </div>
            <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">
              {step.title}
            </h3>
            <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
