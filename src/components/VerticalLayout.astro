---
import type { VerticalData } from '../data/verticals/types';
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { t, getLocaleFromPath, navRoutes } from '../i18n/index';

interface Props {
  data: VerticalData;
}

const { data } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const nav = navRoutes[locale];
---
<Layout
  title={data.title}
  description={data.description}
  canonicalUrl={data.canonicalUrl}
  ogTitle={data.ogTitle}
  ogDescription={data.ogDescription}
  skipFaqSchema={true}
>
  <Header />
  <main id="main-content">

    <!-- Service schema for this vertical -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": data.badge,
      "description": data.description,
      "url": data.canonicalUrl,
      "provider": {
        "@type": "ProfessionalService",
        "name": "Eddie Miller Agency",
        "url": "https://eddiemiller.agency"
      },
      "serviceType": "Local Business Visibility Consulting",
      "areaServed": {
        "@type": "Place",
        "name": "Worldwide"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": data.badge,
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": data.deliverables[0].title,
              "description": data.deliverables[0].text.replace(/<[^>]*>/g, '')
            },
            "price": "0",
            "priceCurrency": "EUR"
          }
        ]
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": data.faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    })} />

    <!-- ═══════════════════ HERO ═══════════════════ -->
    <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 lg:pt-48 lg:pb-32 bg-cream overflow-hidden" aria-label={t('vertical.ariaHero', locale)}>
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl">
          <p class="inline-block px-3 py-1 mb-6 text-sm font-sans font-medium text-terracotta border border-terracotta/40 tracking-wide">
            {data.badge}
          </p>
          <h1 class="text-[2.5rem] md:text-[3.25rem] lg:text-[4rem] font-serif font-normal leading-[1.1] tracking-[-0.02em] text-charcoal" set:html={data.headline} />
          <div class="mt-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>
          <p class="mt-6 md:mt-8 max-w-[65ch] text-lg md:text-xl font-sans font-normal leading-relaxed text-stone blur-in" set:html={data.heroText} />
          <div class="flex flex-col sm:flex-row items-start gap-4 mt-8 md:mt-10 fade-up">
            <a
              href="#diagnostic"
              class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark"
              onclick={`plausible('CTA Click', {props: {location: '${data.plausibleLocation}'}})`}
            >
              {data.ctaText}
            </a>
            <a
              href="#comment-ca-marche"
              class="inline-flex items-center gap-1 px-2 py-4 font-sans font-medium text-base text-stone transition-colors duration-200 hover:text-charcoal"
            >
              {data.secondaryCtaText}
            </a>
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-2 mt-6 md:mt-8 fade-up">
            <span class="text-sm font-sans text-stone/80">{data.trust1}</span>
            <span class="text-sm font-sans text-stone/80">{data.trust2}</span>
            <span class="text-sm font-sans text-stone/80">{data.trust3}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ SOCIAL PROOF ═══════════════════ -->
    <section class="py-12 md:py-16 bg-sand" aria-label={t('vertical.ariaSocialProof', locale)}>
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <p class="text-center text-sm font-sans font-medium tracking-[0.1em] uppercase text-stone mb-8 fade-up">
          {data.socialProofLabel}
        </p>
        <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10 lg:gap-14">
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">ChatGPT</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">&middot;</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Google Maps</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">&middot;</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Gemini</span>
          <span class="text-warmgray/60 select-none" aria-hidden="true">&middot;</span>
          <span class="font-sans font-medium text-base md:text-lg text-stone tracking-wide">Perplexity</span>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ CE QUE VOUS RECEVEZ ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label={t('vertical.ariaWhatYouGet', locale)}>
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow" set:html={data.whatYouGetTitle} />
          <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-14 fade-up">
            {data.whatYouGetSubtitle}
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
            {data.deliverables.map((item, i) => (
              <div class="flex gap-4 scale-in">
                <div class="mt-1 shrink-0"><div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div></div>
                <div>
                  <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">{item.title}</h3>
                  <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone" set:html={item.text} />
                </div>
              </div>
            ))}
          </div>
          <div class="text-center mt-10 md:mt-12 fade-in">
            <a href="#diagnostic" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark">
              {data.ctaText}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ TÉMOIGNAGE ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label={t('vertical.ariaTestimonial', locale)}>
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl mx-auto">
          <div class="border border-warmgray bg-cream p-8 md:p-12 scale-in card-hover">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 mb-8">
              <!-- Before -->
              <div class="text-center md:text-left">
                <p class="text-sm font-sans font-medium text-stone/70 tracking-[0.1em] uppercase mb-3">{t('testimonial.before', locale)}</p>
                <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray">{data.testimonial.beforeScore}<span class="text-[1.5rem]">/100</span></p>
                <p class="mt-2 text-base font-sans font-normal leading-relaxed text-stone">{data.testimonial.beforeLabel}</p>
                <p class="text-sm font-sans text-stone/70 mt-1" set:html={data.testimonial.beforeDetail} />
              </div>
              <!-- After -->
              <div class="text-center md:text-left">
                <p class="text-sm font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-3">{data.testimonial.afterDelay}</p>
                <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta">{data.testimonial.afterScore}<span class="text-[1.5rem]">/100</span></p>
                <p class="mt-2 text-base font-sans font-normal leading-relaxed text-stone">{data.testimonial.afterLabel}</p>
                <p class="text-sm font-sans text-stone/70 mt-1">{data.testimonial.afterDetail}</p>
              </div>
            </div>
            <div class="w-full h-px bg-warmgray/30 mb-8" aria-hidden="true"></div>
            <blockquote>
              <p class="text-lg md:text-xl font-sans font-normal leading-relaxed text-stone italic" set:html={data.testimonial.quote} />
              <footer class="mt-4">
                <p class="font-sans font-medium text-base text-charcoal">{data.testimonial.name}</p>
                <p class="font-sans text-sm text-stone">{data.testimonial.role}</p>
              </footer>
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ STATS / CE QUI A CHANGÉ ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label={t('vertical.ariaStats', locale)}>
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow" set:html={data.statsTitle} />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-12 md:mb-16">
          {data.stats.map((stat, i) => (
            <div class="border border-warmgray p-8 bg-cream card-hover scale-in">
              {stat.countTo !== undefined ? (
                <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4" data-count-to={stat.countTo} data-suffix={stat.suffix || ''}>{stat.countTo}{stat.suffix || ''}</p>
              ) : (
                <p class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4">{stat.staticValue}</p>
              )}
              <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-stone mb-4">{stat.text}</p>
              {stat.source && (
                <p class="text-sm font-sans font-medium text-stone/70">{stat.source}</p>
              )}
            </div>
          ))}
        </div>
        <p class="max-w-[65ch] mx-auto text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone blur-in" set:html={data.statsSubtitle} />
      </div>
    </section>

    <!-- ═══════════════════ PROBLÈMES SPÉCIFIQUES ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label={t('vertical.ariaProblems', locale)}>
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow" set:html={data.problemsTitle} />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          {data.problems.map((problem, i) => (
            <div class="border border-warmgray p-8 bg-cream card-hover scale-in">
              <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">{problem.title}</h3>
              <p class="text-base font-sans font-normal leading-relaxed text-stone">{problem.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════ SOLUTION ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label={t('vertical.ariaSolution', locale)}>
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow" set:html={data.solutionTitle} />
        <p class="text-center max-w-[55ch] mx-auto text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-16 fade-up" set:html={data.solutionSubtitle} />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-4xl mx-auto">
          <div class="border border-warmgray p-8 bg-cream slide-in-left card-hover">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">{data.solutionFeatures[0].title}</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">{data.solutionFeatures[0].text}</p>
          </div>
          <div class="border border-warmgray p-8 bg-cream slide-in-right card-hover">
            <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">{data.solutionFeatures[1].title}</h3>
            <p class="text-base font-sans font-normal leading-relaxed text-stone">{data.solutionFeatures[1].text}</p>
          </div>
        </div>
        <div class="text-center mt-10 md:mt-12 fade-up">
          <a href="#diagnostic" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark">
            {data.ctaText}
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ COMMENT ÇA MARCHE ═══════════════════ -->
    <section id="comment-ca-marche" class="py-16 md:py-24 lg:py-32 bg-cream" aria-label={t('vertical.ariaHowItWorks', locale)}>
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
          {data.howItWorksTitle}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10 mb-12 md:mb-16">
          {data.steps.map((step, i) => (
            <div class:list={['scale-in', { relative: i < 2 }]}>
              <p class="text-[4rem] md:text-[5rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/30 mb-4">{step.number}</p>
              <h3 class="text-xl md:text-[1.75rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">{step.title}</h3>
              <p class="max-w-[45ch] text-base md:text-lg font-sans font-normal leading-relaxed text-stone">{step.text}</p>
              {i < 2 && (
                <div class="hidden md:flex absolute top-12 -right-5 md:-right-6 items-center text-warmgray/50" aria-hidden="true">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              )}
            </div>
          ))}
        </div>
        <div class="text-center fade-up">
          <a href="#diagnostic" class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark" onclick={`plausible('CTA Click', {props: {location: '${data.formConfig.pageSlug}-how-it-works'}})`}>
            {data.ctaText} →
          </a>
        </div>
        <p class="text-center text-sm font-sans font-medium text-stone mt-6 fade-up">
          {data.howItWorksSubtitle}
        </p>
      </div>
    </section>

    <!-- ═══════════════════ FAQ ═══════════════════ -->
    <section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label={t('vertical.ariaFaq', locale)}>
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
            {data.faqTitle}
          </h2>
          <div class="space-y-0 fade-up">
            {data.faqs.map((faq, i) => (
              <details class="group border-b border-warmgray/30" open={i === 0 ? true : undefined}>
                <summary class="flex items-center justify-between gap-4 py-5 md:py-6 cursor-pointer list-none font-sans font-medium text-base md:text-lg text-charcoal transition-all duration-200 hover:text-terracotta hover:pl-2 [&::-webkit-details-marker]:hidden">
                  <span set:html={faq.question} />
                  <svg class="w-5 h-5 shrink-0 text-warmgray transition-transform duration-300 group-open:rotate-45 group-open:text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                </summary>
                <div class="pb-6 pr-8">
                  <p class="text-base font-sans font-normal leading-relaxed text-stone" set:html={faq.answer} />
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ FORMULAIRE ═══════════════════ -->
    <section id="diagnostic" class="py-16 md:py-24 lg:py-32 bg-cream" aria-label={t('vertical.ariaForm', locale)}>
      <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
        <div class="max-w-2xl mx-auto">
          <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow" set:html={data.formTitle} />
          <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-10 md:mb-12 fade-up">
            {data.formSubtitle}
          </p>

          <form id="audit-form" class="space-y-6 fade-up" novalidate
            data-page-slug={data.formConfig.pageSlug}
            data-submitting={t('auditForm.submitting', locale)}
            data-submit-text={data.ctaText}
            data-error-generic={t('auditForm.errorGeneric', locale)}
            data-field-required={t('auditForm.fieldRequired', locale)}
            data-email-invalid={t('auditForm.emailInvalid', locale)}
            data-redirect={nav.thankYou}
          >
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

            <div class="group">
              <label for="etablissement" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-200 group-focus-within:text-terracotta">{data.formConfig.etablissementLabel} <span class="text-terracotta">*</span></label>
              <input type="text" id="etablissement" name="etablissement" required aria-required="true" class="block w-full px-4 py-3 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]" placeholder={data.formConfig.etablissementPlaceholder} />
            </div>

            <div class="group">
              <label for="type" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-200 group-focus-within:text-terracotta">{data.formConfig.typeLabel} <span class="text-terracotta">*</span></label>
              <select id="type" name="type" required aria-required="true" class="select-chevron block w-full px-4 py-3 font-sans text-base text-charcoal bg-cream border border-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]">
                {data.formConfig.typeOptions.map((opt) => (
                  <option value={opt.value} selected={opt.selected || undefined}>{opt.label}</option>
                ))}
              </select>
            </div>

            <div class="group">
              <label for="ville" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-200 group-focus-within:text-terracotta">{t('auditForm.city', locale)} <span class="text-terracotta">*</span></label>
              <input type="text" id="ville" name="ville" required aria-required="true" class="block w-full px-4 py-3 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]" placeholder={t('auditForm.cityPlaceholder', locale)} />
            </div>

            <div class="group">
              <label for="email" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-200 group-focus-within:text-terracotta">{t('auditForm.email', locale)} <span class="text-terracotta">*</span></label>
              <input type="email" id="email" name="email" required aria-required="true" class="block w-full px-4 py-3 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]" placeholder={t('auditForm.emailPlaceholder', locale)} />
            </div>

            <!-- Exclusivity signal -->
            <p class="text-center text-xs font-sans text-stone/80 px-4 py-3 bg-sand border border-warmgray/30">
              {t('auditForm.exclusivity', locale)}
            </p>

            <div id="form-error" class="hidden px-4 py-3 form-error-box font-sans text-sm" role="alert" aria-live="assertive">
              {t('auditForm.errorGeneric', locale)}
            </div>

            <button id="submit-btn" type="submit" class="block w-full px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed">
              {data.ctaText}
            </button>
          </form>

          <p class="text-center text-sm font-sans font-medium text-stone mt-6 fade-up">
            {t('auditForm.trustSignals', locale)}
          </p>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  import { initFormSubmit } from '../utils/form-submit';
  initFormSubmit(import.meta.env.PUBLIC_WEBHOOK_URL);
</script>

<!-- Counter animation for stat cards -->
<script>
  import { initCounterObserver } from '../scripts/counter-animation';
  initCounterObserver();
</script>
