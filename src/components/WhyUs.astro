---
// WhyUs section — Competitive comparison table
const rows = [
  { criteria: 'Focus', classic: 'Google Search (liens bleus)', ema: 'Google + ChatGPT + Gemini + Perplexity' },
  { criteria: 'Spécialisation', classic: 'Tous secteurs, toutes villes', ema: 'Santé et commerces locaux à Paris' },
  { criteria: 'Livrable', classic: 'Audit SEO générique, backlinks', ema: 'Score de visibilité IA /100, optimisations GEO concrètes' },
  { criteria: 'Engagement', classic: 'Contrat 6-12 mois, 500-2 000 €/mois', ema: 'One-shot à partir de 490 €, premiers signaux sous 4 à 8 semaines' },
  { criteria: 'Preuve', classic: '« Vos positions ont bougé »', ema: 'Tapez la requête dans ChatGPT → votre cabinet apparaît' },
];
---
<section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Pourquoi nous choisir">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-in">
      Pourquoi nous et pas une agence SEO&nbsp;?
    </h2>

    <!-- Desktop table -->
    <div class="hidden md:block max-w-4xl mx-auto fade-in">
      <table class="w-full">
        <thead>
          <tr>
            <th class="text-left pb-4 pr-6 text-sm font-sans font-medium text-stone/70 tracking-[0.1em] uppercase border-b-2 border-warmgray/30"></th>
            <th class="text-left pb-4 px-6 text-sm font-sans font-medium text-stone/70 tracking-[0.1em] uppercase border-b-2 border-warmgray/30">Agence SEO classique</th>
            <th class="text-left pb-4 pl-6 text-sm font-sans font-medium text-terracotta tracking-[0.1em] uppercase border-b-2 border-terracotta/30">Eddie Miller Agency</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class="border-b border-warmgray/20">
              <td class="py-4 pr-6 text-sm font-sans font-medium text-charcoal">{row.criteria}</td>
              <td class="py-4 px-6 text-sm font-sans text-stone">{row.classic}</td>
              <td class="py-4 pl-6 text-sm font-sans font-medium text-charcoal">{row.ema}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Mobile cards -->
    <div class="md:hidden space-y-6 fade-in">
      {rows.map((row) => (
        <div class="border border-warmgray/30 bg-cream p-5">
          <p class="text-xs font-sans font-medium text-stone/70 tracking-[0.1em] uppercase mb-3">{row.criteria}</p>
          <div class="space-y-3">
            <div>
              <p class="text-xs font-sans text-warmgray mb-1">Agence SEO classique</p>
              <p class="text-sm font-sans text-stone">{row.classic}</p>
            </div>
            <div class="border-t border-warmgray/20 pt-3">
              <p class="text-xs font-sans text-terracotta mb-1">Eddie Miller Agency</p>
              <p class="text-sm font-sans font-medium text-charcoal">{row.ema}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
