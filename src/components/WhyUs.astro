---
// WhyUs section — Premium numbered cards with urgency
import { t, getLocaleFromPath, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);

const reasons = [
  {
    number: '01',
    title: "Les premiers visibles gardent l'avantage",
    description: "Les IA fonctionnent par habitude : une fois qu'elles recommandent une entreprise, elles continuent. Se positionner tôt, c'est prendre une avance durable.",
  },
  {
    number: '02',
    title: "Vos concurrents n'y sont pas encore",
    description: "La plupart des entreprises locales n'ont aucune idée que ChatGPT influence déjà leurs clients. C'est une fenêtre d'opportunité qui ne restera pas ouverte longtemps.",
  },
  {
    number: '03',
    title: "Chaque jour sans visibilité, ce sont des clients perdus",
    description: "En ce moment même, de potentiels clients vous cherchent. Si l'IA ne vous connaît pas, elle envoie ce client ailleurs. C'est aussi simple que ça.",
  },
];
---
<section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Pourquoi agir maintenant">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-up-slow">
      {t('whyUs.title', locale)}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 max-w-4xl mx-auto">
      {reasons.map((reason, i) => (
        <div class="border border-warmgray p-8 bg-cream card-hover scale-in">
          <p class="text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray/25 mb-4" aria-hidden="true">
            {reason.number}
          </p>
          <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">
            {reason.title}
          </h3>
          <p class="text-base font-sans font-normal leading-relaxed text-stone">
            {reason.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
