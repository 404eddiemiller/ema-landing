---
// WhyUs section — "Pourquoi agir maintenant" — urgency benefits
const reasons = [
  {
    title: "L'IA ne montre que 3 à 5 résultats",
    description: "Pas 10 liens comme Google. Si vous n'êtes pas dans les 5 premiers, vous êtes invisible.",
  },
  {
    title: 'Les premiers positionnés gardent leur avantage',
    description: "Une fois recommandé par ChatGPT, vous restez en tête. Les retardataires auront beaucoup plus de mal à vous déloger.",
  },
  {
    title: "Vos concurrents n'ont pas encore commencé",
    description: "La plupart des commerces locaux ignorent encore que ChatGPT influence leurs clients. C'est le bon moment pour prendre de l'avance.",
  },
];
---
<section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Pourquoi agir maintenant">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-in">
      Pourquoi agir maintenant
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 max-w-4xl mx-auto">
      {reasons.map((reason) => (
        <div class="border border-warmgray p-8 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
          <h3 class="text-xl md:text-[1.35rem] font-serif font-normal leading-[1.2] text-charcoal mb-3">
            {reason.title}
          </h3>
          <p class="text-base font-sans font-normal leading-relaxed text-stone">
            {reason.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
