---
// WhatYouGet section — What the free audit delivers (tangible, no jargon)
const deliverables = [
  {
    title: 'Votre score de visibilité',
    description: "On teste si ChatGPT, Google et les autres IA vous recommandent. Vous recevez une note claire sur 100.",
  },
  {
    title: 'Ce qui bloque vos clients',
    description: "On identifie précisément ce qui empêche les IA et Google de vous montrer quand un client cherche dans votre quartier.",
  },
  {
    title: '3 actions concrètes à faire en premier',
    description: "Pas une liste de 50 tâches. Les 3 corrections qui auront le plus d'impact sur votre nombre de clients.",
  },
  {
    title: 'Un appel de 15 minutes pour en parler',
    description: "On vous explique vos résultats de vive voix, on répond à vos questions, et on voit ensemble si on peut vous aider.",
  },
];
---
<section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Ce que vous recevez">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-in">
        Ce que vous recevez en&nbsp;24h
      </h2>
      <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-14 fade-in">
        Un vrai diagnostic de votre établissement, pas un email automatique.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
        {deliverables.map((item) => (
          <div class="flex gap-4 fade-in">
            <div class="mt-1 shrink-0">
              <div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div>
            </div>
            <div>
              <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">
                {item.title}
              </h3>
              <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10 md:mt-12 fade-in">
        <a
          href="#audit"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark"
        >
          Tester ma visibilité gratuitement
        </a>
      </div>
    </div>
  </div>
</section>
