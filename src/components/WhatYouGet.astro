---
// WhatYouGet section — What the audit delivers (tangibility)
const deliverables = [
  {
    title: 'Score de visibilité /100',
    description: 'Votre note globale sur ChatGPT, Perplexity, Gemini et Google Maps.',
  },
  {
    title: 'Diagnostic par plateforme',
    description: 'Où vous apparaissez, où vous êtes absent, et ce qui empêche ChatGPT de vous recommander.',
  },
  {
    title: '3 actions prioritaires',
    description: 'Les corrections classées par impact : ce qui fera bouger votre score le plus vite.',
  },
  {
    title: 'Appel de restitution',
    description: '15 minutes pour parcourir vos résultats, répondre à vos questions et définir la suite.',
  },
];
---
<section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Ce que vous recevez">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-in">
        Ce que vous recevez en&nbsp;48h
      </h2>
      <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-14 fade-in">
        Un audit complet, pas un simple email. Voici ce que contient votre rapport gratuit.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
        {deliverables.map((item) => (
          <div class="flex gap-4 fade-in">
            <div class="mt-1 shrink-0">
              <div class="w-2 h-2 bg-terracotta" aria-hidden="true"></div>
            </div>
            <div>
              <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">
                {item.title}
              </h3>
              <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10 md:mt-12 fade-in">
        <a
          href="#audit"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark"
        >
          Demander mon audit gratuit
        </a>
      </div>
    </div>
  </div>
</section>
