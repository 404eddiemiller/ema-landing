---
// WhatYouGet section — What the free audit delivers with staggered animations
import { t, getLocaleFromPath, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);
const deliverables = [
  { title: t('whatYouGet.item1Title', locale), description: t('whatYouGet.item1Text', locale), icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>' },
  { title: t('whatYouGet.item2Title', locale), description: t('whatYouGet.item2Text', locale), icon: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>' },
  { title: t('whatYouGet.item3Title', locale), description: t('whatYouGet.item3Text', locale), icon: '<path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/>' },
  { title: t('whatYouGet.item4Title', locale), description: t('whatYouGet.item4Text', locale), icon: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>' },
];
---
<section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Ce que vous recevez">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="section-title mb-4 fade-up-slow">
        <Fragment set:html={t('whatYouGet.title', locale)} />
      </h2>
      <p class="section-subtitle mb-12 md:mb-14 fade-up">
        {t('whatYouGet.subtitle', locale)}
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
        {deliverables.map((item, i) => (
          <div class="flex gap-4 scale-in">
            <div class="mt-1 shrink-0">
              <svg class="w-5 h-5 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
            </div>
            <div>
              <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">
                {item.title}
              </h3>
              <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
