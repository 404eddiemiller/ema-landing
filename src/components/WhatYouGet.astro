---
// WhatYouGet section — What the free audit delivers with staggered animations
import { t, getLocaleFromPath, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);
const deliverables = [
  {
    title: 'Votre score de visibilité IA',
    description: "On interroge ChatGPT, Claude, Gemini et Perplexity sur votre entreprise : 100 requêtes réelles. Votre score = le nombre de fois où vous êtes recommandé. Simple, concret, mesurable.",
    icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
  },
  {
    title: 'Ce qui bloque vos clients',
    description: "On identifie précisément ce qui empêche les IA et Google de vous montrer quand un client cherche dans votre ville et dans votre quartier.",
    icon: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>',
  },
  {
    title: '3 actions concrètes à faire en premier',
    description: "Les 3 corrections qui auront le plus d'impact pour augmenter votre nombre de clients.",
    icon: '<path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/>',
  },
  {
    title: 'Un appel de 15 minutes pour en parler',
    description: "On vous explique vos résultats de vive voix, on répond à vos questions, et on voit ensemble comment on peut vous aider.",
    icon: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
  },
];
---
<section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Ce que vous recevez">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
        <Fragment set:html={t('whatYouGet.title', locale)} />
      </h2>
      <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-14 fade-up">
        {t('whatYouGet.subtitle', locale)}
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
        {deliverables.map((item, i) => (
          <div class="flex gap-4 scale-in">
            <div class="mt-1 shrink-0">
              <svg class="w-5 h-5 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
            </div>
            <div>
              <h3 class="font-sans font-medium text-base md:text-lg text-charcoal mb-1">
                {item.title}
              </h3>
              <p class="text-sm md:text-base font-sans font-normal leading-relaxed text-stone">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10 md:mt-12 fade-up">
        <a
          href="#diagnostic"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark"
          onclick="plausible('CTA Click', {props: {location: 'what-you-get'}})"
        >
          Demander mon diagnostic gratuit
        </a>
      </div>
    </div>
  </div>
</section>
