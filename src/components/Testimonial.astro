---
// Testimonial section — Client result showcase
---
<section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Résultat client">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-in">
      Résultats concrets
    </h2>

    <div class="max-w-3xl mx-auto">
      <!-- Before/After card -->
      <div class="border border-warmgray bg-cream p-8 md:p-12 fade-in">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 mb-8">
          <!-- Before -->
          <div class="text-center md:text-left">
            <p class="text-sm font-sans font-medium text-stone/60 tracking-[0.1em] uppercase mb-3">Avant</p>
            <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-warmgray">0<span class="text-[1.5rem]">/100</span></p>
            <p class="mt-2 text-base font-sans font-normal leading-relaxed text-stone">Score de visibilité IA</p>
            <p class="text-sm font-sans text-stone/60 mt-1">Aucune mention sur ChatGPT, Perplexity ou Gemini</p>
          </div>
          <!-- After -->
          <div class="text-center md:text-left">
            <p class="text-sm font-sans font-medium text-terracotta tracking-[0.1em] uppercase mb-3">Après 8 semaines</p>
            <p class="text-[2.5rem] md:text-[3rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta">54<span class="text-[1.5rem]">/100</span></p>
            <p class="mt-2 text-base font-sans font-normal leading-relaxed text-stone">Score de visibilité IA</p>
            <p class="text-sm font-sans text-stone/60 mt-1">3 mentions IA confirmées, +40% de trafic</p>
          </div>
        </div>

        <!-- Divider -->
        <div class="w-full h-px bg-warmgray/30 mb-8" aria-hidden="true"></div>

        <!-- Testimonial quote -->
        <blockquote>
          <p class="text-lg md:text-xl font-sans font-normal leading-relaxed text-stone italic">
            «&nbsp;En deux mois, notre cabinet est passé de zéro mention à trois recommandations sur ChatGPT et Perplexity. Nous recevons maintenant des appels de patients qui disent avoir trouvé notre cabinet grâce à l'IA.&nbsp;»
          </p>
          <footer class="mt-4">
            <p class="font-sans font-medium text-base text-charcoal">Dr. Sophie M.</p>
            <p class="font-sans text-sm text-stone">Cabinet dentaire — Paris 16e</p>
          </footer>
        </blockquote>
      </div>
    </div>
  </div>
</section>
