---
// Header component — Logo + nav + CTA
---
<header class="fixed top-0 left-0 w-full z-50 bg-cream/95 backdrop-blur-sm">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:px-4 focus:py-2 focus:bg-terracotta focus:text-cream focus:font-sans focus:font-medium focus:text-sm">
    Aller au contenu principal
  </a>
  <div class="flex items-center justify-between max-w-container mx-auto px-6 md:px-8 lg:px-16 py-4">
    <a href="/" class="font-serif text-base md:text-xl text-charcoal tracking-tight leading-tight shrink-0" aria-label="Eddie Miller Agency — Accueil">
      Eddie Miller Agency
    </a>
    <nav class="flex items-center gap-4 md:gap-6" aria-label="Navigation principale">
      <a
        href="/blog"
        class="hidden md:inline-block font-sans font-medium text-xs md:text-[0.9375rem] text-stone tracking-wide transition-colors duration-200 hover:text-charcoal"
      >
        Blog
      </a>
      <a
        href="/formules"
        class="hidden md:inline-block font-sans font-medium text-xs md:text-[0.9375rem] text-stone tracking-wide transition-colors duration-200 hover:text-charcoal"
      >
        Nos formules
      </a>
      <a
        href="/#audit"
        class="inline-block shrink-0 px-4 py-2.5 md:px-6 md:py-3 font-sans font-medium text-xs md:text-[0.9375rem] text-cream bg-terracotta tracking-wider uppercase whitespace-nowrap transition-colors duration-300 hover:bg-terracotta-dark"
      >
        Test gratuit
      </a>
    </nav>
  </div>
  <div class="h-px bg-warmgray opacity-50"></div>
</header>
