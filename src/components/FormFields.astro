---
// Shared form fields for AuditForm and VerticalLayout
// Centralizes: honeypot, 4 fields, error display, submit button with spinner

interface TypeOption {
  value: string;
  label: string;
  selected?: boolean;
  disabled?: boolean;
}

interface Props {
  etablissementLabel: string;
  etablissementPlaceholder: string;
  typeLabel: string;
  typeOptions: TypeOption[];
  cityLabel: string;
  cityPlaceholder: string;
  emailLabel: string;
  emailPlaceholder: string;
  submitText: string;
  errorGeneric: string;
  fieldRequired: string;
  emailInvalid: string;
  submitting: string;
  redirect: string;
  pageSlug?: string;
  exclusivityText?: string;
}

const {
  etablissementLabel,
  etablissementPlaceholder,
  typeLabel,
  typeOptions,
  cityLabel,
  cityPlaceholder,
  emailLabel,
  emailPlaceholder,
  submitText,
  errorGeneric,
  fieldRequired,
  emailInvalid,
  submitting,
  redirect,
  pageSlug,
  exclusivityText,
} = Astro.props;
---

<form id="audit-form" class="space-y-6 fade-up" novalidate
  data-error-generic={errorGeneric}
  data-submitting={submitting}
  data-submit-text={submitText}
  data-redirect={redirect}
  data-field-required={fieldRequired}
  data-email-invalid={emailInvalid}
  data-page-slug={pageSlug}
>
  <!-- Anti-spam: honeypot + timestamp + JS challenge -->
  <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
  <input type="hidden" name="_loaded" value="" />
  <input type="hidden" name="_js" value="" />

  <div class="group">
    <label for="etablissement" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
      {etablissementLabel} <span class="text-terracotta">*</span>
    </label>
    <input
      type="text"
      id="etablissement"
      name="etablissement"
      required
      aria-required="true"
      aria-describedby="etablissement-error"
      class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
      placeholder={etablissementPlaceholder}
    />
    <p id="etablissement-error" class="field-error hidden text-red-500 text-xs font-sans mt-1" role="alert"></p>
  </div>

  <div class="group">
    <label for="type" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
      {typeLabel} <span class="text-terracotta">*</span>
    </label>
    <select
      id="type"
      name="type"
      required
      aria-required="true"
      aria-describedby="type-error"
      class="select-chevron block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
    >
      {typeOptions.map((opt) => (
        <option value={opt.value} selected={opt.selected || undefined} disabled={opt.disabled || undefined}>{opt.label}</option>
      ))}
    </select>
    <p id="type-error" class="field-error hidden text-red-500 text-xs font-sans mt-1" role="alert"></p>
  </div>

  <div class="group">
    <label for="ville" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
      {cityLabel} <span class="text-terracotta">*</span>
    </label>
    <input
      type="text"
      id="ville"
      name="ville"
      required
      aria-required="true"
      aria-describedby="ville-error"
      class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
      placeholder={cityPlaceholder}
    />
    <p id="ville-error" class="field-error hidden text-red-500 text-xs font-sans mt-1" role="alert"></p>
  </div>

  <div class="group">
    <label for="email" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
      {emailLabel} <span class="text-terracotta">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      aria-required="true"
      aria-describedby="email-error"
      class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
      placeholder={emailPlaceholder}
    />
    <p id="email-error" class="field-error hidden text-red-500 text-xs font-sans mt-1" role="alert"></p>
  </div>

  {exclusivityText && (
    <p class="text-center text-xs font-sans text-stone/80 px-4 py-3 bg-sand border border-warmgray/30">
      {exclusivityText}
    </p>
  )}

  <!-- Error message -->
  <div id="form-error" class="hidden px-4 py-3 form-error-box font-sans text-sm" role="alert" aria-live="assertive" tabindex="-1">
    {errorGeneric}
  </div>

  <button
    type="submit"
    id="submit-btn"
    class="btn-primary flex items-center justify-center gap-2 w-full cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed"
  >
    <svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
    <span id="submit-text">{submitText}</span>
  </button>
</form>
