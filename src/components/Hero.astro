---
// Hero section — Apple-inspired text reveal + decorative elements
import { t, getLocaleFromPath, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);
---
<section class="relative pt-32 pb-16 md:pt-40 md:pb-24 lg:pt-48 lg:pb-32 bg-cream overflow-hidden" aria-label="Accroche principale">
  <!-- Subtle decorative grain texture -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>

  <!-- Decorative terracotta accent line -->
  <div class="absolute top-[45%] right-0 w-[30%] hidden lg:block" aria-hidden="true">
    <svg viewBox="0 0 400 2" class="w-full draw-line" style="--line-length: 400;">
      <line x1="0" y1="1" x2="400" y2="1" stroke="#C4785B" stroke-width="1" opacity="0.3" />
    </svg>
  </div>

  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16 relative">
    <div class="max-w-3xl">
      <!-- Text reveal headline -->
      <h1 class="text-[2.5rem] md:text-[3.25rem] lg:text-[4rem] font-serif font-normal leading-[1.1] tracking-[-0.02em] text-charcoal" set:html={t('hero.title', locale)}>
      </h1>

      <!-- Animated terracotta accent under title -->
      <div class="mt-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>

      <p class="mt-6 md:mt-8 max-w-[65ch] text-lg md:text-xl font-sans font-normal leading-relaxed text-stone blur-in">
        {t('hero.subtitle', locale)}
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-4 mt-8 md:mt-10 fade-up">
        <a
          href="#diagnostic"
          class="inline-block px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark"
          onclick="plausible('CTA Click', {props: {location: 'hero'}})"
        >
          {t('hero.cta', locale)}
        </a>
        <a
          href="#diagnostic"
          class="inline-flex items-center gap-1 px-2 py-4 font-sans font-medium text-base text-stone transition-colors duration-200 hover:text-charcoal group"
        >
          {t('hero.secondary', locale)}
        </a>
      </div>

      <!-- Reassurance bar -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 mt-6 md:mt-8 fade-up">
        <span class="text-sm font-sans text-stone/80">&#10003; {t('hero.trust1', locale)}</span>
        <span class="text-sm font-sans text-stone/80">&#10003; {t('hero.trust2', locale)}</span>
        <span class="text-sm font-sans text-stone/80">&#10003; {t('hero.trust3', locale)}</span>
      </div>
    </div>
  </div>
</section>
