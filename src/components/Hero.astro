---
// Hero section — Apple-inspired text reveal + decorative elements
import { t, getLocaleFromPath, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);
---
<section class="relative pt-32 pb-16 md:pt-40 md:pb-24 lg:pt-48 lg:pb-32 bg-cream overflow-hidden" aria-label="Accroche principale">
  <!-- Subtle decorative grain texture -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('/grain.svg');"></div>

  <!-- Decorative terracotta accent line -->
  <div class="absolute top-[45%] right-0 w-[30%] hidden lg:block" aria-hidden="true">
    <svg viewBox="0 0 400 2" class="w-full draw-line" style="--line-length: 400;">
      <line x1="0" y1="1" x2="400" y2="1" stroke="#C4785B" stroke-width="1" opacity="0.3" />
    </svg>
  </div>

  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16 relative">
    <div class="max-w-3xl">
      <!-- Text reveal headline -->
      <h1 class="font-serif font-normal tracking-[-0.02em] text-charcoal">
        <span class="block text-[2.5rem] md:text-[3.25rem] lg:text-[4rem] leading-[1.1]">
          {t('hero.title', locale)}
        </span>
        <span class="block text-[1.75rem] md:text-[2.25rem] lg:text-[2.75rem] leading-[1.2] mt-3 text-stone">
          {t('hero.titleLine2', locale)} <em class="not-italic font-serif text-terracotta hero-typewriter" data-text={t('hero.titleHighlight', locale)}>&nbsp;</em>
        </span>
      </h1>

      <!-- Animated terracotta accent under title -->
      <div class="mt-6 separator-animate h-[2px] bg-terracotta" aria-hidden="true"></div>

      <p class="mt-6 md:mt-8 max-w-[65ch] text-lg md:text-xl font-sans font-normal leading-relaxed text-stone blur-in">
        {t('hero.subtitle', locale)}
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-4 mt-8 md:mt-10 fade-up">
        <a
          href="#diagnostic"
          class="btn-primary"
          data-track="hero"
        >
          {t('hero.cta', locale)}
        </a>
        <a
          href="#diagnostic"
          class="inline-flex items-center gap-1 px-2 py-4 font-sans font-medium text-base text-stone transition-colors duration-200 hover:text-charcoal group"
        >
          {t('hero.secondary', locale)}
        </a>
      </div>

      <!-- Reassurance bar -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 mt-6 md:mt-8 fade-up">
        <span class="text-sm font-sans text-stone/80">&#10003; {t('hero.trust1', locale)}</span>
        <span class="text-sm font-sans text-stone/80">&#10003; {t('hero.trust2', locale)}</span>
        <span class="text-sm font-sans text-stone/80">&#10003; {t('hero.trust3', locale)}</span>
        <span class="text-sm font-sans text-stone/80">&#10003; {t('hero.trust4', locale)}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-typewriter {
    font-style: italic;
    border-right: 2px solid var(--color-terracotta);
    padding-right: 2px;
  }
  .hero-typewriter.done {
    border-right-color: transparent;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-typewriter {
      border-right: none;
      padding-right: 0;
    }
  }
</style>

<script>
  function initTypewriter() {
    const el = document.querySelector<HTMLElement>('.hero-typewriter');
    if (!el) return;
    const text = el.dataset.text || '';
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReduced) {
      el.textContent = text;
      el.classList.add('done');
      return;
    }

    el.textContent = '';
    let i = 0;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          observer.unobserve(entry.target);
          setTimeout(() => {
            const interval = setInterval(() => {
              if (i < text.length) {
                el.textContent = text.slice(0, i + 1);
                i++;
              } else {
                clearInterval(interval);
                setTimeout(() => el.classList.add('done'), 600);
              }
            }, 120);
          }, 800);
        }
      });
    }, { threshold: 0.3 });

    observer.observe(el);
  }

  initTypewriter();
  document.addEventListener('astro:after-swap', initTypewriter);
</script>
