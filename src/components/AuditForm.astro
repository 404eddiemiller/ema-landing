---
// AuditForm section — Submits to n8n webhook
import { t, getLocaleFromPath, navRoutes, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);
const nav = navRoutes[locale];
---
<section id="audit" class="py-16 md:py-24 lg:py-32 bg-sand relative overflow-hidden" aria-label="Tester ma visibilité">
  <!-- Decorative accent -->
  <div class="absolute top-0 left-0 w-24 h-24 md:w-40 md:h-40 opacity-[0.03] pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 100 100" class="w-full h-full">
      <circle cx="0" cy="0" r="80" fill="none" stroke="#C4785B" stroke-width="0.5"/>
      <circle cx="0" cy="0" r="60" fill="none" stroke="#C4785B" stroke-width="0.5"/>
    </svg>
  </div>

  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16 relative">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
        {t('auditForm.title', locale)}
      </h2>
      <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-10 md:mb-12 fade-up">
        {t('auditForm.subtitle', locale)}
      </p>

      <form id="audit-form" class="space-y-6 fade-up" style="transition-delay: 0.2s;" novalidate
        data-error-source={t('auditForm.errorSource', locale)}
        data-error-generic={t('auditForm.errorGeneric', locale)}
        data-submitting={t('auditForm.submitting', locale)}
        data-submit-text={t('auditForm.submitButton', locale)}
        data-redirect={nav.thankYou}
      >
        <!-- Honeypot anti-spam -->
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="group">
          <label for="etablissement" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.businessName', locale)} <span class="text-terracotta">*</span>
          </label>
          <input
            type="text"
            id="etablissement"
            name="etablissement"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.businessNamePlaceholder', locale)}
          />
        </div>

        <div class="group">
          <label for="responsable" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.managerName', locale)} <span class="text-warmgray font-normal">({t('auditForm.optional', locale)})</span>
          </label>
          <input
            type="text"
            id="responsable"
            name="responsable"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.managerNamePlaceholder', locale)}
          />
        </div>

        <div class="group">
          <label for="type" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.businessType', locale)} <span class="text-terracotta">*</span>
          </label>
          <select
            id="type"
            name="type"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)] appearance-none"
            style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2216%22 height=%2216%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%236B6360%22 stroke-width=%221.5%22%3E%3Cpath d=%22M6 9l6 6 6-6%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 1rem center;"
          >
            <option value="" disabled selected>{t('auditForm.choosePlaceholder', locale)}</option>
            <option value="dentiste">{t('auditForm.typeDentist', locale)}</option>
            <option value="medical">{t('auditForm.typeMedical', locale)}</option>
            <option value="avocat">{t('auditForm.typeLawyer', locale)}</option>
            <option value="restaurant">{t('auditForm.typeRestaurant', locale)}</option>
            <option value="hotel">{t('auditForm.typeHotel', locale)}</option>
            <option value="coiffure">{t('auditForm.typeHair', locale)}</option>
            <option value="spa">{t('auditForm.typeSpa', locale)}</option>
            <option value="sport">{t('auditForm.typeGym', locale)}</option>
            <option value="bar">{t('auditForm.typeBar', locale)}</option>
            <option value="autre">{t('auditForm.typeOther', locale)}</option>
          </select>
        </div>

        <div class="group">
          <label for="adresse" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.address', locale)} <span class="text-warmgray font-normal">({t('auditForm.optional', locale)})</span>
          </label>
          <input
            type="text"
            id="adresse"
            name="adresse"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.addressPlaceholder', locale)}
          />
        </div>

        <div class="group">
          <label for="email" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.email', locale)} <span class="text-terracotta">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.emailPlaceholder', locale)}
          />
        </div>

        <div class="group">
          <label for="telephone" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.phone', locale)} <span class="text-warmgray font-normal">({t('auditForm.optional', locale)})</span>
          </label>
          <input
            type="tel"
            id="telephone"
            name="telephone"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.phonePlaceholder', locale)}
          />
        </div>

        <div class="group">
          <label for="site_web" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.website', locale)} <span class="text-warmgray font-normal">({t('auditForm.optional', locale)})</span>
          </label>
          <input
            type="url"
            id="site_web"
            name="site_web"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.websitePlaceholder', locale)}
          />
        </div>

        <div class="group">
          <label for="google_business" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.googleBusiness', locale)} <span class="text-warmgray font-normal">({t('auditForm.optional', locale)})</span>
          </label>
          <input
            type="url"
            id="google_business"
            name="google_business"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.googleBusinessPlaceholder', locale)}
          />
        </div>

        <fieldset class="group">
          <legend class="block text-sm font-sans font-medium text-charcoal mb-3">
            {t('auditForm.sourceQuestion', locale)} <span class="text-terracotta">*</span>
          </legend>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <label class="flex items-center gap-3 px-4 py-3 bg-cream border border-warmgray cursor-pointer transition-all duration-300 hover:border-terracotta has-[:checked]:border-terracotta has-[:checked]:bg-[#F9F4EF]">
              <input type="checkbox" name="source" value="recommandation" class="w-4 h-4 accent-terracotta" />
              <span class="font-sans text-sm text-charcoal">{t('auditForm.sourceRecommendation', locale)}</span>
            </label>
            <label class="flex items-center gap-3 px-4 py-3 bg-cream border border-warmgray cursor-pointer transition-all duration-300 hover:border-terracotta has-[:checked]:border-terracotta has-[:checked]:bg-[#F9F4EF]">
              <input type="checkbox" name="source" value="email" class="w-4 h-4 accent-terracotta" />
              <span class="font-sans text-sm text-charcoal">{t('auditForm.sourceEmail', locale)}</span>
            </label>
            <label class="flex items-center gap-3 px-4 py-3 bg-cream border border-warmgray cursor-pointer transition-all duration-300 hover:border-terracotta has-[:checked]:border-terracotta has-[:checked]:bg-[#F9F4EF]">
              <input type="checkbox" name="source" value="reseaux-sociaux" class="w-4 h-4 accent-terracotta" />
              <span class="font-sans text-sm text-charcoal">{t('auditForm.sourceSocial', locale)}</span>
            </label>
            <label class="flex items-center gap-3 px-4 py-3 bg-cream border border-warmgray cursor-pointer transition-all duration-300 hover:border-terracotta has-[:checked]:border-terracotta has-[:checked]:bg-[#F9F4EF]">
              <input type="checkbox" name="source" value="recherche-google" class="w-4 h-4 accent-terracotta" />
              <span class="font-sans text-sm text-charcoal">{t('auditForm.sourceGoogle', locale)}</span>
            </label>
            <label class="flex items-center gap-3 px-4 py-3 bg-cream border border-warmgray cursor-pointer transition-all duration-300 hover:border-terracotta has-[:checked]:border-terracotta has-[:checked]:bg-[#F9F4EF]">
              <input type="checkbox" name="source" value="recherche-ia" class="w-4 h-4 accent-terracotta" />
              <span class="font-sans text-sm text-charcoal">{t('auditForm.sourceAI', locale)}</span>
            </label>
            <label class="flex items-center gap-3 px-4 py-3 bg-cream border border-warmgray cursor-pointer transition-all duration-300 hover:border-terracotta has-[:checked]:border-terracotta has-[:checked]:bg-[#F9F4EF]">
              <input type="checkbox" name="source" value="autre" class="w-4 h-4 accent-terracotta" />
              <span class="font-sans text-sm text-charcoal">{t('auditForm.sourceOther', locale)}</span>
            </label>
          </div>
        </fieldset>

        <!-- Error message -->
        <div id="form-error" class="hidden px-4 py-3 bg-red-50 border border-red-200 text-red-700 font-sans text-sm" role="alert">
          {t('auditForm.errorGeneric', locale)}
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="block w-full px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed"
        >
          {t('auditForm.submitButton', locale)}
        </button>
      </form>

      <!-- Trust signals -->
      <p class="text-center text-sm font-sans font-medium text-stone mt-6 fade-up" style="transition-delay: 0.4s;">
        {t('auditForm.trustSignals', locale)}
      </p>
    </div>
  </div>
</section>

<script>
  // n8n webhook URL — replace with your actual n8n webhook URL
  const WEBHOOK_URL = '__N8N_WEBHOOK_URL__';

  const form = document.getElementById('audit-form');
  const submitBtn = document.getElementById('submit-btn');
  const errorDiv = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot check
    const honey = form.querySelector('input[name="_honey"]');
    if (honey && honey.value) return;

    // Basic validation
    const etablissement = form.querySelector('#etablissement');
    const email = form.querySelector('#email');
    const type = form.querySelector('#type');
    const sources = form.querySelectorAll('input[name="source"]:checked');

    if (!etablissement?.value || !email?.value || !type?.value || sources.length === 0) {
      // Let browser handle native validation for required fields
      // For checkboxes, show custom message
      if (sources.length === 0) {
        errorDiv.textContent = form.dataset.errorSource || 'Veuillez indiquer comment vous nous avez connu.';
        errorDiv.classList.remove('hidden');
      }
      form.reportValidity();
      return;
    }

    // Collect form data
    const data = {
      etablissement: etablissement.value,
      responsable: form.querySelector('#responsable')?.value || '',
      type: type.value,
      adresse: form.querySelector('#adresse')?.value || '',
      email: email.value,
      telephone: form.querySelector('#telephone')?.value || '',
      site_web: form.querySelector('#site_web')?.value || '',
      google_business: form.querySelector('#google_business')?.value || '',
      source: Array.from(sources).map(s => s.value),
      page: 'homepage',
      submitted_at: new Date().toISOString()
    };

    // UI: loading state
    submitBtn.disabled = true;
    submitBtn.textContent = form.dataset.submitting || 'Envoi en cours…';
    errorDiv.classList.add('hidden');

    try {
      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (!response.ok) throw new Error('Erreur serveur');

      // Track with Plausible
      if (typeof plausible !== 'undefined') {
        plausible('Form Submit');
      }

      // Redirect to thank you page (locale-aware)
      window.location.href = form.dataset.redirect || '/merci';
    } catch (err) {
      errorDiv.textContent = form.dataset.errorGeneric || 'Une erreur est survenue. Veuillez réessayer ou nous contacter à contact@eddiemiller.agency.';
      errorDiv.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = form.dataset.submitText || 'Demander mon diagnostic gratuit';
    }
  });
</script>
