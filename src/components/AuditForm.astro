---
// AuditForm section — Premium focus states + visual polish
---
<section id="audit" class="py-16 md:py-24 lg:py-32 bg-sand relative overflow-hidden" aria-label="Tester ma visibilité">
  <!-- Decorative accent -->
  <div class="absolute top-0 left-0 w-24 h-24 md:w-40 md:h-40 opacity-[0.03] pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 100 100" class="w-full h-full">
      <circle cx="0" cy="0" r="80" fill="none" stroke="#C4785B" stroke-width="0.5"/>
      <circle cx="0" cy="0" r="60" fill="none" stroke="#C4785B" stroke-width="0.5"/>
    </svg>
  </div>

  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16 relative">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
        Votre diagnostic gratuit en&nbsp;24h
      </h2>
      <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-10 md:mb-12 fade-up">
        On vérifie gratuitement si ChatGPT et Google recommandent votre établissement. Résultat en 24h, sans engagement.
      </p>

      <form class="space-y-6 fade-up" style="transition-delay: 0.2s;" action="https://formsubmit.co/contact@eddiemiller.agency" method="POST" onsubmit="plausible('Form Submit')">
        <!-- Formsubmit.co configuration -->
        <input type="hidden" name="_next" value="https://eddiemiller.agency/merci" />
        <input type="hidden" name="_subject" value="Nouvelle demande de diagnostic — Eddie Miller Agency" />
        <input type="hidden" name="_captcha" value="true" />
        <input type="text" name="_honey" style="display:none" />

        <div class="group">
          <label for="etablissement" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            Nom de l'établissement
          </label>
          <input
            type="text"
            id="etablissement"
            name="etablissement"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder="Le Petit Cler, Cabinet Dr. Martin…"
          />
        </div>

        <div class="group">
          <label for="type" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            Type d'établissement
          </label>
          <select
            id="type"
            name="type"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)] appearance-none"
            style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2216%22 height=%2216%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%236B6360%22 stroke-width=%221.5%22%3E%3Cpath d=%22M6 9l6 6 6-6%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 1rem center;"
          >
            <option value="" disabled selected>Choisir…</option>
            <option value="dentiste">Cabinet dentaire</option>
            <option value="medical">Cabinet médical</option>
            <option value="avocat">Cabinet d'avocats</option>
            <option value="restaurant">Restaurant</option>
            <option value="hotel">Hôtel</option>
            <option value="coiffure">Coiffure / Esthétique</option>
            <option value="spa">Bien-être / Spa</option>
            <option value="sport">Salle de sport</option>
            <option value="bar">Bar / Lieu de soirée</option>
            <option value="autre">Autre</option>
          </select>
        </div>

        <div class="group">
          <label for="localisation" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            Arrondissement ou ville
          </label>
          <input
            type="text"
            id="localisation"
            name="localisation"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder="Paris 7e, Neuilly-sur-Seine…"
          />
        </div>

        <div class="group">
          <label for="email" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            Adresse email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder="vous@exemple.com"
          />
        </div>

        <div class="group">
          <label for="telephone" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            Numéro de téléphone <span class="text-warmgray font-normal">(optionnel)</span>
          </label>
          <input
            type="tel"
            id="telephone"
            name="telephone"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder="06 12 34 56 78"
          />
        </div>

        <button
          type="submit"
          class="block w-full px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark cursor-pointer"
        >
          Demander mon diagnostic gratuit
        </button>
      </form>

      <!-- Trust signals -->
      <p class="text-center text-sm font-sans font-medium text-stone mt-6 fade-up" style="transition-delay: 0.4s;">
        Diagnostic en 24h · 100&nbsp;% gratuit · Sans engagement
      </p>
    </div>
  </div>
</section>
