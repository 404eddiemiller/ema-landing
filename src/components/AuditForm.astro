---
// AuditForm section — Submits to n8n webhook
import { t, getLocaleFromPath, navRoutes, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);
const nav = navRoutes[locale];
---
<section id="diagnostic" class="py-16 md:py-24 lg:py-32 bg-cream relative overflow-hidden" aria-label="Tester ma visibilité">
  <!-- Decorative accent -->
  <div class="absolute top-0 left-0 w-24 h-24 md:w-40 md:h-40 opacity-[0.03] pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 100 100" class="w-full h-full">
      <circle cx="0" cy="0" r="80" fill="none" stroke="#C4785B" stroke-width="0.5"/>
      <circle cx="0" cy="0" r="60" fill="none" stroke="#C4785B" stroke-width="0.5"/>
    </svg>
  </div>

  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16 relative">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
        {t('auditForm.title', locale)}
      </h2>
      <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-10 md:mb-12 fade-up">
        {t('auditForm.subtitle', locale)}
      </p>

      <form id="audit-form" class="space-y-6 fade-up" novalidate
        data-error-generic={t('auditForm.errorGeneric', locale)}
        data-submitting={t('auditForm.submitting', locale)}
        data-submit-text={t('auditForm.submitButton', locale)}
        data-redirect={nav.thankYou}
        data-field-required={t('auditForm.fieldRequired', locale)}
        data-email-invalid={t('auditForm.emailInvalid', locale)}
      >
        <!-- Honeypot anti-spam -->
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="group">
          <label for="etablissement" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.businessName', locale)} <span class="text-terracotta">*</span>
          </label>
          <input
            type="text"
            id="etablissement"
            name="etablissement"
            required
            aria-required="true"
            aria-describedby="etablissement-error"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.businessNamePlaceholder', locale)}
          />
          <p id="etablissement-error" class="field-error hidden text-red-500 text-xs font-sans mt-1" role="alert"></p>
        </div>

        <div class="group">
          <label for="type" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.businessType', locale)} <span class="text-terracotta">*</span>
          </label>
          <select
            id="type"
            name="type"
            required
            aria-required="true"
            aria-describedby="type-error"
            class="select-chevron block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
          >
            <option value="" disabled selected>{t('auditForm.choosePlaceholder', locale)}</option>
            <option value="restaurant">{t('auditForm.typeRestaurant', locale)}</option>
            <option value="hotel">{t('auditForm.typeHotel', locale)}</option>
            <option value="bar">{t('auditForm.typeBar', locale)}</option>
            <option value="medical">{t('auditForm.typeMedical', locale)}</option>
            <option value="dentiste">{t('auditForm.typeDentist', locale)}</option>
            <option value="avocat">{t('auditForm.typeLawyer', locale)}</option>
            <option value="coiffure">{t('auditForm.typeHair', locale)}</option>
            <option value="spa">{t('auditForm.typeSpa', locale)}</option>
            <option value="sport">{t('auditForm.typeGym', locale)}</option>
            <option value="autre">{t('auditForm.typeOther', locale)}</option>
          </select>
          <p id="type-error" class="field-error hidden text-red-500 text-xs font-sans mt-1" role="alert"></p>
        </div>

        <div class="group">
          <label for="ville" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.city', locale)} <span class="text-terracotta">*</span>
          </label>
          <input
            type="text"
            id="ville"
            name="ville"
            required
            aria-required="true"
            aria-describedby="ville-error"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.cityPlaceholder', locale)}
          />
          <p id="ville-error" class="field-error hidden text-red-500 text-xs font-sans mt-1" role="alert"></p>
        </div>

        <div class="group">
          <label for="email" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.email', locale)} <span class="text-terracotta">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            aria-required="true"
            aria-describedby="email-error"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.emailPlaceholder', locale)}
          />
          <p id="email-error" class="field-error hidden text-red-500 text-xs font-sans mt-1" role="alert"></p>
        </div>

        <!-- Error message -->
        <div id="form-error" class="hidden px-4 py-3 form-error-box font-sans text-sm" role="alert" aria-live="assertive" tabindex="-1">
          {t('auditForm.errorGeneric', locale)}
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="flex items-center justify-center gap-2 w-full px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span id="submit-text">{t('auditForm.submitButton', locale)}</span>
        </button>
      </form>

      <!-- Trust signals -->
      <p class="text-center text-sm font-sans font-medium text-stone mt-6 fade-up">
        {t('auditForm.trustSignals', locale)}
      </p>

      <!-- Phone contact alternative -->
      <p class="text-center text-sm font-sans text-stone/80 mt-4 fade-up">
        {t('auditForm.phonePrefer', locale)}
        <a href="tel:+33612754218" class="font-medium text-terracotta transition-colors duration-200 hover:text-terracotta-dark hover-underline">
          06 12 75 42 18
        </a>
      </p>
    </div>
  </div>
</section>

<script>
  import { initFormSubmit } from '../utils/form-submit';
  initFormSubmit(import.meta.env.PUBLIC_WEBHOOK_URL);
</script>
