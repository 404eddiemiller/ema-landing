---
// AuditForm section — Submits to n8n webhook
import { t, getLocaleFromPath, navRoutes, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);
const nav = navRoutes[locale];
---
<section id="diagnostic" class="py-16 md:py-24 lg:py-32 bg-sand relative overflow-hidden" aria-label="Tester ma visibilité">
  <!-- Decorative accent -->
  <div class="absolute top-0 left-0 w-24 h-24 md:w-40 md:h-40 opacity-[0.03] pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 100 100" class="w-full h-full">
      <circle cx="0" cy="0" r="80" fill="none" stroke="#C4785B" stroke-width="0.5"/>
      <circle cx="0" cy="0" r="60" fill="none" stroke="#C4785B" stroke-width="0.5"/>
    </svg>
  </div>

  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16 relative">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-up-slow">
        {t('auditForm.title', locale)}
      </h2>
      <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-10 md:mb-12 fade-up">
        {t('auditForm.subtitle', locale)}
      </p>

      <form id="audit-form" class="space-y-6 fade-up" novalidate
        data-error-source={t('auditForm.errorSource', locale)}
        data-error-generic={t('auditForm.errorGeneric', locale)}
        data-submitting={t('auditForm.submitting', locale)}
        data-submit-text={t('auditForm.submitButton', locale)}
        data-redirect={nav.thankYou}
      >
        <!-- Honeypot anti-spam -->
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="group">
          <label for="etablissement" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.businessName', locale)} <span class="text-terracotta">*</span>
          </label>
          <input
            type="text"
            id="etablissement"
            name="etablissement"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.businessNamePlaceholder', locale)}
          />
        </div>

        <div class="group">
          <label for="type" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.businessType', locale)} <span class="text-terracotta">*</span>
          </label>
          <select
            id="type"
            name="type"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)] appearance-none"
            style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2216%22 height=%2216%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%236B6360%22 stroke-width=%221.5%22%3E%3Cpath d=%22M6 9l6 6 6-6%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 1rem center;"
          >
            <option value="" disabled selected>{t('auditForm.choosePlaceholder', locale)}</option>
            <option value="dentiste">{t('auditForm.typeDentist', locale)}</option>
            <option value="medical">{t('auditForm.typeMedical', locale)}</option>
            <option value="avocat">{t('auditForm.typeLawyer', locale)}</option>
            <option value="restaurant">{t('auditForm.typeRestaurant', locale)}</option>
            <option value="hotel">{t('auditForm.typeHotel', locale)}</option>
            <option value="coiffure">{t('auditForm.typeHair', locale)}</option>
            <option value="spa">{t('auditForm.typeSpa', locale)}</option>
            <option value="sport">{t('auditForm.typeGym', locale)}</option>
            <option value="bar">{t('auditForm.typeBar', locale)}</option>
            <option value="autre">{t('auditForm.typeOther', locale)}</option>
          </select>
        </div>

        <div class="group">
          <label for="ville" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.city', locale)} <span class="text-terracotta">*</span>
          </label>
          <input
            type="text"
            id="ville"
            name="ville"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.cityPlaceholder', locale)}
          />
        </div>

        <div class="group">
          <label for="email" class="block text-sm font-sans font-medium text-charcoal mb-2 transition-colors duration-300 group-focus-within:text-terracotta">
            {t('auditForm.email', locale)} <span class="text-terracotta">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            aria-required="true"
            class="block w-full px-4 py-3.5 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-all duration-300 focus:border-terracotta focus:outline-none focus:shadow-[0_0_0_3px_rgba(196,120,91,0.1)]"
            placeholder={t('auditForm.emailPlaceholder', locale)}
          />
        </div>

        <!-- Error message -->
        <div id="form-error" class="hidden px-4 py-3 bg-red-50 border border-red-200 text-red-700 font-sans text-sm" role="alert">
          {t('auditForm.errorGeneric', locale)}
        </div>

        <!-- Exclusivity signal -->
        <p class="text-center text-xs font-sans text-stone/80 px-4 py-3 bg-sand border border-warmgray/30">
          {t('auditForm.exclusivity', locale)}
        </p>

        <button
          type="submit"
          id="submit-btn"
          class="block w-full px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-all duration-300 hover:bg-terracotta-dark cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed"
        >
          {t('auditForm.submitButton', locale)}
        </button>
      </form>

      <!-- Trust signals -->
      <p class="text-center text-sm font-sans font-medium text-stone mt-6 fade-up">
        {t('auditForm.trustSignals', locale)}
      </p>
    </div>
  </div>
</section>

<script>
  // n8n webhook URL — loaded from PUBLIC_WEBHOOK_URL env variable (.env)
  const WEBHOOK_URL = import.meta.env.PUBLIC_WEBHOOK_URL;

  const form = document.getElementById('audit-form');
  const submitBtn = document.getElementById('submit-btn');
  const errorDiv = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot check
    const honey = form.querySelector('input[name="_honey"]');
    if (honey && honey.value) return;

    // Basic validation
    const etablissement = form.querySelector('#etablissement');
    const email = form.querySelector('#email');
    const type = form.querySelector('#type');
    const ville = form.querySelector('#ville');

    if (!etablissement?.value || !email?.value || !type?.value || !ville?.value) {
      form.reportValidity();
      return;
    }

    // Collect form data
    const data = {
      etablissement: etablissement.value,
      type: type.value,
      ville: ville.value,
      email: email.value,
      page: window.location.pathname,
      submitted_at: new Date().toISOString()
    };

    // UI: loading state
    submitBtn.disabled = true;
    submitBtn.textContent = form.dataset.submitting || 'Envoi en cours…';
    errorDiv.classList.add('hidden');

    try {
      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (!response.ok) throw new Error('Erreur serveur');

      // Track with Plausible
      if (typeof plausible !== 'undefined') {
        plausible('Form Submit');
      }

      // Redirect to thank you page (locale-aware)
      window.location.href = form.dataset.redirect || '/merci';
    } catch (err) {
      errorDiv.textContent = form.dataset.errorGeneric || 'Une erreur est survenue. Veuillez réessayer ou nous contacter à contact@eddiemiller.agency.';
      errorDiv.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = form.dataset.submitText || 'Demander mon diagnostic gratuit';
    }
  });
</script>
