---
// AuditForm section — CTA final + native form placeholder for Tally embed
---
<section id="audit" class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Demander un audit gratuit">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-in">
        Votre audit gratuit en 30&nbsp;minutes
      </h2>
      <p class="text-center text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-10 md:mb-12 fade-in">
        Découvrez votre score de visibilité IA. Sans engagement, sans carte bancaire.
      </p>

      <!-- TODO: Replace with Tally embed when URL is available -->
      <form class="space-y-6 fade-in" action="#" method="POST">
        <div>
          <label for="etablissement" class="block text-sm font-sans font-medium text-charcoal mb-2">
            Nom de l'établissement
          </label>
          <input
            type="text"
            id="etablissement"
            name="etablissement"
            required
            class="block w-full px-4 py-3 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-colors duration-300 focus:border-terracotta focus:outline-none"
            placeholder="Le Petit Cler, Cabinet Dr. Martin…"
          />
        </div>

        <div>
          <label for="type" class="block text-sm font-sans font-medium text-charcoal mb-2">
            Type d'établissement
          </label>
          <select
            id="type"
            name="type"
            required
            class="block w-full px-4 py-3 font-sans text-base text-charcoal bg-cream border border-warmgray transition-colors duration-300 focus:border-terracotta focus:outline-none appearance-none"
            style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2216%22 height=%2216%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%236B6360%22 stroke-width=%221.5%22%3E%3Cpath d=%22M6 9l6 6 6-6%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 1rem center;"
          >
            <option value="" disabled selected>Choisir…</option>
            <option value="restaurant">Restaurant</option>
            <option value="hotel">Hôtel</option>
            <option value="dentiste">Cabinet dentaire</option>
            <option value="medical">Cabinet médical</option>
            <option value="avocat">Cabinet d'avocats</option>
            <option value="autre">Autre</option>
          </select>
        </div>

        <div>
          <label for="localisation" class="block text-sm font-sans font-medium text-charcoal mb-2">
            Arrondissement ou ville
          </label>
          <input
            type="text"
            id="localisation"
            name="localisation"
            required
            class="block w-full px-4 py-3 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-colors duration-300 focus:border-terracotta focus:outline-none"
            placeholder="Paris 7e, Neuilly-sur-Seine…"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-sans font-medium text-charcoal mb-2">
            Adresse email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="block w-full px-4 py-3 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-colors duration-300 focus:border-terracotta focus:outline-none"
            placeholder="vous@exemple.com"
          />
        </div>

        <div>
          <label for="telephone" class="block text-sm font-sans font-medium text-charcoal mb-2">
            Numéro de téléphone <span class="text-warmgray font-normal">(optionnel)</span>
          </label>
          <input
            type="tel"
            id="telephone"
            name="telephone"
            class="block w-full px-4 py-3 font-sans text-base text-charcoal bg-cream border border-warmgray placeholder:text-warmgray transition-colors duration-300 focus:border-terracotta focus:outline-none"
            placeholder="06 12 34 56 78"
          />
        </div>

        <button
          type="submit"
          class="block w-full px-8 py-4 font-sans font-medium text-base text-cream bg-terracotta tracking-[0.02em] transition-colors duration-300 hover:bg-terracotta-dark cursor-pointer"
        >
          Recevoir mon audit gratuit
        </button>
      </form>

      <!-- Trust signals -->
      <p class="text-center text-sm font-sans font-medium text-stone mt-6 fade-in">
        Réponse sous 24h · 100&nbsp;% gratuit · Sans engagement
      </p>
    </div>
  </div>
</section>
