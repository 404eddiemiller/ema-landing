---
// Problem section — Dark background Apple-style + animated stat cards
import { t, getLocaleFromPath, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);

const decSep = locale === 'en' ? '.' : ',';
const fmt = (v: number) => v % 1 !== 0 ? v.toFixed(1).replace('.', decSep) : String(v);

const stats = [
  { value: parseFloat(t('problem.stat1Value', locale)), suffix: t('problem.stat1Suffix', locale), text: t('problem.stat1Text', locale), source: t('problem.stat1Source', locale) },
  { value: parseFloat(t('problem.stat2Value', locale)), suffix: t('problem.stat2Suffix', locale), text: t('problem.stat2Text', locale), source: t('problem.stat2Source', locale) },
  { value: parseFloat(t('problem.stat3Value', locale)), suffix: t('problem.stat3Suffix', locale), text: t('problem.stat3Text', locale), source: t('problem.stat3Source', locale) },
];
---
<section class="py-16 md:py-24 lg:py-32 bg-charcoal text-cream section-inverted" aria-label="Le problème">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <h2 class="section-title text-cream mb-4 fade-up-slow">
      {t('problem.title', locale)}
    </h2>
    <p class="text-center max-w-[55ch] mx-auto text-lg md:text-xl font-sans font-normal leading-relaxed text-cream/70 mb-12 md:mb-16 fade-up"
      set:html={t('problem.subtitle', locale).replace('. ', '.<br />')}
    />

    <!-- Stat cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-12 md:mb-16">
      {stats.map((stat, i) => (
        <div class="border border-cream/10 p-8 bg-cream/5 transition-all duration-400 hover:border-terracotta hover:bg-cream/8 scale-in">
          <p
            class="text-[3rem] md:text-[3.5rem] font-serif font-normal leading-none tracking-[-0.02em] text-terracotta mb-4"
            data-count-to={stat.value}
            data-suffix={stat.suffix}
            data-dec-sep={decSep}
          >
            {fmt(stat.value)}{stat.suffix}
          </p>
          <p class="text-base md:text-lg font-sans font-normal leading-relaxed text-cream/80 mb-4">
            {stat.text}
          </p>
          {stat.source && (
            <p class="text-sm font-sans font-medium text-cream/40">
              <cite class="not-italic">{stat.source}</cite>
            </p>
          )}
        </div>
      ))}
    </div>

    <!-- ChatGPT mock-up with tabs -->
    <div class="max-w-xl mx-auto mb-12 md:mb-16 scale-in" id="mockup-tabs">
      <p class="text-xs font-sans font-medium text-cream/40 uppercase tracking-wider mb-3 text-center">Ce que voit votre futur client</p>

      <!-- Tab buttons -->
      <div class="flex gap-0 mb-0" role="tablist">
        <button type="button" role="tab" id="tab-restaurant" aria-controls="panel-restaurant" class="mockup-tab flex-1 px-4 py-2.5 text-xs font-sans font-medium tracking-wider uppercase border border-cream/10 border-b-0 transition-colors duration-200 bg-cream/10 text-cream/90" data-tab="restaurant" aria-selected="true" tabindex="0">Restaurant</button>
        <button type="button" role="tab" id="tab-dentiste" aria-controls="panel-dentiste" class="mockup-tab flex-1 px-4 py-2.5 text-xs font-sans font-medium tracking-wider uppercase border border-cream/10 border-b-0 transition-colors duration-200 bg-cream/5 text-cream/40 hover:text-cream/60" data-tab="dentiste" aria-selected="false" tabindex="-1">Dentiste</button>
        <button type="button" role="tab" id="tab-hotel" aria-controls="panel-hotel" class="mockup-tab flex-1 px-4 py-2.5 text-xs font-sans font-medium tracking-wider uppercase border border-cream/10 border-b-0 transition-colors duration-200 bg-cream/5 text-cream/40 hover:text-cream/60" data-tab="hotel" aria-selected="false" tabindex="-1">Hôtel</button>
      </div>

      <!-- Restaurant panel -->
      <div role="tabpanel" id="panel-restaurant" aria-labelledby="tab-restaurant" class="mockup-panel border border-cream/10 bg-cream/5 p-5 md:p-6" data-panel="restaurant">
        <div class="flex items-start gap-3 mb-5">
          <div class="w-7 h-7 shrink-0 bg-cream/20 flex items-center justify-center" aria-hidden="true">
            <svg class="w-4 h-4 text-cream/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <p class="text-sm font-sans font-medium text-cream/90 leading-relaxed">
            Meilleur restaurant italien dans le 11e ?
          </p>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-7 h-7 shrink-0 bg-terracotta/20 flex items-center justify-center" aria-hidden="true">
            <svg class="w-4 h-4 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c.5 3.5 2 5 5.5 5.5-3.5.5-5 2-5.5 5.5-.5-3.5-2-5-5.5-5.5C10 8 11.5 6.5 12 3Z"/><path d="M19 10c.3 2 1.2 3 3.3 3.3-2.1.3-3 1.2-3.3 3.3-.3-2.1-1.2-3-3.3-3.3 2.1-.3 3-1.3 3.3-3.3Z"/></svg>
          </div>
          <div class="text-sm font-sans text-cream/80 leading-relaxed">
            <p class="mb-3">Voici les 3 restaurants italiens les mieux notés dans le 11e :</p>
            <ol class="space-y-2 list-decimal list-inside">
              <li><strong class="text-terracotta">Votre restaurant pourrait être ici.</strong></li>
              <li><strong class="text-cream">Trattoria Della Nonna</strong> — 4.7★, pâtes fraîches maison</li>
              <li><strong class="text-cream">Il Contadino</strong> — 4.6★, cuisine napolitaine</li>
            </ol>
          </div>
        </div>
      </div>

      <!-- Dentiste panel -->
      <div role="tabpanel" id="panel-dentiste" aria-labelledby="tab-dentiste" class="mockup-panel border border-cream/10 bg-cream/5 p-5 md:p-6 hidden" data-panel="dentiste">
        <div class="flex items-start gap-3 mb-5">
          <div class="w-7 h-7 shrink-0 bg-cream/20 flex items-center justify-center" aria-hidden="true">
            <svg class="w-4 h-4 text-cream/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <p class="text-sm font-sans font-medium text-cream/90 leading-relaxed">
            Meilleur dentiste près de chez moi ?
          </p>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-7 h-7 shrink-0 bg-terracotta/20 flex items-center justify-center" aria-hidden="true">
            <svg class="w-4 h-4 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c.5 3.5 2 5 5.5 5.5-3.5.5-5 2-5.5 5.5-.5-3.5-2-5-5.5-5.5C10 8 11.5 6.5 12 3Z"/><path d="M19 10c.3 2 1.2 3 3.3 3.3-2.1.3-3 1.2-3.3 3.3-.3-2.1-1.2-3-3.3-3.3 2.1-.3 3-1.3 3.3-3.3Z"/></svg>
          </div>
          <div class="text-sm font-sans text-cream/80 leading-relaxed">
            <p class="mb-3">Voici les 3 cabinets dentaires les mieux notés dans votre quartier :</p>
            <ol class="space-y-2 list-decimal list-inside">
              <li><strong class="text-terracotta">Votre cabinet pourrait être ici.</strong></li>
              <li><strong class="text-cream">Cabinet Martin</strong> — 4.9★, spécialiste en implantologie</li>
              <li><strong class="text-cream">Dr. Lefebvre</strong> — 4.8★, soins esthétiques dentaires</li>
            </ol>
          </div>
        </div>
      </div>

      <!-- Hôtel panel -->
      <div role="tabpanel" id="panel-hotel" aria-labelledby="tab-hotel" class="mockup-panel border border-cream/10 bg-cream/5 p-5 md:p-6 hidden" data-panel="hotel">
        <div class="flex items-start gap-3 mb-5">
          <div class="w-7 h-7 shrink-0 bg-cream/20 flex items-center justify-center" aria-hidden="true">
            <svg class="w-4 h-4 text-cream/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <p class="text-sm font-sans font-medium text-cream/90 leading-relaxed">
            Best boutique hotel in Le Marais?
          </p>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-7 h-7 shrink-0 bg-terracotta/20 flex items-center justify-center" aria-hidden="true">
            <svg class="w-4 h-4 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c.5 3.5 2 5 5.5 5.5-3.5.5-5 2-5.5 5.5-.5-3.5-2-5-5.5-5.5C10 8 11.5 6.5 12 3Z"/><path d="M19 10c.3 2 1.2 3 3.3 3.3-2.1.3-3 1.2-3.3 3.3-.3-2.1-1.2-3-3.3-3.3 2.1-.3 3-1.3 3.3-3.3Z"/></svg>
          </div>
          <div class="text-sm font-sans text-cream/80 leading-relaxed">
            <p class="mb-3">Here are 3 highly-rated boutique hotels in Le Marais:</p>
            <ol class="space-y-2 list-decimal list-inside">
              <li><strong class="text-terracotta">Votre hôtel pourrait être ici.</strong></li>
              <li><strong class="text-cream">Hôtel du Petit Moulin</strong> — 4.8★, design by Christian Lacroix</li>
              <li><strong class="text-cream">Le Pavillon de la Reine</strong> — 4.7★, Place des Vosges</li>
            </ol>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Mockup tabs script -->
<script>
  const tabContainer = document.getElementById('mockup-tabs');
  if (tabContainer) {
    const tabs = tabContainer.querySelectorAll<HTMLButtonElement>('.mockup-tab');
    const panels = tabContainer.querySelectorAll<HTMLDivElement>('.mockup-panel');

    function activateTab(tab: HTMLButtonElement) {
      const target = tab.dataset.tab;

      tabs.forEach(t => {
        const isActive = t.dataset.tab === target;
        t.setAttribute('aria-selected', String(isActive));
        t.setAttribute('tabindex', isActive ? '0' : '-1');
        t.classList.toggle('bg-cream/10', isActive);
        t.classList.toggle('text-cream/90', isActive);
        t.classList.toggle('bg-cream/5', !isActive);
        t.classList.toggle('text-cream/40', !isActive);
      });

      panels.forEach(p => {
        p.classList.toggle('hidden', p.dataset.panel !== target);
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => activateTab(tab));
    });

    // Keyboard navigation: arrow keys to move between tabs
    tabContainer.querySelector('[role="tablist"]')?.addEventListener('keydown', (e: KeyboardEvent) => {
      const tabArray = Array.from(tabs);
      const current = tabArray.findIndex(t => t.getAttribute('aria-selected') === 'true');
      let next = -1;

      if (e.key === 'ArrowRight') next = (current + 1) % tabArray.length;
      else if (e.key === 'ArrowLeft') next = (current - 1 + tabArray.length) % tabArray.length;
      else if (e.key === 'Home') next = 0;
      else if (e.key === 'End') next = tabArray.length - 1;

      if (next >= 0) {
        e.preventDefault();
        activateTab(tabArray[next]);
        tabArray[next].focus();
      }
    });
  }
</script>

<!-- Counter animation script -->
<script>
  import { initCounterObserver } from '../scripts/counter-animation';
  initCounterObserver();
</script>
