---
// Verticals section — "Pour qui travaillons-nous" — 5 cards grid
const verticals = [
  {
    title: 'Cabinets dentaires',
    description: 'Soyez le dentiste que ChatGPT recommande dans votre arrondissement.',
    icon: 'stethoscope',
  },
  {
    title: 'Cabinets médicaux',
    description: "Devenez le médecin que les patients trouvent en demandant conseil à l'IA.",
    icon: 'heart-pulse',
  },
  {
    title: "Cabinets d'avocats",
    description: 'Apparaissez quand un client potentiel demande « meilleur avocat Paris » à Gemini.',
    icon: 'scale',
  },
  {
    title: 'Restaurants',
    description: 'Soyez la première recommandation quand un touriste demande où dîner ce soir.',
    icon: 'utensils-crossed',
  },
  {
    title: 'Hôtels',
    description: "Intégrez les suggestions d'hébergement que les voyageurs reçoivent de Perplexity et ChatGPT.",
    icon: 'building',
  },
];
---
<section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Pour qui travaillons-nous">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-12 md:mb-16 fade-in">
      Pour qui travaillons-nous
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {verticals.map((v) => (
        <div class="border border-warmgray p-8 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
          <div class="mb-5">
            {v.icon === 'stethoscope' && (
              <svg class="w-8 h-8 text-stone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M11 2v2" />
                <path d="M5 2v2" />
                <path d="M5 3H4a2 2 0 0 0-2 2v4a6 6 0 0 0 12 0V5a2 2 0 0 0-2-2h-1" />
                <path d="M8 15a6 6 0 0 0 12 0v-3" />
                <circle cx="20" cy="10" r="2" />
              </svg>
            )}
            {v.icon === 'heart-pulse' && (
              <svg class="w-8 h-8 text-stone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5" />
                <path d="M3.22 13H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27" />
              </svg>
            )}
            {v.icon === 'scale' && (
              <svg class="w-8 h-8 text-stone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3v18" />
                <path d="m19 8 3 8a5 5 0 0 1-6 0z" />
                <path d="M3 7h1a17 17 0 0 0 8-2 17 17 0 0 0 8 2h1" />
                <path d="m5 8 3 8a5 5 0 0 1-6 0z" />
                <path d="M7 21h10" />
              </svg>
            )}
            {v.icon === 'utensils-crossed' && (
              <svg class="w-8 h-8 text-stone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m16 2-2.3 2.3a3 3 0 0 0 0 4.2l1.8 1.8a3 3 0 0 0 4.2 0L22 8" />
                <path d="M15 15 3.3 3.3a4.2 4.2 0 0 0 0 6l7.3 7.3c.7.7 2 .7 2.8 0L15 15Zm0 0 7 7" />
                <path d="m2.1 21.8 6.4-6.3" />
                <path d="m19 5-7 7" />
              </svg>
            )}
            {v.icon === 'building' && (
              <svg class="w-8 h-8 text-stone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="4" y="2" width="16" height="20" rx="2" />
                <path d="M9 22v-3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3" />
                <path d="M8 6h.01" /><path d="M12 6h.01" /><path d="M16 6h.01" />
                <path d="M8 10h.01" /><path d="M12 10h.01" /><path d="M16 10h.01" />
                <path d="M8 14h.01" /><path d="M12 14h.01" /><path d="M16 14h.01" />
              </svg>
            )}
          </div>
          <h3 class="text-xl md:text-2xl font-serif font-normal leading-[1.2] text-charcoal mb-3">
            {v.title}
          </h3>
          <p class="text-base font-sans font-normal leading-relaxed text-stone">
            {v.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
