---
// Verticals section — "Pour qui" — compact 8-card grid
const verticals = [
  {
    title: 'Cabinets dentaires & médicaux',
    description: "Apparaissez quand un patient demande « dentiste » ou « médecin » à ChatGPT.",
    icon: 'stethoscope',
  },
  {
    title: "Cabinets d'avocats",
    description: "Soyez la recommandation quand un client cherche « avocat » sur ChatGPT.",
    icon: 'scale',
  },
  {
    title: 'Restaurants',
    description: "Devenez le restaurant que ChatGPT recommande aux touristes et aux locaux.",
    icon: 'utensils-crossed',
  },
  {
    title: 'Hôtels',
    description: "40 % des voyageurs planifient avec l'IA. Soyez dans leurs suggestions.",
    icon: 'building',
  },
  {
    title: 'Coiffure & Esthétique',
    description: "« Meilleur coiffeur Paris » sur ChatGPT : 3 résultats. Faites-en partie.",
    icon: 'scissors',
  },
  {
    title: 'Bien-être & Spa',
    description: "Soyez le spa recommandé par l'IA dans votre arrondissement.",
    icon: 'sparkles',
  },
  {
    title: 'Salles de sport',
    description: "Captez les nouveaux adhérents qui demandent conseil à l'IA.",
    icon: 'dumbbell',
  },
  {
    title: 'Bars & Lieux de soirée',
    description: "« Où sortir ce soir ? » — l'IA devient le nouveau guide de nuit.",
    icon: 'glass',
  },
];
---
<section class="py-16 md:py-24 lg:py-32 bg-cream" aria-label="Pour qui">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <h2 class="text-center text-[2rem] md:text-[3rem] font-serif font-normal leading-[1.15] tracking-[-0.02em] text-charcoal mb-4 fade-in">
      Pour qui
    </h2>
    <p class="text-center max-w-[50ch] mx-auto text-lg md:text-xl font-sans font-normal leading-relaxed text-stone mb-12 md:mb-16 fade-in">
      Tout commerce local avec une adresse physique à Paris.
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
      {verticals.map((v) => (
        <div class="border border-warmgray p-5 md:p-6 bg-cream transition-colors duration-300 hover:border-terracotta fade-in">
          <div class="mb-3">
            {v.icon === 'stethoscope' && (
              <svg class="w-6 h-6 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M11 2v2" />
                <path d="M5 2v2" />
                <path d="M5 3H4a2 2 0 0 0-2 2v4a6 6 0 0 0 12 0V5a2 2 0 0 0-2-2h-1" />
                <path d="M8 15a6 6 0 0 0 12 0v-3" />
                <circle cx="20" cy="10" r="2" />
              </svg>
            )}
            {v.icon === 'scale' && (
              <svg class="w-6 h-6 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3v18" />
                <path d="m19 8 3 8a5 5 0 0 1-6 0z" />
                <path d="M3 7h1a17 17 0 0 0 8-2 17 17 0 0 0 8 2h1" />
                <path d="m5 8 3 8a5 5 0 0 1-6 0z" />
                <path d="M7 21h10" />
              </svg>
            )}
            {v.icon === 'utensils-crossed' && (
              <svg class="w-6 h-6 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m16 2-2.3 2.3a3 3 0 0 0 0 4.2l1.8 1.8a3 3 0 0 0 4.2 0L22 8" />
                <path d="M15 15 3.3 3.3a4.2 4.2 0 0 0 0 6l7.3 7.3c.7.7 2 .7 2.8 0L15 15Zm0 0 7 7" />
                <path d="m2.1 21.8 6.4-6.3" />
                <path d="m19 5-7 7" />
              </svg>
            )}
            {v.icon === 'building' && (
              <svg class="w-6 h-6 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="4" y="2" width="16" height="20" rx="2" />
                <path d="M9 22v-3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3" />
                <path d="M8 6h.01" /><path d="M12 6h.01" /><path d="M16 6h.01" />
                <path d="M8 10h.01" /><path d="M12 10h.01" /><path d="M16 10h.01" />
                <path d="M8 14h.01" /><path d="M12 14h.01" /><path d="M16 14h.01" />
              </svg>
            )}
            {v.icon === 'scissors' && (
              <svg class="w-6 h-6 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="6" cy="6" r="3" />
                <path d="M8.12 8.12 12 12" />
                <path d="M20 4 8.12 15.88" />
                <circle cx="6" cy="18" r="3" />
                <path d="M14.8 14.8 20 20" />
              </svg>
            )}
            {v.icon === 'sparkles' && (
              <svg class="w-6 h-6 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3c.5 3.5 2 5 5.5 5.5-3.5.5-5 2-5.5 5.5-.5-3.5-2-5-5.5-5.5C10 8 11.5 6.5 12 3Z" />
                <path d="M19 10c.3 2 1.2 3 3.3 3.3-2.1.3-3 1.2-3.3 3.3-.3-2.1-1.2-3-3.3-3.3 2.1-.3 3-1.3 3.3-3.3Z" />
                <path d="M9 17c.3 2 1.2 3 3.3 3.3-2.1.3-3 1.2-3.3 3.3-.3-2.1-1.2-3-3.3-3.3C7.8 20 8.7 19 9 17Z" />
              </svg>
            )}
            {v.icon === 'dumbbell' && (
              <svg class="w-6 h-6 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14.4 14.4 9.6 9.6" />
                <path d="M18.657 21.485a2 2 0 1 1-2.829-2.828l-1.767-1.768a2 2 0 1 1-2.829-2.829l6.364-6.364a2 2 0 1 1 2.829 2.829l1.767 1.767a2 2 0 1 1 2.829 2.829z" />
                <path d="m21.5 21.5-1.4-1.4" />
                <path d="M3.9 3.9 2.5 2.5" />
                <path d="M6.404 12.768a2 2 0 1 1-2.829-2.829l1.768-1.767a2 2 0 1 1-2.828-2.829l2.828-2.828a2 2 0 1 1 2.829 2.828l1.767-1.768a2 2 0 1 1 2.829 2.829z" />
              </svg>
            )}
            {v.icon === 'glass' && (
              <svg class="w-6 h-6 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M8 22h8" />
                <path d="M12 15v7" />
                <path d="m19 2-7 10-7-10Z" />
              </svg>
            )}
          </div>
          <h3 class="text-base md:text-lg font-serif font-normal leading-[1.2] text-charcoal mb-1.5">
            {v.title}
          </h3>
          <p class="text-sm font-sans font-normal leading-relaxed text-stone">
            {v.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
