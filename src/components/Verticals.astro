---
// Verticals section — Interactive cards with hover animations
import { t, getLocaleFromPath, pageRoutes, localePath, type Locale } from '../i18n/index';
const locale = getLocaleFromPath(Astro.url.pathname);
const verticals = [
  { titleKey: 'verticals.card1Title', textKey: 'verticals.card1Text', icon: 'utensils-crossed', routeKey: 'restaurants' as const },
  { titleKey: 'verticals.card2Title', textKey: 'verticals.card2Text', icon: 'building', routeKey: 'hotels' as const },
  { titleKey: 'verticals.card3Title', textKey: 'verticals.card3Text', icon: 'glass', routeKey: 'bars' as const },
  { titleKey: 'verticals.card4Title', textKey: 'verticals.card4Text', icon: 'stethoscope', href: localePath('/medical', locale) },
  { titleKey: 'verticals.card5Title', textKey: 'verticals.card5Text', icon: 'tooth', routeKey: 'dentists' as const },
  { titleKey: 'verticals.card6Title', textKey: 'verticals.card6Text', icon: 'scale', routeKey: 'lawyers' as const },
  { titleKey: 'verticals.card7Title', textKey: 'verticals.card7Text', icon: 'scissors', routeKey: 'hair' as const },
  { titleKey: 'verticals.card8Title', textKey: 'verticals.card8Text', icon: 'sparkles', routeKey: 'spa' as const },
  { titleKey: 'verticals.card9Title', textKey: 'verticals.card9Text', icon: 'dumbbell', routeKey: 'gyms' as const },
  { titleKey: 'verticals.card10Title', textKey: 'verticals.card10Text', icon: 'plus' },
];

// SVG icon paths by name
const icons: Record<string, string> = {
  tooth: '<path d="M12 2C9.5 2 8 3.5 7.5 5c-.3.8-.5 2-.2 3.5.4 2 .7 4 .2 6-.3 1.2-.8 2.5-1 3.5-.3 1.5.5 3 1.5 3s1.5-1 2-3c.3-1 .5-2 1-3 .3-.5.7-.5 1-.5s.7 0 1 .5c.5 1 .7 2 1 3 .5 2 1 3 2 3s1.8-1.5 1.5-3c-.2-1-.7-2.3-1-3.5-.5-2-.2-4 .2-6 .3-1.5.1-2.7-.2-3.5C16 3.5 14.5 2 12 2Z"/>',
  stethoscope: '<path d="M11 2v2"/><path d="M5 2v2"/><path d="M5 3H4a2 2 0 0 0-2 2v4a6 6 0 0 0 12 0V5a2 2 0 0 0-2-2h-1"/><path d="M8 15a6 6 0 0 0 12 0v-3"/><circle cx="20" cy="10" r="2"/>',
  scale: '<path d="M12 3v18"/><path d="m19 8 3 8a5 5 0 0 1-6 0z"/><path d="M3 7h1a17 17 0 0 0 8-2 17 17 0 0 0 8 2h1"/><path d="m5 8 3 8a5 5 0 0 1-6 0z"/><path d="M7 21h10"/>',
  'utensils-crossed': '<path d="m16 2-2.3 2.3a3 3 0 0 0 0 4.2l1.8 1.8a3 3 0 0 0 4.2 0L22 8"/><path d="M15 15 3.3 3.3a4.2 4.2 0 0 0 0 6l7.3 7.3c.7.7 2 .7 2.8 0L15 15Zm0 0 7 7"/><path d="m2.1 21.8 6.4-6.3"/><path d="m19 5-7 7"/>',
  building: '<rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3"/><path d="M8 6h.01"/><path d="M12 6h.01"/><path d="M16 6h.01"/><path d="M8 10h.01"/><path d="M12 10h.01"/><path d="M16 10h.01"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/>',
  scissors: '<circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/>',
  sparkles: '<path d="M12 3c.5 3.5 2 5 5.5 5.5-3.5.5-5 2-5.5 5.5-.5-3.5-2-5-5.5-5.5C10 8 11.5 6.5 12 3Z"/><path d="M19 10c.3 2 1.2 3 3.3 3.3-2.1.3-3 1.2-3.3 3.3-.3-2.1-1.2-3-3.3-3.3 2.1-.3 3-1.3 3.3-3.3Z"/><path d="M9 17c.3 2 1.2 3 3.3 3.3-2.1.3-3 1.2-3.3 3.3-.3-2.1-1.2-3-3.3-3.3C7.8 20 8.7 19 9 17Z"/>',
  heartpulse: '<path d="M19.5 12.572l-7.5 7.428l-7.5-7.428A5 5 0 1 1 12 6.006a5 5 0 1 1 7.5 6.572"/><path d="M12 6v4l2 2"/>',
  dumbbell: '<path d="m6.5 6.5 11 0M17.5 4v5M6.5 4v5"/><rect x="3" y="5" width="3.5" height="3" rx="0.5"/><rect x="17.5" y="5" width="3.5" height="3" rx="0.5"/><path d="M2 6.5h1M21 6.5h1"/><path d="m6.5 15.5 11 0M17.5 13v5M6.5 13v5"/><rect x="3" y="14" width="3.5" height="3" rx="0.5"/><rect x="17.5" y="14" width="3.5" height="3" rx="0.5"/><path d="M2 15.5h1M21 15.5h1"/>',
  plus: '<path d="M5 12h14"/><path d="M12 5v14"/>',
  glass: '<path d="M8 22h8"/><path d="M12 15v7"/><path d="m19 2-7 10-7-10Z"/>',
};
---
<section class="py-16 md:py-24 lg:py-32 bg-sand" aria-label="Ça marche pour votre métier">
  <div class="max-w-container mx-auto px-6 md:px-8 lg:px-16">
    <h2 class="section-title mb-4 fade-up-slow">
      {t('verticals.title', locale)}
    </h2>
    <p class="section-subtitle max-w-[55ch] mx-auto mb-12 md:mb-16 fade-up">
      {t('verticals.subtitle', locale)}
    </p>

    <div class="verticals-carousel flex overflow-x-auto snap-x snap-mandatory gap-4 md:gap-5 pb-4 -mx-6 px-6 md:-mx-8 md:px-8 lg:-mx-16 lg:px-16">
      {verticals.map((v, i) => {
        const href = v.href ?? (v.routeKey ? pageRoutes[v.routeKey]?.[locale] : undefined);
        const cardClasses = "snap-start shrink-0 w-[72vw] sm:w-[44vw] lg:w-[320px] block border border-warmgray p-5 md:p-6 bg-cream card-hover scale-in group";
        const cardContent = (
          <>
            <div class="mb-3">
              <svg class="w-6 h-6 text-terracotta transition-colors duration-300 group-hover:text-terracotta-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[v.icon]} />
            </div>
            <h3 class="text-base md:text-lg font-serif font-normal leading-[1.2] text-charcoal mb-1.5">
              {t(v.titleKey, locale)}
            </h3>
            <p class="text-sm font-sans font-normal leading-relaxed text-stone">
              {t(v.textKey, locale)}
            </p>
            {href && (
              <p class="mt-3 text-sm font-sans font-medium text-terracotta transition-transform duration-300 group-hover:translate-x-1">{t('verticals.learnMore', locale)}</p>
            )}
          </>
        );

        return href ? (
          <a href={href} class={cardClasses + " no-underline"}>
            {cardContent}
          </a>
        ) : (
          <div class={cardClasses}>
            {cardContent}
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .verticals-carousel {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .verticals-carousel::-webkit-scrollbar {
    display: none;
  }
</style>
