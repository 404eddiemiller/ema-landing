---
import '../styles/global.css';
import { t, getLocaleFromPath, localeISO, navRoutes, getAlternateUrls, locales, type Locale } from '../i18n/index';

const locale = getLocaleFromPath(Astro.url.pathname);
const nav = navRoutes[locale];
const alternates = getAlternateUrls(Astro.url.pathname);
const siteUrl = 'https://eddiemiller.agency';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  skipFaqSchema?: boolean;
}
const {
  title,
  description,
  canonicalUrl = new URL(Astro.url.pathname, siteUrl).href,
  ogTitle = t('meta.ogTitle', locale),
  ogDescription = t('meta.ogDescription', locale),
  ogType = 'website',
  ogImage = 'https://eddiemiller.agency/og-image.png',
  skipFaqSchema = false,
} = Astro.props;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#F5F0EB" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1C1814" media="(prefers-color-scheme: dark)" />
    <meta name="google-site-verification" content="40e5qXx2eUyxAmLgBGHqS-pSbohrWFWtwIgj2nrnkH0" />

    <!-- Dark mode anti-FOUC: apply saved theme before render -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || t === 'light') {
          document.documentElement.setAttribute('data-theme', t);
        }
      })();
    </script>
    <!-- Preconnect for external services -->
    <link rel="preconnect" href="https://plausible.io" crossorigin />
    <link rel="dns-prefetch" href="https://plausible.io" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Hreflang alternate links for SEO -->
    {alternates && locales.map((l) => (
      <link rel="alternate" hreflang={l} href={`${siteUrl}${alternates[l]}`} />
    ))}
    {alternates && (
      <link rel="alternate" hreflang="x-default" href={`${siteUrl}${alternates.fr}`} />
    )}

    <!-- Preload fonts -->
    <link rel="preload" href="/fonts/DMSerifDisplay-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={localeISO[locale]} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Eddie Miller Agency" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:description" content={ogDescription} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Eddie Miller Agency",
      "description": t('meta.ogDescription', locale),
      "url": "https://eddiemiller.agency",
      "email": "contact@eddiemiller.agency",
      "logo": "https://eddiemiller.agency/favicon-192x192.png",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "41 Rue du Montparnasse",
        "postalCode": "75014",
        "addressLocality": "Paris",
        "addressCountry": "FR"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Worldwide"
      },
      "serviceType": [
        "Local Business Visibility Consulting",
        "Google Business Profile Management",
        "Google Maps Optimization",
        "AI Search Optimization",
        "ChatGPT Visibility for Local Businesses",
        "Local Online Reputation Management"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": t('meta.ogTitle', locale),
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": t('howItWorks.step1Title', locale),
              "description": t('howItWorks.step1Text', locale),
              "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": t('howItWorks.step2Title', locale),
              "description": t('howItWorks.step2Text', locale)
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": t('howItWorks.step3Title', locale),
              "description": t('howItWorks.step3Text', locale)
            }
          }
        ]
      },
      "knowsLanguage": ["fr", "en", "es", "de", "it", "pt", "nl"],
      "priceRange": "€€",
      "founder": {
        "@type": "Person",
        "name": "Adam Douieb"
      },
      "foundingDate": "2026",
      "openingHours": "Mo-Fr 09:00-18:00",
      "sameAs": [
        "https://share.google/7G3R43yFI12f0SMcI"
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": t('howItWorks.title', locale),
      "description": t('howItWorks.subtitle', locale),
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": t('howItWorks.step1Title', locale),
          "text": t('howItWorks.step1Text', locale)
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": t('howItWorks.step2Title', locale),
          "text": t('howItWorks.step2Text', locale)
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": t('howItWorks.step3Title', locale),
          "text": t('howItWorks.step3Text', locale)
        }
      ]
    })} />
    {!skipFaqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": Array.from({ length: 10 }, (_, i) => ({
          "@type": "Question",
          "name": t(`faq.q${i + 1}`, locale),
          "acceptedAnswer": {
            "@type": "Answer",
            "text": t(`faq.a${i + 1}`, locale)
          }
        }))
      })} />
    )}

    <!-- WebSite schema — tells Google to show "Eddie Miller Agency" as site name -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Eddie Miller Agency",
        "url": "https://eddiemiller.agency"
      }
    </script>

    <!-- Plausible Analytics -->
    <script is:inline async src="https://plausible.io/js/pa-V0XLRxsUEbXHqAAPrygvE.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>

  </head>
  <body class="bg-cream text-charcoal font-sans pb-16 md:pb-0">
    <!-- Language suggestion banner -->
    <div id="lang-banner" class="hidden sticky top-[73px] left-0 w-full z-40 bg-cream/95 backdrop-blur-sm border-b border-warmgray/30 py-4 px-4" role="alert">
      <div class="max-w-container mx-auto flex items-center justify-between gap-3">
        <p id="lang-banner-text" class="font-sans text-sm text-stone"></p>
        <div class="flex items-center gap-2 shrink-0">
          <a id="lang-banner-link" href="/" class="font-sans text-sm font-medium text-terracotta transition-colors duration-200 hover:text-terracotta-dark"></a>
          <button id="lang-banner-close" type="button" class="ml-2 text-stone hover:text-charcoal cursor-pointer bg-transparent border-none p-1" aria-label="Close">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </div>
      </div>
    </div>
    <slot />

    <!-- Sticky CTA bar — fixed at bottom of screen -->
    <div id="sticky-cta" class="fixed bottom-0 left-0 w-full z-40 backdrop-blur-sm py-3 px-4 md:py-3.5 md:px-6 sticky-cta-bar">
      <div class="max-w-container mx-auto flex items-center justify-between gap-4">
        <p class="sticky-cta-text font-sans text-sm text-stone leading-snug">
          {t('stickyCta.text', locale)}
        </p>
        <a
          href={nav.audit}
          class="sticky-cta-btn text-center inline-block px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta-dark tracking-wider uppercase whitespace-nowrap transition-colors duration-300 hover:bg-terracotta"
          onclick="plausible('CTA Click', {props: {location: 'sticky-bar'}})"
        >
          {t('stickyCta.button', locale)}
        </a>
      </div>
    </div>

    <!-- Sticky CTA visibility logic -->
    <script>
      const stickyCta = document.getElementById('sticky-cta');
      if (stickyCta) {
        const auditSection = document.getElementById('diagnostic');
        let ticking = false;

        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const scrollY = window.scrollY;
              const show = scrollY > 400;

              // Hide when the audit form is visible on screen
              let auditVisible = false;
              if (auditSection) {
                const rect = auditSection.getBoundingClientRect();
                auditVisible = rect.top < window.innerHeight && rect.bottom > 0;
              }

              if (show && !auditVisible) {
                stickyCta.style.transform = 'translateY(0)';
              } else {
                stickyCta.style.transform = 'translateY(100%)';
              }
              ticking = false;
            });
            ticking = true;
          }
        });
      }
    </script>

    <!-- Intersection Observer for scroll animations -->
    <script>
      const animClasses = ['.fade-up', '.fade-up-slow', '.scale-in', '.slide-in-left', '.slide-in-right', '.blur-in', '.fade-in', '.draw-line', '.separator-animate'];

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced) {
        document.querySelectorAll(animClasses.join(',')).forEach(el => {
          el.classList.add('visible');
        });
      } else {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll(animClasses.join(',')).forEach((el) => {
          observer.observe(el);
        });
      }
    </script>

    <!-- Language detection banner -->
    <script is:inline>
      (function() {
        if (sessionStorage.getItem('lang-banner-dismissed')) return;

        var pageLocale = document.documentElement.lang || 'fr';
        var browserLang = (navigator.language || '').split('-')[0].toLowerCase();
        var supported = ['fr','en','es','de','it','pt','nl'];

        if (!supported.includes(browserLang) || browserLang === pageLocale) return;

        var messages = {
          fr: { text: 'Cette page est aussi disponible en français.', cta: 'Passer au français', home: '/' },
          en: { text: 'This page is also available in English.', cta: 'Switch to English', home: '/en/' },
          es: { text: 'Esta página también está disponible en español.', cta: 'Cambiar a español', home: '/es/' },
          de: { text: 'Diese Seite ist auch auf Deutsch verfügbar.', cta: 'Zu Deutsch wechseln', home: '/de/' },
          it: { text: 'Questa pagina è disponibile anche in italiano.', cta: 'Passa all\'italiano', home: '/it/' },
          pt: { text: 'Esta página também está disponível em português.', cta: 'Mudar para português', home: '/pt/' },
          nl: { text: 'Deze pagina is ook beschikbaar in het Nederlands.', cta: 'Overschakelen naar Nederlands', home: '/nl/' }
        };

        var msg = messages[browserLang];
        if (!msg) return;

        var banner = document.getElementById('lang-banner');
        var text = document.getElementById('lang-banner-text');
        var link = document.getElementById('lang-banner-link');
        var close = document.getElementById('lang-banner-close');

        if (banner && text && link && close) {
          text.textContent = msg.text;
          link.textContent = msg.cta;
          link.href = msg.home;
          banner.classList.remove('hidden');

          close.addEventListener('click', function() {
            banner.classList.add('hidden');
            sessionStorage.setItem('lang-banner-dismissed', '1');
          });

          link.addEventListener('click', function() {
            sessionStorage.setItem('lang-banner-dismissed', '1');
          });
        }
      })();
    </script>
  </body>
</html>
