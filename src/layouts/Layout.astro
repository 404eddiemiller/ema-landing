---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
}
const {
  title,
  description,
  canonicalUrl = 'https://eddiemiller.agency',
  ogTitle = 'Eddie Miller Agency — Visibilité IA & SEO Local à Paris',
  ogDescription = '83 % des commerces locaux sont invisibles sur ChatGPT. Nous changeons ça. Audit gratuit en 30 minutes.',
  ogType = 'website',
} = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- DNS prefetch for external services -->
    <link rel="dns-prefetch" href="https://plausible.io" />
    <link rel="dns-prefetch" href="https://formsubmit.co" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Preload fonts -->
    <link rel="preload" href="/fonts/DMSerifDisplay-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content="https://eddiemiller.agency/og-image.svg" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:image" content="https://eddiemiller.agency/og-image.svg" />
    <meta name="twitter:description" content={ogDescription} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Eddie Miller Agency",
        "description": "Agence spécialisée en optimisation de visibilité IA (GEO) et SEO local pour restaurants, hôtels et cabinets professionnels à Paris.",
        "url": "https://eddiemiller.agency",
        "email": "contact@eddiemiller.agency",
        "logo": "https://eddiemiller.agency/favicon.svg",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "41 Rue du Montparnasse",
          "postalCode": "75014",
          "addressLocality": "Paris",
          "addressCountry": "FR"
        },
        "areaServed": {
          "@type": "City",
          "name": "Paris"
        },
        "serviceType": [
          "Generative Engine Optimization",
          "SEO local",
          "Optimisation Google Business Profile",
          "Visibilité IA"
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Services de visibilité IA et SEO local",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Audit de visibilité IA gratuit",
                "description": "Analyse complète de votre visibilité sur ChatGPT, Perplexity, Gemini, Google AI Overview et Google Maps. Score sur 100 et recommandations prioritaires.",
                "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" }
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Optimisation visibilité IA (GEO)",
                "description": "Optimisation pour apparaître dans les recommandations de ChatGPT, Gemini, Perplexity et Claude."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "SEO local et Google Business Profile",
                "description": "Classement Google Maps, optimisation fiche Google Business Profile, stratégie d'avis et maillage d'annuaires."
              }
            }
          ]
        },
        "knowsLanguage": ["fr", "en"],
        "priceRange": "€€"
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": "Comment obtenir un audit de visibilité IA gratuit",
        "description": "Trois étapes simples pour connaître votre score de visibilité IA et améliorer votre présence sur ChatGPT, Google et les assistants IA.",
        "step": [
          {
            "@type": "HowToStep",
            "position": 1,
            "name": "Audit gratuit",
            "text": "Nous analysons votre visibilité IA et Google en 30 minutes. Vous recevez un score sur 100 et un diagnostic clair."
          },
          {
            "@type": "HowToStep",
            "position": 2,
            "name": "Plan d'action",
            "text": "Vous recevez un rapport avec les actions prioritaires, classées par impact et par effort. Pas de jargon."
          },
          {
            "@type": "HowToStep",
            "position": 3,
            "name": "Résultats",
            "text": "Nous implémentons les optimisations. Vos clients vous trouvent sur ChatGPT, Google Maps et les plateformes IA."
          }
        ]
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Combien coûte une optimisation de visibilité IA ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "L'audit initial est 100 % gratuit et sans engagement. Nos tarifs commencent à partir de 490 € par mois, avec un devis transparent adapté à votre établissement."
            }
          },
          {
            "@type": "Question",
            "name": "En combien de temps voit-on des résultats ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Les premiers résultats apparaissent entre 4 et 8 semaines. L'optimisation Google Business Profile peut produire des effets dès les premiers jours."
            }
          },
          {
            "@type": "Question",
            "name": "Quelle est la différence entre le GEO et le SEO classique ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Le SEO optimise votre position dans les résultats Google. Le GEO optimise votre présence dans les réponses des assistants IA comme ChatGPT, Perplexity ou Gemini, qui ne montrent que 3 à 5 résultats."
            }
          },
          {
            "@type": "Question",
            "name": "Comment se déroule l'audit gratuit ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Vous remplissez le formulaire, notre équipe teste votre visibilité sur ChatGPT, Perplexity, Gemini et Google Maps. Vous recevez un rapport sous 24 heures avec votre score sur 100 et vos actions prioritaires."
            }
          }
        ]
      }
    </script>

    <!-- Plausible Analytics -->
    <script defer data-domain="eddiemiller.agency" src="https://plausible.io/js/script.js"></script>
    <!-- Plausible custom event tracking -->
    <script>
      window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) };
    </script>

  </head>
  <body class="bg-cream text-charcoal font-sans pb-16 md:pb-0">
    <slot />

    <!-- Sticky CTA bar — fixed at bottom of screen -->
    <div id="sticky-cta" class="fixed bottom-0 left-0 w-full z-40 backdrop-blur-sm py-3 px-4 md:py-3.5 md:px-6" style="background-color: rgba(245, 240, 235, 0.95); border-top: 1px solid rgba(181, 173, 166, 0.3); transform: translateY(100%); transition: transform 0.3s ease;">
      <div class="max-w-container mx-auto flex items-center justify-between gap-4">
        <p class="sticky-cta-text font-sans text-sm text-stone leading-snug">
          Votre commerce est-il visible sur ChatGPT ?
        </p>
        <a
          href="/#audit"
          class="sticky-cta-btn text-center inline-block px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase whitespace-nowrap transition-colors duration-300 hover:bg-terracotta-dark"
          onclick="plausible('CTA Click', {props: {location: 'sticky-bar'}})"
        >
          Audit gratuit →
        </a>
      </div>
    </div>

    <!-- Sticky CTA visibility logic -->
    <script>
      const stickyCta = document.getElementById('sticky-cta');
      if (stickyCta) {
        const auditSection = document.getElementById('audit');
        let ticking = false;

        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const scrollY = window.scrollY;
              const show = scrollY > 400;

              // Hide when the audit form is visible on screen
              let auditVisible = false;
              if (auditSection) {
                const rect = auditSection.getBoundingClientRect();
                auditVisible = rect.top < window.innerHeight && rect.bottom > 0;
              }

              if (show && !auditVisible) {
                stickyCta.style.transform = 'translateY(0)';
              } else {
                stickyCta.style.transform = 'translateY(100%)';
              }
              ticking = false;
            });
            ticking = true;
          }
        });
      }
    </script>

    <!-- Intersection Observer for fade-in animations with stagger -->
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach((el, i) => {
        // Stagger siblings within the same grid parent
        const parent = el.parentElement;
        if (parent && (parent.classList.contains('grid') || parent.classList.contains('flex'))) {
          const siblings = Array.from(parent.querySelectorAll(':scope > .fade-in'));
          const index = siblings.indexOf(el);
          if (index > 0) {
            el.style.transitionDelay = `${index * 0.1}s`;
          }
        }
        observer.observe(el);
      });
    </script>
  </body>
</html>
