---
import '../styles/global.css';
import { t, getLocaleFromPath, localeISO, navRoutes, getAlternateUrls, locales, type Locale } from '../i18n/index';

const locale = getLocaleFromPath(Astro.url.pathname);
const nav = navRoutes[locale];
const alternates = getAlternateUrls(Astro.url.pathname);
const siteUrl = 'https://eddiemiller.agency';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
}
const {
  title,
  description,
  canonicalUrl = 'https://eddiemiller.agency',
  ogTitle = t('meta.ogTitle', locale),
  ogDescription = t('meta.ogDescription', locale),
  ogType = 'website',
  ogImage = 'https://eddiemiller.agency/og-image.png',
} = Astro.props;
---
<!doctype html>
<html lang={locale}
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#F5F0EB" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1A1816" media="(prefers-color-scheme: dark)" />
    <meta name="google-site-verification" content="40e5qXx2eUyxAmLgBGHqS-pSbohrWFWtwIgj2nrnkH0" />

    <!-- Dark mode anti-FOUC: apply saved theme before render -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || t === 'light') {
          document.documentElement.setAttribute('data-theme', t);
        }
      })();
    </script>
    <!-- DNS prefetch for external services -->
    <link rel="dns-prefetch" href="https://plausible.io" />
    <link rel="dns-prefetch" href="https://formsubmit.co" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang alternate links for SEO -->
    {alternates && locales.map((l) => (
      <link rel="alternate" hreflang={l} href={`${siteUrl}${alternates[l]}`} />
    ))}
    {alternates && (
      <link rel="alternate" hreflang="x-default" href={`${siteUrl}${alternates.fr}`} />
    )}

    <!-- Preload fonts -->
    <link rel="preload" href="/fonts/DMSerifDisplay-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={localeISO[locale]} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:description" content={ogDescription} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Eddie Miller Agency",
        "description": "Votre activité est-elle recommandée quand un client demande à ChatGPT ? On vérifie gratuitement en 24h : score sur 100 et 3 actions concrètes.",
        "url": "https://eddiemiller.agency",
        "email": "contact@eddiemiller.agency",
        "logo": "https://eddiemiller.agency/favicon-192x192.png",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "41 Rue du Montparnasse",
          "postalCode": "75014",
          "addressLocality": "Paris",
          "addressCountry": "FR"
        },
        "areaServed": {
          "@type": "Place",
          "name": "Worldwide"
        },
        "serviceType": [
          "Visibilité en ligne pour activités locales",
          "Référencement Google Maps",
          "Optimisation Google Business Profile",
          "Visibilité sur les moteurs de recherche et assistants IA"
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Services pour aider les activités locales à être trouvées en ligne",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Diagnostic de visibilité gratuit",
                "description": "On vérifie si vos futurs clients vous trouvent sur Google et sur les IA. Vous recevez un score sur 100 et des recommandations concrètes.",
                "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" }
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Optimisation Google Maps et Google Business Profile",
                "description": "Votre fiche Google bien renseignée, de meilleurs avis, et plus de clients qui vous trouvent sur Google Maps."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Visibilité sur les assistants IA",
                "description": "Quand quelqu'un demande une recommandation à ChatGPT ou Gemini, votre activité apparaît dans les résultats."
              }
            }
          ]
        },
        "knowsLanguage": ["fr", "en"],
        "priceRange": "€€",
        "founder": {
          "@type": "Person",
          "name": "Adam Douieb"
        },
        "foundingDate": "2026",
        "openingHours": "Mo-Fr 09:00-18:00"
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": "Comment savoir si vos futurs clients vous trouvent en ligne",
        "description": "Trois étapes simples pour savoir si vos futurs clients vous trouvent en ligne, et comment améliorer votre visibilité.",
        "step": [
          {
            "@type": "HowToStep",
            "position": 1,
            "name": "Diagnostic gratuit",
            "text": "Nous vérifions si vos futurs clients vous trouvent sur Google et sur les IA. Vous recevez un score sur 100 et un diagnostic clair."
          },
          {
            "@type": "HowToStep",
            "position": 2,
            "name": "Plan d'action",
            "text": "Vous recevez un rapport avec les actions prioritaires, classées par impact et par effort. Pas de jargon."
          },
          {
            "@type": "HowToStep",
            "position": 3,
            "name": "Résultats",
            "text": "Nous mettons en place les corrections. Vos futurs clients vous trouvent, sur Google et sur les IA."
          }
        ]
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Combien ça coûte ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Le diagnostic initial est 100 % gratuit et sans engagement. Après le diagnostic, nous vous présentons les options adaptées à votre activité."
            }
          },
          {
            "@type": "Question",
            "name": "En combien de temps voit-on des résultats ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Les premiers résultats apparaissent entre 4 et 8 semaines. L'optimisation Google Business Profile peut produire des effets dès les premiers jours."
            }
          },
          {
            "@type": "Question",
            "name": "Quelle est la différence avec une agence web classique ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Une agence web classique vous aide à apparaître sur Google. Nous allons plus loin : on vous rend aussi visible dans les réponses des assistants IA comme ChatGPT ou Gemini, qui ne recommandent que 3 à 5 résultats."
            }
          },
          {
            "@type": "Question",
            "name": "Comment se déroule le diagnostic gratuit ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Vous remplissez le formulaire, notre équipe vérifie si vos futurs clients vous trouvent en ligne. Vous recevez un rapport sous 24 heures avec votre score sur 100 et vos actions prioritaires."
            }
          }
        ]
      }
    </script>

    <!-- Plausible Analytics -->
    <script is:inline async src="https://plausible.io/js/pa-V0XLRxsUEbXHqAAPrygvE.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>

  </head>
  <body class="bg-cream text-charcoal font-sans pb-16 md:pb-0">
    <!-- Language suggestion banner -->
    <div id="lang-banner" class="hidden fixed top-[57px] left-0 w-full z-40 bg-cream/95 backdrop-blur-sm border-b border-warmgray/30 py-2.5 px-4" role="alert">
      <div class="max-w-container mx-auto flex items-center justify-between gap-3">
        <p id="lang-banner-text" class="font-sans text-sm text-stone"></p>
        <div class="flex items-center gap-2 shrink-0">
          <a id="lang-banner-link" href="/" class="font-sans text-sm font-medium text-terracotta transition-colors duration-200 hover:text-terracotta-dark"></a>
          <button id="lang-banner-close" type="button" class="ml-2 text-stone hover:text-charcoal cursor-pointer bg-transparent border-none p-1" aria-label="Close">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </div>
      </div>
    </div>
    <slot />

    <!-- Sticky CTA bar — fixed at bottom of screen -->
    <div id="sticky-cta" class="fixed bottom-0 left-0 w-full z-40 backdrop-blur-sm py-3 px-4 md:py-3.5 md:px-6 sticky-cta-bar">
      <div class="max-w-container mx-auto flex items-center justify-between gap-4">
        <p class="sticky-cta-text font-sans text-sm text-stone leading-snug">
          {t('stickyCta.text', locale)}
        </p>
        <a
          href={nav.audit}
          class="sticky-cta-btn text-center inline-block px-6 py-3 font-sans font-medium text-sm text-cream bg-terracotta tracking-wider uppercase whitespace-nowrap transition-colors duration-300 hover:bg-terracotta-dark"
          onclick="plausible('CTA Click', {props: {location: 'sticky-bar'}})"
        >
          {t('stickyCta.button', locale)}
        </a>
      </div>
    </div>

    <!-- Sticky CTA visibility logic -->
    <script>
      const stickyCta = document.getElementById('sticky-cta');
      if (stickyCta) {
        const auditSection = document.getElementById('audit');
        let ticking = false;

        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const scrollY = window.scrollY;
              const show = scrollY > 400;

              // Hide when the audit form is visible on screen
              let auditVisible = false;
              if (auditSection) {
                const rect = auditSection.getBoundingClientRect();
                auditVisible = rect.top < window.innerHeight && rect.bottom > 0;
              }

              if (show && !auditVisible) {
                stickyCta.style.transform = 'translateY(0)';
              } else {
                stickyCta.style.transform = 'translateY(100%)';
              }
              ticking = false;
            });
            ticking = true;
          }
        });
      }
    </script>

    <!-- Intersection Observer for all scroll animations with stagger -->
    <script>
      // All animatable classes
      const animClasses = ['.fade-up', '.fade-up-slow', '.scale-in', '.slide-in-left', '.slide-in-right', '.blur-in', '.fade-in', '.draw-line', '.separator-animate', '.text-reveal-line'];

      // Respect prefers-reduced-motion
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced) {
        // Immediately show all elements
        document.querySelectorAll(animClasses.join(',')).forEach(el => {
          el.classList.add('visible');
        });
      } else {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll(animClasses.join(',')).forEach((el) => {
          // Stagger siblings within the same grid/flex parent
          const parent = el.parentElement;
          if (parent && (parent.classList.contains('grid') || parent.classList.contains('flex') || parent.classList.contains('space-y-0'))) {
            const selector = animClasses.map(c => `:scope > ${c}`).join(',');
            const siblings = Array.from(parent.querySelectorAll(selector));
            const index = siblings.indexOf(el);
            if (index > 0) {
              (el as HTMLElement).style.transitionDelay = `${index * 0.12}s`;
            }
          }
          observer.observe(el);
        });
      }
    </script>

    <!-- Language detection banner -->
    <script is:inline>
      (function() {
        if (sessionStorage.getItem('lang-banner-dismissed')) return;

        var pageLocale = document.documentElement.lang || 'fr';
        var browserLang = (navigator.language || '').split('-')[0].toLowerCase();
        var supported = ['fr','en','es','de','it','pt','nl'];

        if (!supported.includes(browserLang) || browserLang === pageLocale) return;

        var messages = {
          fr: { text: 'Cette page est aussi disponible en français.', cta: 'Passer au français', home: '/' },
          en: { text: 'This page is also available in English.', cta: 'Switch to English', home: '/en/' },
          es: { text: 'Esta página también está disponible en español.', cta: 'Cambiar a español', home: '/es/' },
          de: { text: 'Diese Seite ist auch auf Deutsch verfügbar.', cta: 'Zu Deutsch wechseln', home: '/de/' },
          it: { text: 'Questa pagina è disponibile anche in italiano.', cta: 'Passa all\'italiano', home: '/it/' },
          pt: { text: 'Esta página também está disponível em português.', cta: 'Mudar para português', home: '/pt/' },
          nl: { text: 'Deze pagina is ook beschikbaar in het Nederlands.', cta: 'Overschakelen naar Nederlands', home: '/nl/' }
        };

        var msg = messages[browserLang];
        if (!msg) return;

        var banner = document.getElementById('lang-banner');
        var text = document.getElementById('lang-banner-text');
        var link = document.getElementById('lang-banner-link');
        var close = document.getElementById('lang-banner-close');

        if (banner && text && link && close) {
          text.textContent = msg.text;
          link.textContent = msg.cta;
          link.href = msg.home;
          banner.classList.remove('hidden');

          close.addEventListener('click', function() {
            banner.classList.add('hidden');
            sessionStorage.setItem('lang-banner-dismissed', '1');
          });

          link.addEventListener('click', function() {
            sessionStorage.setItem('lang-banner-dismissed', '1');
          });
        }
      })();
    </script>
  </body>
</html>
